<style>
  .footer {
    background: var(--bg-elev);
    border-top: 1px solid var(--line);
    padding: 48px 0 32px;
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 28px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }
  .footer-brand {
    font-family: 'Sora', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }
  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-info-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-dim);
    text-decoration: none;
  }
  .footer-info-row svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--text-mute);
  }
  a.footer-info-row:hover { color: var(--text); }
  .footer-socials {
    display: flex;
    gap: 12px;
  }
  .footer-social {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .footer-social:hover {
    background: var(--brand-grad-soft);
    border-color: rgba(184,95,232,.3);
    color: var(--text);
  }
  .footer-social svg { width: 18px; height: 18px; }
  .footer-divider {
    border: none;
    border-top: 1px solid var(--line);
  }
  .footer-copy {
    font-size: 13px;
    color: var(--text-mute);
    text-align: center;
  }
  @media (max-width: 560px) {
    .footer-top { flex-direction: column; align-items: flex-start; }
    .footer-inner { padding: 0 20px; }
  }
</style>

