---
const year = new Date().getFullYear();
---

<footer class="relative bg-[var(--color-surface-elevated)] mt-12">
  <!-- Top divider (même pattern que Testimonials) -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-8 pb-14 lg:pt-10 lg:pb-16">
    <!-- Eyebrow + Brand -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
      <!-- Coordonnées -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-400)] mb-3">
          Nous trouver
        </span>
        <h3 class="font-display text-3xl font-extrabold tracking-tight text-white mb-5">
          VR Café
        </h3>
        <ul class="space-y-3 text-white/70 text-sm">
          <li class="flex items-start gap-3 justify-center md:justify-start">
            <svg class="w-5 h-5 shrink-0 mt-0.5 text-[var(--color-brand-300)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>2 rue du Pilou<br class="md:hidden" /> 66140 Canet-en-Roussillon</span>
          </li>
          <li class="flex items-center gap-3 justify-center md:justify-start">
            <svg class="w-5 h-5 shrink-0 text-[var(--color-brand-300)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+33671410695" class="hover:text-[var(--color-brand-300)] transition-colors duration-[var(--dur-fast)]">
              06 71 41 06 95
            </a>
          </li>
        </ul>
      </div>

      <!-- Réseaux sociaux -->
      <div class="flex flex-col items-center md:items-end gap-4">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-white/40">
          Suivez-nous
        </span>
        <div class="flex gap-3">
          <a
            href="https://www.facebook.com/vrcafe66"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook VR Café"
            class="group w-11 h-11 inline-flex items-center justify-center rounded-full bg-white/5 ring-1 ring-white/10 text-white/70 hover:text-white hover:ring-white/30 hover:-translate-y-0.5 transition-all duration-[var(--dur-base)] ease-[var(--ease-out-soft)]"
          >
            <span class="absolute -inset-px rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-[var(--dur-base)] bg-[var(--color-glow-blue)] -z-10 blur-md" aria-hidden="true"></span>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/vrcafe66/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram VR Café"
            class="group relative w-11 h-11 inline-flex items-center justify-center rounded-full bg-white/5 ring-1 ring-white/10 text-white/70 hover:text-white hover:ring-white/30 hover:-translate-y-0.5 transition-all duration-[var(--dur-base)] ease-[var(--ease-out-soft)]"
          >
            <span class="absolute -inset-px rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-[var(--dur-base)] -z-10 blur-md bg-gradient-to-br from-[var(--color-brand-500)] to-[var(--color-glow-pink)]" aria-hidden="true"></span>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent my-10"></div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row sm:justify-between items-center gap-3 text-xs text-white/40">
      <p>© {year} VR Café · Canet-en-Roussillon</p>
      <p>Fait à 10 min de Perpignan, avec passion.</p>
    </div>
  </div>
</footer>
