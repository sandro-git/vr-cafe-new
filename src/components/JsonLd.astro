---
// Rend un bloc JSON-LD. `schema` provient toujours d'une source de confiance
// (helpers seo.ts / CMS), donc pas d'échappement HTML supplémentaire requis.
interface Props {
  schema: Record<string, unknown>;
}
const { schema } = Astro.props;
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
