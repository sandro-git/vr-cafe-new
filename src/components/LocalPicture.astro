---
// src/components/LocalPicture.astro
// Replacement for SanityPicture using local images from public/
interface Props {
  image: string; // Path to image like "/images/games/slug.jpg"
  alt: string;
  className?: string;
  loading?: "lazy" | "eager";
}

const {
  image,
  alt,
  className = "",
  loading = "lazy",
} = Astro.props;
---

<img
  src={image}
  alt={alt}
  class={className}
  loading={loading}
  style="width: 100%; height: 100%; object-fit: cover; display: block;"
/>
