---
import { Image } from 'astro:assets';
import Ubisoft  from '../assets/ubisoft-white.webp';
import Wanadev  from '../assets/wanadev_studio.webp';
import Arvi     from '../assets/arvi_vr_white.webp';
import Ldlc     from '../assets/LDLC-VR-Studio.webp';
import VexPlay  from '../assets/VexPlayLight.webp';

const partenaires = [
  { src: Ubisoft, alt: 'Ubisoft', href: 'https://www.ubisoft.com/en-gb/entertainment/parks-experiences/escape-games' },
  { src: Wanadev, alt: 'Wanadev Studio', href: 'https://www.wanadevstudio.com/home' },
  { src: Arvi,    alt: 'ARVI VR',  href: 'https://vr.arvilab.com/' },
  { src: Ldlc,    alt: 'LDLC VR Studio', href: 'https://www.ldlc-vrstudio.com/' },
  { src: VexPlay, alt: 'VexPlay',  href: '#' },
];
---

<style>
  .ts-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .ts-card {
    padding: 28px 40px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 36px;
  }
  .ts-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ts-logos {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    align-items: center;
    gap: 28px;
    flex: 1;
    min-width: 0;
  }
  .ts-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    opacity: 0.7;
    filter: grayscale(1);
    transition: opacity 0.2s ease, filter 0.2s ease;
  }
  .ts-logo:hover {
    opacity: 1;
    filter: none;
  }
  .ts-logo img {
    height: 44px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .ts-card { padding: 24px 28px; flex-direction: column; align-items: flex-start; gap: 20px; }
    .ts-logos { grid-template-columns: repeat(3, 1fr); gap: 24px 28px; width: 100%; }
    .ts-logo img { height: 38px; }
  }
  @media (max-width: 480px) {
    .ts-card { padding: 22px 20px; gap: 18px; }
    .ts-logos { grid-template-columns: repeat(2, 1fr); gap: 22px 20px; }
    .ts-logo img { height: 32px; }
  }
</style>

<section aria-label="Éditeurs partenaires" style="padding: 0; background: var(--bg);">
  <div class="ts-wrap">
    <div class="ts-card">
      <span class="ts-label">Éditeurs partenaires</span>
      <div class="ts-logos">
        {partenaires.map(({ src, alt, href }) => (
          <a href={href} class="ts-logo" target="_blank" rel="noopener noreferrer" aria-label={alt} title={alt}>
            <Image src={src} alt={alt} height={56} loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
