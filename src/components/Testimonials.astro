---
import { loadQuery } from "../sanity/lib/load-query";
import { AVIS_QUERY } from "../sanity/lib/queries";

type Avis = {
  prenom: string;
  note: number;
  commentaire: string;
  dateVisite: string;
};

const FALLBACK: Avis[] = [
  { prenom: "Mathilde D.", note: 5, commentaire: "Anniversaire de mon fils (10 ans) avec 6 copains. L'équipe a été géniale, patiente, le matériel impeccable. Les enfants en parlent encore.", dateVisite: "2026-03-01" },
  { prenom: "Thomas V.", note: 5, commentaire: "Team building d'équipe (12 personnes). L'escape game VR a été un vrai révélateur des dynamiques de groupe. Debrief animé top. À refaire.", dateVisite: "2026-02-01" },
  { prenom: "Sophie L.", note: 5, commentaire: "On hésitait entre VR Café et un autre, on a bien fait de choisir Canet. Ambiance bar/terrasse vraiment cool, ça change d'une simple salle de jeux.", dateVisite: "2026-04-01" },
];

let avis: Avis[] = FALLBACK;
try {
  const { data } = await loadQuery<Avis[]>({ query: AVIS_QUERY });
  if (data && data.length > 0) avis = data;
} catch (_) {}

const STAR_PATH = "M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.37 1.12l1.07 3.29c.3.92-.76 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.18 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12L2.98 8.72c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z";
---

<style>
  .rev-section {
    padding: 96px 0;
    background: var(--bg-elev);
  }
  .rev-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* Header */
  .rev-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .rev-head h2 {
    font-size: clamp(32px, 3.8vw, 52px);
    font-weight: 700;
    margin-top: 12px;
    color: var(--text);
  }

  /* Google rating block */
  .google-rating {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }
  .google-big {
    font-family: 'Sora', sans-serif;
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1;
  }
  .google-right {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stars-row {
    display: flex;
    gap: 2px;
    color: var(--gold);
  }
  .stars-row svg { width: 14px; height: 14px; }
  .google-label {
    font-size: 13px;
    color: var(--text-mute);
  }
  .google-label b { color: var(--text-dim); }
  .google-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .google-link:hover { color: var(--text); }
  .google-link svg { width: 12px; height: 12px; }

  /* Grid */
  .rev-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* Card */
  .rev-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Avatar */
  .rev-avatar-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .rev-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--brand-grad);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-size: 15px;
    flex-shrink: 0;
  }
  .rev-who b { display: block; font-size: 14px; color: var(--text); }
  .rev-who span { font-size: 12px; color: var(--text-mute); }

  .rev-text {
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .rev-section { padding: 56px 0; }
    .rev-inner { padding: 0 20px; }
    .rev-head { gap: 24px; }
    .google-big { font-size: 36px; }
    .rev-grid {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 8px;
      scrollbar-width: none;
    }
    .rev-grid::-webkit-scrollbar { display: none; }
    .rev-card { flex-shrink: 0; width: 280px; scroll-snap-align: start; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .rev-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<section class="rev-section">
  <div class="rev-inner">

    <div class="rev-head">
      <div>
        <span class="kicker">Avis</span>
        <h2>Ce qu'on dit de nous,<br/>sans filtre.</h2>
      </div>
      <div class="google-rating">
        <div class="google-big">4,9</div>
        <div class="google-right">
          <div class="stars-row" aria-label="4,9 étoiles sur 5">
            {[0,1,2,3,4].map(() => (
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={STAR_PATH}/>
              </svg>
            ))}
          </div>
          <div class="google-label"><b>56 avis</b> · Google Reviews</div>
          <a
            class="google-link"
            href="https://www.google.com/maps/place/VR+Caf%C3%A9/@42.7025,3.0211,17z/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Voir tous les avis
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M9 7h8v8"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="rev-grid">
      {avis.slice(0, 3).map((a) => (
        <article class="rev-card">
          <div class="rev-avatar-row">
            <div class="rev-avatar">{a.prenom.charAt(0).toUpperCase()}</div>
            <div class="rev-who">
              <b>{a.prenom}</b>
              {a.dateVisite && (
                <span>
                  {new Date(a.dateVisite).toLocaleDateString("fr-FR", { month: "long", year: "numeric" })}
                </span>
              )}
            </div>
          </div>
          <div class="stars-row" aria-label={`${a.note} étoiles sur 5`}>
            {[0,1,2,3,4].map((i) => (
              <svg viewBox="0 0 20 20" fill={i < a.note ? "currentColor" : "none"} stroke="currentColor" stroke-width="0.5" aria-hidden="true">
                <path d={STAR_PATH}/>
              </svg>
            ))}
          </div>
          <p class="rev-text">« {a.commentaire} »</p>
        </article>
      ))}
    </div>

  </div>
</section>
