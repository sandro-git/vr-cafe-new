---
// src/components/SanityPicture.astro
// Image Sanity responsive : un seul <img srcset> multi-largeurs, la
// négociation de format (AVIF/WebP selon le navigateur) étant déléguée au
// CDN Sanity via auto=format. Crop carré conservé (aspect-square).
import { urlForImage } from "../sanity/lib/url-for-image";

interface Props {
  image: any;
  alt?: string | null;
  className?: string;
  sizes?: string;
  loading?: "lazy" | "eager";
}

const {
  image,
  alt,
  className,
  sizes = "(min-width: 1280px) 400px, (min-width: 768px) 33vw, 100vw",
  loading = "lazy",
} = Astro.props;

const base = urlForImage(image).auto("format");
const widths = [400, 600, 800, 1200, 1600];
const srcset = widths
  .map((w) => `${base.width(w).height(w).url()} ${w}w`)
  .join(", ");
---

<div class={`aspect-square overflow-hidden rounded-lg ${className || ""}`}>
  <img
    src={base.width(800).height(800).url()}
    srcset={srcset}
    sizes={sizes}
    alt={alt || image?.alt || "Image"}
    width={800}
    height={800}
    class="w-full h-full object-cover transition-transform duration-300 hover:scale-110"
    loading={loading}
    decoding="async"
  />
</div>
