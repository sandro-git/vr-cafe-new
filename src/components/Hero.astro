---
import { Image } from 'astro:assets';
import vrcafe from '../assets/vrcafe.webp';
---

<style>
  .hero-photo { aspect-ratio: 4/4.6; }
  @media (min-width: 1024px) { .hero-photo { aspect-ratio: 4/3.05; } }
</style>

<section class="relative overflow-hidden" style="padding: 128px 0 80px; background: var(--bg);">

  <!-- Halos décoratifs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute rounded-full blur-3xl"
         style="width:900px;height:500px;top:10%;right:15%;background:radial-gradient(circle,rgba(78,210,255,.12) 0%,transparent 70%)"></div>
    <div class="absolute rounded-full blur-3xl"
         style="width:700px;height:500px;bottom:15%;left:5%;background:radial-gradient(circle,rgba(184,95,232,.13) 0%,transparent 70%)"></div>
  </div>

  <div class="relative max-w-[1280px] mx-auto px-4 lg:px-7">

    <!-- ============================================================
         LAYOUT DESKTOP : grille 1.05fr / 1fr
         LAYOUT MOBILE  : colonne unique (photo en premier)
         ============================================================ -->
    <div class="flex flex-col lg:grid lg:items-start" style="gap:56px;grid-template-columns:1.05fr 1fr;">

      <!-- ──────────────────── COLONNE TEXTE (desktop) ──────────────────── -->
      <div class="hidden lg:flex flex-col order-1">

        <!-- H1 -->
        <h1 style="font-size:clamp(40px,5.4vw,76px);font-weight:700;letter-spacing:-0.035em;color:var(--text);">
          La réalité virtuelle,<br>version <span class="grad-text">café.</span>
        </h1>

        <!-- Sous-titre -->
        <p class="mt-6 leading-relaxed max-w-[540px]"
           style="font-size:18px;color:var(--text-dim);">
          Votre salle VR à Canet-en-Roussillon — 4 stations filaires, 1 arène free-roaming,
          20+ jeux, à 10 min de Perpignan.
        </p>

        <!-- Chips -->
        <div class="flex flex-wrap gap-2.5 mt-6">
          <!-- Note Google -->
          <div class="inline-flex items-center gap-2 rounded-full"
               style="padding:8px 12px;background:var(--surface);border:1px solid var(--line);font-size:13px;color:var(--text);">
            <span class="flex gap-px" style="color:var(--gold);">
              {[...Array(5)].map(() => (
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </span>
            <strong>4,9</strong> <span style="color:var(--text-dim);">(56 avis)</span>
          </div>
          <!-- Localisation -->
          <div class="inline-flex items-center gap-2 rounded-full"
               style="padding:8px 12px;background:var(--surface);border:1px solid var(--line);font-size:13px;color:var(--text);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            Canet-en-Roussillon · 10 min Perpignan
          </div>
          <!-- Prix -->
          <div class="inline-flex items-center gap-2 rounded-full"
               style="padding:8px 12px;background:var(--surface);border:1px solid var(--line);font-size:13px;color:var(--text);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            Dès 18 €/pers
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="/reservation"
             class="inline-flex items-center gap-2 rounded-full font-semibold transition-transform hover:-translate-y-px"
             style="padding:14px 22px;font-size:15px;background:var(--brand-grad);color:white;box-shadow:0 10px 30px -10px rgba(184,95,232,.6);">
            Réserver un créneau
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
          <a href="/jeux"
             class="inline-flex items-center gap-2 rounded-full font-semibold transition-transform hover:-translate-y-px"
             style="padding:14px 22px;font-size:15px;border:1px solid var(--line-strong);color:var(--text);">
            Découvrir nos jeux
          </a>
        </div>

        <!-- Trust line -->
        <p class="mt-9" style="font-size:12px;color:var(--text-mute);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
          <strong style="color:var(--text);">+12 000</strong> joueurs depuis 2023
          <span style="margin:0 10px;opacity:.4;">·</span>
          <strong style="color:var(--text);">20+</strong> jeux
          <span style="margin:0 10px;opacity:.4;">·</span>
          <strong style="color:var(--text);">4</strong> stations
          <span style="margin:0 10px;opacity:.4;">·</span>
          <strong style="color:var(--text);">1</strong> arène free-roaming
        </p>
      </div>

      <!-- ──────────────────── COLONNE PHOTO ──────────────────── -->
      <div class="relative order-2 lg:order-2">

        <!-- Conteneur photo : aspect 4/4.6 mobile → 4/3.05 desktop -->
        <div class="hero-photo relative overflow-hidden rounded-[22px] lg:rounded-[var(--r-xl)]"
             style="box-shadow:var(--shadow-lg);">

          <!-- Photo LCP (priorité maximale) -->
          <Image
            src={vrcafe}
            alt="Salle de réalité virtuelle VR Café Canet-en-Roussillon"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />

          <!-- Overlay gradient desktop (bas) -->
          <div class="absolute inset-0 hidden lg:block pointer-events-none"
               style="background:linear-gradient(180deg,transparent 55%,rgba(10,10,18,.55) 100%)"></div>

          <!-- Overlay gradient mobile (fort, noir 10→96%) -->
          <div class="absolute inset-0 lg:hidden pointer-events-none"
               style="background:linear-gradient(180deg,rgba(10,10,18,.10) 0%,rgba(10,10,18,.55) 50%,rgba(10,10,18,.96) 92%)"></div>

          <!-- ── MOBILE ONLY : rating superposé en haut ── -->
          <div class="absolute lg:hidden z-10 inline-flex items-center gap-1.5 rounded-full"
               style="top:38px;right:32px;padding:6px 10px;background:rgba(0,0,0,.55);border:1px solid rgba(255,255,255,.12);backdrop-filter:blur(8px);font-size:12px;color:white;">
            <span class="flex gap-px" style="color:var(--gold);">
              {[...Array(5)].map(() => (
                <svg width="11" height="11" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </span>
            <strong>4,9</strong>
          </div>

          <!-- ── MOBILE ONLY : H1 + sous-titre en bas de la photo ── -->
          <div class="absolute lg:hidden z-10" style="bottom:44px;left:32px;right:32px;">
            <h1 class="text-white font-extrabold"
                style="font-size:40px;letter-spacing:-0.04em;line-height:0.95;text-shadow:0 4px 30px rgba(0,0,0,.5);">
              La réalité virtuelle,<br>version <span class="grad-text">café.</span>
            </h1>
            <p class="mt-3.5 leading-relaxed" style="font-size:15px;color:rgba(255,255,255,.82);">
              Votre salle VR à Canet-en-Roussillon, à 10 min de Perpignan.
            </p>
          </div>

        </div><!-- /photo container -->

        <!-- ── MOBILE ONLY : chips sous la photo ── -->
        <div class="flex flex-wrap gap-2 lg:hidden mt-0 pt-3">
          <div class="inline-flex items-center gap-2 rounded-full"
               style="padding:9px 14px;background:var(--surface);border:1px solid var(--line);font-size:14px;color:var(--text);">
            <span class="flex gap-px" style="color:var(--gold);">
              {[...Array(5)].map(() => (
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </span>
            <strong>4,9</strong> <span style="color:var(--text-dim);">(56 avis)</span>
          </div>
          <div class="inline-flex items-center gap-2 rounded-full"
               style="padding:9px 14px;background:var(--surface);border:1px solid var(--line);font-size:14px;color:var(--text);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--brand-cyan);">
              <path d="M12 2C8.134 2 5 5.134 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.866-3.134-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            Canet · 10 min Perpignan
          </div>
          <div class="inline-flex items-center gap-2 rounded-full"
               style="padding:9px 14px;background:var(--surface);border:1px solid var(--line);font-size:14px;color:var(--text);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--brand-cyan);">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            Dès 18 €/pers
          </div>
        </div>

        <!-- ── MOBILE ONLY : CTAs en row ── -->
        <div class="flex gap-2.5 lg:hidden mt-4">
          <a href="/reservation"
             class="flex-1 inline-flex items-center justify-center gap-2 rounded-[14px] font-bold transition-transform active:scale-95"
             style="height:52px;font-size:15px;background:var(--brand-grad);color:white;box-shadow:0 12px 30px -10px rgba(184,95,232,.6);">
            Réserver un créneau
          </a>
          <!-- Appel rapide mobile (48×48 min) -->
          <a href="tel:+33671410695"
             class="flex-shrink-0 inline-flex items-center justify-center rounded-[14px] transition-transform active:scale-95"
             aria-label="Appeler le VR Café"
             style="width:52px;height:52px;background:var(--surface);border:1px solid var(--line);color:var(--text);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1.18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 9.06a16 16 0 006.85 6.85l1.45-1.41a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </a>
        </div>

      </div><!-- /photo column -->

    </div><!-- /grid -->
  </div><!-- /container -->
</section>
