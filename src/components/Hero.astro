---
import Button from "./Button.astro";
---

<section class="relative isolate overflow-hidden mesh-bg">
  <!-- Floating orbs -->
  <div
    class="orb"
    style="width: 480px; height: 480px; background: var(--color-brand-500); top: -120px; left: -120px; animation-delay: 0s;"
    aria-hidden="true"
  ></div>
  <div
    class="orb"
    style="width: 380px; height: 380px; background: var(--color-glow-pink); top: 40%; right: -100px; animation-delay: -4s;"
    aria-hidden="true"
  ></div>
  <div
    class="orb"
    style="width: 420px; height: 420px; background: var(--color-glow-blue); bottom: -160px; left: 30%; animation-delay: -8s;"
    aria-hidden="true"
  ></div>

  <!-- Grid noise overlay -->
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 48px 48px;"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
    <!-- Eyebrow -->
    <div class="reveal flex justify-center mb-6">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 backdrop-blur-md px-4 py-1.5 text-xs font-medium text-white/80">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-glow-cyan)] opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-glow-cyan)]"></span>
        </span>
        Canet-en-Roussillon · à 10 min de Perpignan
      </span>
    </div>

    <!-- Title -->
    <h1 class="reveal text-center mx-auto max-w-5xl text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-[1.05] tracking-tight text-white">
      Plongez dans
      <span class="text-shimmer block sm:inline">d'autres mondes.</span>
      <span class="block text-white/90 text-3xl sm:text-4xl lg:text-5xl font-bold mt-4">
        Sans bouger de Canet.
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal text-center mx-auto max-w-2xl mt-8 text-lg sm:text-xl text-white/70 leading-relaxed">
      Escape games, free roaming, jeux multi-joueurs : vivez la réalité virtuelle
      nouvelle génération dans un espace pensé pour vous, en famille, entre amis
      ou en équipe.
    </p>

    <!-- CTAs -->
    <div class="reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button href="/reservation" variant="primary" size="lg" pulse>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        Réserver maintenant
      </Button>
      <Button href="/jeux" variant="secondary" size="lg">
        Découvrir nos jeux
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </Button>
    </div>

    <!-- Trust strip -->
    <div class="reveal mt-16 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-white/60 text-sm">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-[var(--color-accent-400)]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        <span><strong class="text-white">4,9/5</strong> · 56 avis Google</span>
      </div>
      <div class="hidden sm:block w-px h-4 bg-white/15"></div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-[var(--color-glow-cyan)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        <span>Réservation en ligne · 24h/24</span>
      </div>
      <div class="hidden sm:block w-px h-4 bg-white/15"></div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-[var(--color-glow-pink)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-8a4 4 0 11-8 0 4 4 0 018 0zm6 3a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>De 7 à 77 ans</span>
      </div>
    </div>
  </div>

  <!-- Scroll cue desktop (texte + ligne) -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 text-white/40" aria-hidden="true">
    <span class="text-[10px] uppercase tracking-[0.2em]">Scroll</span>
    <span class="w-px h-10 bg-gradient-to-b from-white/40 to-transparent"></span>
  </div>

  <!-- Scroll cue mobile (chevron rebondissant) -->
  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex lg:hidden text-white/50 bounce-soft" aria-hidden="true">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
