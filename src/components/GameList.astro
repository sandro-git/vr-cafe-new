---
import Card from "../components/Card.astro";
const { experiences } = Astro.props;
// Interface pour les données spécifiques à l'expérience (Keystatic format)
interface Experience {
  name: string;
  description?: string | (() => Promise<any>);
  image: string; // Local path like "/images/games/slug.jpg"
  imageAlt: string;
  tag?: {
    title: string;
  };
  slug: string;
}
---

<div
  class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 container mx-auto px-4 max-w-7xl"
>
  {
    experiences.map((exp: Experience) => (
      <div class="w-full">
        <Card
          game={{
            ...exp,
            image: exp.image,
          }}
          slug={exp.slug}
        />
      </div>
    ))
  }
</div>
