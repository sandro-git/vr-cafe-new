---
import Pricing5, { type PricingPlan } from "./Pricing5.astro";

const plans: PricingPlan[] = [
  {
    name: "Starter",
    description: "Perfect for individuals",
    price: "$12",
    period: "per month",
    features: [
      { text: "Up to 5 projects", included: true },
      { text: "Basic analytics", included: true },
      { text: "Email support", included: true },
      { text: "1GB storage", included: true },
    ],
    buttonText: "Get Started",
    buttonHref: "/signup?plan=starter",
  },
  {
    name: "Professional",
    description: "For growing teams and businesses",
    price: "$29",
    period: "per month",
    features: [
      { text: "Unlimited projects", included: true },
      { text: "Advanced analytics", included: true },
      { text: "24/7 priority support", included: true },
      { text: "50GB storage", included: true },
      { text: "Custom integrations", included: true },
      { text: "API access", included: true },
    ],
    buttonText: "Get Started",
    buttonHref: "/signup?plan=professional",
    highlighted: true,
    badge: "Most Popular",
  },
  {
    name: "Enterprise",
    description: "For large organizations",
    price: "$99",
    period: "per month",
    features: [
      { text: "Unlimited everything", included: true },
      { text: "Advanced analytics & insights", included: true },
      { text: "Dedicated support team", included: true },
      { text: "Unlimited storage", included: true },
      { text: "Custom integrations", included: true },
      { text: "API access", included: true },
      { text: "SLA guarantee", included: true },
    ],
    buttonText: "Contact Sales",
    buttonHref: "/contact?plan=enterprise",
  },
];
---

<Pricing5
  heading="Pricing Plans"
  description="Choose the perfect plan for your team. Start with a free trial on any plan."
  plans={plans}
/>
