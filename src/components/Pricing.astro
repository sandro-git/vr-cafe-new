---
import PricingCard from "./PricingCard.astro";
import { sanityClient } from "sanity:client";

type Tarif = {
  _id: string;
  name: string;
  prix: number;
  description?: string;
  isPromo: boolean;
  nbJoueurs: number;
  dureeMinutes: number;
};

const FALLBACK: Tarif[] = [
  { _id: "1", name: "30 min", prix: 18, isPromo: false, nbJoueurs: 1, dureeMinutes: 30 },
  { _id: "2", name: "1 Heure", prix: 25, isPromo: true, nbJoueurs: 1, dureeMinutes: 60 },
  { _id: "3", name: "Anniversaire", prix: 25, isPromo: false, nbJoueurs: 1, dureeMinutes: 60 },
];

const data = await sanityClient.fetch<Tarif[]>(
  `*[_type == "tarif"] | order(ordre asc) { _id, name, prix, description, isPromo, nbJoueurs, dureeMinutes }`
);

const tarifs = data?.length > 0 ? data : FALLBACK;
---

<div
  class="md:container mx-4 md:mx-auto flex flex-col lg:flex-row gap-6 md:gap-8 md:justify-center items-center md:items-stretch pt-6 pb-12 flex-wrap"
>
  {tarifs.map((tarif) => (
    <PricingCard
      title={tarif.name}
      price={String(tarif.prix)}
      popular={tarif.isPromo}
      type={tarif.name.toLowerCase().includes("anniversaire") ? "birthday" : "standard"}
      features={tarif.description ? tarif.description.split("\n").filter(Boolean) : undefined}
    />
  ))}
</div>
