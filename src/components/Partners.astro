---
import Image from "astro/components/Image.astro";
import Arvi from "../assets/arvi_vr_white.webp";
import Ubisoft from "../assets/ubisoft-white.webp";
import Wanadev from "../assets/wanadev_studio.webp";
import Ldlc from "../assets/LDLC-VR-Studio.webp";

const partners = [
  { src: Ubisoft, alt: "Ubisoft logo", href: "https://www.ubisoft.com/en-gb/entertainment/parks-experiences/escape-games", label: "Ubisoft" },
  { src: Wanadev, alt: "Wanadev Studio logo", href: "https://www.wanadevstudio.com/home", label: "Wanadev Studio" },
  { src: Arvi, alt: "ARVI VR logo", href: "https://vr.arvilab.com/", label: "ARVI VR" },
  { src: Ldlc, alt: "LDLC VR Studio logo", href: "https://www.ldlc-vrstudio.com/", label: "LDLC VR Studio" },
];

// Doubler la liste pour un marquee continu sans saut
const loop = [...partners, ...partners];
---

<section class="relative bg-[var(--color-surface)] py-20 lg:py-24 overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal text-center mb-12">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-400)] mb-3">
        Studios partenaires
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white">
        Les meilleurs créateurs VR du monde, <span class="text-shimmer">chez nous.</span>
      </h2>
    </div>
  </div>

  <!-- Marquee -->
  <div
    class="reveal-fade relative w-full overflow-hidden"
    style="mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent); -webkit-mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);"
  >
    <div class="marquee-track gap-16 lg:gap-24 items-center py-4">
      {loop.map((p, i) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={p.label}
          aria-hidden={i >= partners.length ? "true" : "false"}
          tabindex={i >= partners.length ? -1 : 0}
          class="shrink-0 opacity-60 hover:opacity-100 transition-opacity duration-[var(--dur-base)] grayscale hover:grayscale-0"
        >
          <Image src={p.src} alt={p.alt} class="h-10 lg:h-12 w-auto" height={48} />
        </a>
      ))}
    </div>
  </div>
</section>
