---
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "ghost" | "accent";
  size?: "sm" | "md" | "lg";
  target?: string;
  rel?: string;
  ariaLabel?: string;
  class?: string;
  pulse?: boolean;
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  target,
  rel,
  ariaLabel,
  class: className = "",
  pulse = false,
} = Astro.props;

const base =
  "group relative inline-flex items-center justify-center gap-2 font-semibold tracking-tight rounded-full transition-all duration-[var(--dur-base)] ease-[var(--ease-out-soft)] focus:outline-none";

const sizes = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-base",
  lg: "px-8 py-4 text-lg",
}[size];

const variants = {
  primary:
    "bg-white text-[--color-brand-900] hover:bg-[--color-accent-300] hover:-translate-y-0.5 shadow-[0_10px_40px_-10px_rgba(139,92,246,0.6)]",
  secondary:
    "bg-transparent text-white border border-white/30 hover:bg-white/10 hover:border-white/60 backdrop-blur-sm",
  ghost:
    "bg-transparent text-[--color-text-base] hover:text-white hover:bg-white/5",
  accent:
    "bg-[--color-accent-400] text-[--color-brand-900] hover:bg-[--color-accent-300] hover:-translate-y-0.5 shadow-[0_10px_30px_-10px_rgba(234,179,8,0.6)]",
}[variant];

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  class:list={[base, sizes, variants, pulse && "pulse-ring", className]}
>
  <slot />
</Tag>
