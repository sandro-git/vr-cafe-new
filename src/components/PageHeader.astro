---
interface Props {
  eyebrow?: string;
  title: string;
  highlight?: string;
  subtitle?: string;
  align?: "center" | "left";
  class?: string;
}

const {
  eyebrow,
  title,
  highlight,
  subtitle,
  align = "center",
  class: className = "",
} = Astro.props;

// Découpe le titre autour du highlight pour appliquer text-shimmer
let before = title;
let after = "";
let hl = "";
if (highlight && title.includes(highlight)) {
  const idx = title.indexOf(highlight);
  before = title.slice(0, idx);
  hl = highlight;
  after = title.slice(idx + highlight.length);
}

const alignClass = align === "center" ? "text-center mx-auto items-center" : "text-left items-start";
---

<header
  class:list={[
    "reveal relative flex flex-col gap-4 pt-8 sm:pt-10 pb-10 px-4 sm:px-6 lg:px-8 max-w-4xl",
    alignClass,
    className,
  ]}
>
  {eyebrow && (
    <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-400)]">
      {eyebrow}
    </span>
  )}
  <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.05]">
    {hl ? (
      <>{before}<span class="text-shimmer">{hl}</span>{after}</>
    ) : (
      title
    )}
  </h1>
  {subtitle && (
    <p class:list={["text-lg text-white/70 leading-relaxed", align === "center" ? "max-w-2xl mx-auto" : "max-w-2xl"]}>
      {subtitle}
    </p>
  )}
</header>
