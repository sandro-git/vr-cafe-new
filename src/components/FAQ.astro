---
import { sanityClient } from "sanity:client";

type FaqItem = { question: string; answer: string };
type SanityBlock = { children?: { text: string }[] };

const FALLBACK_FAQS: FaqItem[] = [
  {
    question: "Qu'est-ce qu'un escape game en réalité virtuelle ?",
    answer: "La VR (Réalité Virtuelle) est un monde généré par ordinateur. Vous y accéderez à l'aide d'un casque. Une fois à l'intérieur, l'objectif est de collaborer pour réussir une ou plusieurs missions dans un temps imparti.",
  },
  {
    question: "Je porte des lunettes, est-ce compatible ?",
    answer: "La plupart des lunettes peuvent être portées à l'intérieur de nos casques, mais la VR est plus confortable sans lunettes. Les lentilles de contact sont vos alliées si vous pouvez en porter.",
  },
  {
    question: "Y aura-t-il d'autres personnes dans notre partie ?",
    answer: "Non. Votre réservation est privée, la partie est exclusivement pour votre groupe.",
  },
  {
    question: "Vos jeux sont-ils adaptés aux enfants ?",
    answer: "Nous conseillons de ne pas faire venir des enfants de moins de 7 ans (taille des casques). La plupart de nos jeux conviennent aux enfants — notre équipe vous conseillera le titre le plus adapté à l'âge de vos enfants.",
  },
  {
    question: "Peut-on avoir le mal des transports en VR ?",
    answer: "Très rarement dans nos installations. Le mal de VR survient quand le cerveau perçoit un mouvement sans que le corps bouge. Ici vous vous déplacez réellement dans l'espace, ce qui rend l'expérience naturelle.",
  },
  {
    question: "Le site est-il accessible aux personnes en fauteuil roulant ?",
    answer: "Oui pour les espaces filaires — aucune marche n'est requise. L'arène free-roaming nécessite malheureusement de se déplacer et n'est pas accessible aux PMR.",
  },
  {
    question: "Peut-on annuler ou reporter une réservation ?",
    answer: "Oui, jusqu'à 24h avant votre créneau. Contactez-nous par téléphone ou par email pour organiser le report.",
  },
  {
    question: "Faut-il réserver à l'avance ?",
    answer: "La réservation en ligne est possible jusqu'à 1h avant le créneau. Pour les groupes de 6+ personnes nous recommandons de réserver plusieurs jours à l'avance pour garantir la disponibilité.",
  },
  {
    question: "C'est quoi le free-roaming ?",
    answer: "Le free-roaming est notre arène sans fil de 60 m². Vous portez un casque autonome et vous déplacez librement — pas de câbles, pas de manettes. Jusqu'à 8 joueurs peuvent s'affronter ou coopérer simultanément.",
  },
  {
    question: "Vous convient-il pour un événement de groupe ou d'entreprise ?",
    answer: "Absolument. Nous proposons des formules team building, anniversaires, EVG/EVJF et séminaires. Contactez-nous pour un devis personnalisé en moins de 24h.",
  },
];

const extractText = (blocks: SanityBlock[]) =>
  blocks?.map((b) => b.children?.map((c) => c.text).join("")).join("\n") ?? "";

const {
  faqs: propFaqs,
  showCTA = true,
  ctaLink = "/contact",
} = Astro.props;

let faqs: FaqItem[] = propFaqs ?? [];

if (faqs.length === 0) {
  try {
    const data = await sanityClient.fetch<{ question: string; reponse: SanityBlock[] }[]>(
      `*[_type == "faq"] | order(ordre asc) { question, reponse }`
    );
    if (data?.length > 0) {
      faqs = data.map((f) => ({ question: f.question, answer: extractText(f.reponse) }));
    } else {
      faqs = FALLBACK_FAQS;
    }
  } catch (_) {
    faqs = FALLBACK_FAQS;
  }
}

const mid = Math.ceil(faqs.length / 2);
const col1 = faqs.slice(0, mid);
const col2 = faqs.slice(mid);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
};
---

<style>
  .faq-section {
    padding: 96px 0;
    background: var(--bg);
  }
  .faq-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .faq-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }
  .faq-header h2 {
    font-size: clamp(32px, 3.8vw, 52px);
    font-weight: 700;
    margin-top: 12px;
    color: var(--text);
  }

  /* 2-column grid */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 40px;
    align-items: start;
  }

  /* Individual item */
  .faq-item {
    border-bottom: 1px solid var(--line);
  }
  .faq-item:first-child {
    border-top: 1px solid var(--line);
  }

  summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    user-select: none;
  }
  summary::-webkit-details-marker { display: none; }

  .faq-chevron {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--text-mute);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  details[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--brand-violet);
  }
  details[open] summary {
    color: var(--brand-violet);
  }

  .faq-answer {
    padding: 0 0 20px;
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.65;
  }

  /* CTA */
  .faq-cta {
    margin-top: 56px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .faq-cta p {
    color: var(--text-dim);
    font-size: 16px;
  }
  .faq-cta a {
    display: inline-block;
    padding: 14px 32px;
    border-radius: var(--r-md);
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--text);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .faq-cta a:hover {
    border-color: var(--line-strong);
    background: var(--surface-2);
  }

  @media (max-width: 767px) {
    .faq-section { padding: 56px 0; }
    .faq-inner { padding: 0 20px; }
    .faq-header { gap: 20px; }
    .faq-grid { grid-template-columns: 1fr; gap: 0; }
    .faq-col:last-child .faq-item:first-child { border-top: none; }
  }
</style>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<section class="faq-section">
  <div class="faq-inner">

    <div class="faq-header">
      <div>
        <span class="kicker">FAQ</span>
        <h2>Questions fréquentes.</h2>
      </div>
    </div>

    <div class="faq-grid">
      {[col1, col2].map((col) => (
        <div class="faq-col">
          {col.map((faq) => (
            <details class="faq-item">
              <summary>
                {faq.question}
                <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </summary>
              <p class="faq-answer">{faq.answer}</p>
            </details>
          ))}
        </div>
      ))}
    </div>

    {showCTA && (
      <div class="faq-cta">
        <p>Vous avez d'autres questions ?</p>
        <a href={ctaLink}>Contactez-nous</a>
      </div>
    )}

  </div>
</section>
