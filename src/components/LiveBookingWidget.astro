---
// Widget de réservation rapide — redirige vers /reservation avec les paramètres pré-remplis
// Durées disponibles : 30 min et 1 heure UNIQUEMENT (pas de 1h30)
---

<style>
  .lbw {
    padding: 0 0 0;
    background: var(--bg);
  }
  .lbw-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .lbw-card {
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr auto;
    gap: 12px;
    align-items: end;
  }
  @media (max-width: 900px) {
    .lbw-card { grid-template-columns: 1fr 1fr; }
    .lbw-submit { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .lbw-inner { padding: 0 16px; }
    .lbw-card { grid-template-columns: 1fr 1fr; }
    .lbw-dur  { grid-column: 1 / -1; }
    .lbw-submit { grid-column: 1 / -1; }
  }

  .lbw-label {
    display: block;
    font-size: 11px;
    color: var(--text-mute);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-family: 'JetBrains Mono', monospace;
  }

  .lbw-field {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 52px;
    cursor: pointer;
    transition: border-color .15s;
  }
  .lbw-field:hover { border-color: var(--line-strong); }
  .lbw-field svg { width: 18px; height: 18px; color: var(--text-mute); flex-shrink: 0; }
  .lbw-v  { font-size: 14px; font-weight: 600; color: var(--text); }
  .lbw-sub { font-size: 11px; color: var(--text-mute); margin-top: 1px; }

  /* Date input overlay — invisible mais cliquable */
  .lbw-date-wrap { position: relative; }
  .lbw-date-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
    font-size: 16px; /* évite le zoom iOS */
  }

  /* Stepper */
  .lbw-stepper { display: flex; gap: 6px; margin-left: auto; flex-shrink: 0; }
  .lbw-stepper button {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--surface-2);
    border: 1px solid var(--line-strong);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    transition: background .15s;
    /* Touch target ≥ 44px via padding */
    padding: 0;
    min-width: 28px;
    min-height: 28px;
  }
  .lbw-stepper button:hover { background: var(--line-strong); }
  .lbw-stepper button:disabled { opacity: .35; cursor: not-allowed; }

  /* Segmented control */
  .lbw-seg {
    display: flex;
    gap: 2px;
    padding: 3px;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    width: 100%;
    min-height: 52px;
    align-items: center;
  }
  .lbw-seg button {
    flex: 1;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    cursor: pointer;
    transition: background .15s, color .15s;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .lbw-seg button[aria-selected="true"] {
    background: var(--surface);
    color: var(--text);
    border-color: var(--line-strong);
  }

  /* Submit */
  .lbw-submit {
    padding: 0 22px;
    border-radius: var(--r-md);
    background: var(--brand-grad);
    color: white;
    font-weight: 700;
    font-size: 15px;
    min-height: 52px;
    white-space: nowrap;
    cursor: pointer;
    transition: transform .15s ease, opacity .15s;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 10px 30px -10px rgba(184,95,232,.6);
  }
  .lbw-submit:hover { transform: translateY(-1px); opacity: .92; }
</style>

<section class="lbw" aria-label="Réservation rapide">
  <div class="lbw-inner">
    <div class="lbw-card">

      <!-- ── DATE ── -->
      <div>
        <span class="lbw-label">Date</span>
        <div class="lbw-field lbw-date-wrap" id="lbw-date-field">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="5" width="18" height="16" rx="2"/>
            <path d="M8 3v4M16 3v4M3 11h18"/>
          </svg>
          <div>
            <div class="lbw-v" id="lbw-date-label">—</div>
            <div class="lbw-sub" id="lbw-hours-label">14h – 22h</div>
          </div>
          <input
            type="date"
            id="lbw-date-input"
            class="lbw-date-input"
            aria-label="Choisir une date"
          />
        </div>
      </div>

      <!-- ── JOUEURS ── -->
      <div>
        <span class="lbw-label">Joueurs</span>
        <div class="lbw-field" id="lbw-players-field">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="9" cy="8" r="3"/>
            <path d="M3 21c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
            <circle cx="17" cy="6" r="2.5"/>
            <path d="M15 14c1.4-.6 2.7-1 4-1 2.2 0 4 1.8 4 4"/>
          </svg>
          <div>
            <div class="lbw-v" id="lbw-count-label">2 personnes</div>
            <div class="lbw-sub" id="lbw-price-label">— 29 €/pers</div>
          </div>
          <div class="lbw-stepper" role="group" aria-label="Nombre de joueurs">
            <button id="lbw-dec" aria-label="Diminuer" disabled>−</button>
            <button id="lbw-inc" aria-label="Augmenter">+</button>
          </div>
        </div>
      </div>

      <!-- ── DURÉE ── -->
      <div class="lbw-dur">
        <span class="lbw-label">Durée</span>
        <div class="lbw-seg" role="group" aria-label="Durée de session">
          <button
            id="lbw-btn-30"
            data-dur="30"
            aria-selected="false"
          >30 min</button>
          <button
            id="lbw-btn-60"
            data-dur="60"
            aria-selected="true"
          >1 heure</button>
        </div>
      </div>

      <!-- ── SUBMIT ── -->
      <button class="lbw-submit" id="lbw-submit" type="button">
        Voir les créneaux
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>

    </div><!-- /lbw-card -->
  </div><!-- /lbw-inner -->
</section>

<script>
(function () {
  /* ── Jours ouverts (hors vacances) : dim=0, mer=3, ven=5, sam=6 ── */
  const OPEN_DAYS = new Set([0, 3, 5, 6]);
  const JOURS   = ['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
  const MOIS    = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];

  /* ── Tarifs ── */
  const PRIX = {
    30: () => 18,
    60: (n) => n >= 5 ? 25 : n >= 3 ? 27 : 29,
  };

  /* ── État ── */
  let joueurs = 2;
  let duree   = 60;
  let dateISO = '';

  /* ── Éléments DOM ── */
  const dateInput  = document.getElementById('lbw-date-input');
  const dateLabel  = document.getElementById('lbw-date-label');
  const hoursLabel = document.getElementById('lbw-hours-label');
  const countLabel = document.getElementById('lbw-count-label');
  const priceLabel = document.getElementById('lbw-price-label');
  const decBtn     = document.getElementById('lbw-dec');
  const incBtn     = document.getElementById('lbw-inc');
  const btn30      = document.getElementById('lbw-btn-30');
  const btn60      = document.getElementById('lbw-btn-60');
  const submitBtn  = document.getElementById('lbw-submit');

  /* ── Prochain jour ouvert (à partir de demain) ── */
  function nextOpenDay() {
    const d = new Date();
    d.setDate(d.getDate() + 1);
    d.setHours(0, 0, 0, 0);
    for (let i = 0; i < 7; i++) {
      if (OPEN_DAYS.has(d.getDay())) return d;
      d.setDate(d.getDate() + 1);
    }
    return d;
  }

  /* ── Format YYYY-MM-DD pour l'input ── */
  function toISO(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const j = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${j}`;
  }

  /* ── Affichage de la date ── */
  function updateDateDisplay(d) {
    dateLabel.textContent = `${JOURS[d.getDay()]} ${d.getDate()} ${MOIS[d.getMonth()]}`;
    hoursLabel.textContent = '14h – 22h';
  }

  /* ── Affichage des joueurs + prix ── */
  function updatePlayers() {
    countLabel.textContent = joueurs === 1 ? '1 personne' : `${joueurs} personnes`;
    const p = PRIX[duree](joueurs);
    priceLabel.textContent = `— ${p} €/pers`;
    decBtn.disabled = joueurs <= 1;
    incBtn.disabled = joueurs >= 6;
  }

  /* ── Durée ── */
  function selectDur(val) {
    duree = val;
    btn30.setAttribute('aria-selected', val === 30 ? 'true' : 'false');
    btn60.setAttribute('aria-selected', val === 60 ? 'true' : 'false');
    updatePlayers();
  }

  /* ── Init ── */
  const defaultDate = nextOpenDay();
  dateISO = toISO(defaultDate);
  dateInput.value = dateISO;
  /* Min = demain, max = dans 60 jours */
  const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);
  const maxDate  = new Date(); maxDate.setDate(maxDate.getDate() + 60);
  dateInput.min = toISO(tomorrow);
  dateInput.max = toISO(maxDate);
  updateDateDisplay(defaultDate);
  updatePlayers();

  /* ── Listeners ── */
  dateInput.addEventListener('change', (e) => {
    if (!e.target.value) return;
    dateISO = e.target.value;
    const [y, m, d] = dateISO.split('-').map(Number);
    updateDateDisplay(new Date(y, m - 1, d));
  });

  decBtn.addEventListener('click', () => { if (joueurs > 1) { joueurs--; updatePlayers(); } });
  incBtn.addEventListener('click', () => { if (joueurs < 6) { joueurs++; updatePlayers(); } });

  btn30.addEventListener('click', () => selectDur(30));
  btn60.addEventListener('click', () => selectDur(60));

  submitBtn.addEventListener('click', () => {
    const params = new URLSearchParams({ date: dateISO, joueurs: String(joueurs), duree: String(duree) });
    window.location.href = `/reservation?${params.toString()}`;
  });
})();
</script>
