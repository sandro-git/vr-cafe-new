---
import Logo from "../assets/logo.webp";
import { Image } from "astro:assets";

const currentPath = Astro.url.pathname;

const isExperiencesSubmenu =
  currentPath.includes("/escapes") ||
  currentPath.includes("/jeux") ||
  currentPath.includes("/freeroaming") ||
  currentPath.includes("/escapesFreeroaming");

const isOccasionsSubmenu =
  currentPath === "/anniversaire" || currentPath === "/anniversaire/" ||
  currentPath === "/team-building" || currentPath === "/team-building/" ||
  currentPath === "/evg-evjf" || currentPath === "/evg-evjf/";

const isActive = (path: string) =>
  currentPath === path || currentPath === `${path}/`;

// Items dropdowns avec icônes SVG + descriptions
const experiencesItems = [
  {
    href: "/escapes",
    title: "Escape Games VR",
    desc: "Missions immersives, jusqu'à 6 joueurs",
    accent: "from-[var(--color-brand-500)] to-[var(--color-glow-pink)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11V7a4 4 0 118 0v4m-9 0h10a2 2 0 012 2v6a2 2 0 01-2 2H11a2 2 0 01-2-2v-6a2 2 0 012-2z"/>`,
  },
  {
    href: "/escapesFreeroaming",
    title: "Escape Games Sans Fil",
    desc: "Liberté de mouvement totale",
    accent: "from-[var(--color-glow-cyan)] to-[var(--color-brand-500)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11V7a4 4 0 118 0v4m-9 0h10a2 2 0 012 2v6a2 2 0 01-2 2H11a2 2 0 01-2-2v-6a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13c1.5-1.5 3-1.5 4.5 0M3 17c2.5-2 5-2 7.5 0" opacity="0.6"/>`,
  },
  {
    href: "/jeux",
    title: "Jeux VR",
    desc: "Arcade, sports, simulateurs",
    accent: "from-[var(--color-glow-blue)] to-[var(--color-brand-500)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12h2m-1-1v2m6-1h.01M17 12h.01M5 7h14a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2V9a2 2 0 012-2z"/>`,
  },
  {
    href: "/freeroaming",
    title: "Jeux Sans Fil",
    desc: "Free roaming multi-joueurs",
    accent: "from-[var(--color-accent-400)] to-[var(--color-glow-pink)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12h2m-1-1v2m6-1h.01M17 12h.01M5 7h14a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2V9a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M1 14c1-1 2-1 3 0M20 14c1-1 2-1 3 0" opacity="0.6"/>`,
  },
];

const occasionsItems = [
  {
    href: "/anniversaire",
    title: "Anniversaire",
    desc: "Enfants & ados, formules clé en main",
    accent: "from-[var(--color-glow-pink)] to-[var(--color-accent-400)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V3m-3 3h6M5 10h14v9a1 1 0 01-1 1H6a1 1 0 01-1-1v-9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14c0-1 1-2 2-2s2 1 2 2-1 2-2 2-2-1-2-2zM15 14c0-1 1-2 2-2"/>`,
  },
  {
    href: "/team-building",
    title: "Team Building",
    desc: "Cohésion d'équipe en mode VR",
    accent: "from-[var(--color-accent-400)] to-[var(--color-brand-500)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v6m-3-3h6m-9-9a3 3 0 116 0v3a3 3 0 11-6 0V9zm0 6h6"/>`,
  },
  {
    href: "/evg-evjf",
    title: "EVG / EVJF",
    desc: "Une soirée mémorable garantie",
    accent: "from-[var(--color-brand-500)] to-[var(--color-glow-pink)]",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6l-1 7a3 3 0 11-4 0L9 3zM7 21h10M12 14v7"/>`,
  },
];
---

<nav class="fixed inset-x-0 top-0 z-20 w-full" aria-label="Navigation principale">
  <div
    class="navbar-pill mx-4 md:mx-auto my-4 flex max-w-(--breakpoint-xl) flex-wrap items-center justify-between px-5 py-2.5 md:px-7 md:py-3 bg-[var(--color-surface-card)]/70 backdrop-blur-xl ring-1 ring-white/10 rounded-full shadow-[0_8px_32px_-12px_rgba(139,92,246,0.35)]"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Accueil VR Café">
      <Image
        loading="eager"
        width={64}
        src={Logo}
        class="h-8 w-auto transition-transform duration-[var(--dur-base)] group-hover:scale-105"
        alt="VR Café"
      />
    </a>

    <!-- Mobile menu button -->
    <div class="flex items-center md:order-2">
      <button
        data-collapse-toggle="navbar-sticky"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full text-white/80 hover:text-white hover:bg-white/5 ring-1 ring-transparent hover:ring-white/10 transition-all md:hidden"
        aria-controls="navbar-sticky"
        aria-expanded="false"
      >
        <span class="sr-only">Ouvrir le menu principal</span>
        <svg id="hamburger-icon" class="h-5 w-5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="h-5 w-5 hidden" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Menu -->
    <div
      class="hidden w-full items-center md:order-1 md:flex md:w-auto"
      id="navbar-sticky"
    >
      <ul
        class="dropdown-anim mt-4 flex flex-col gap-1 rounded-2xl bg-[var(--color-surface-card)]/95 backdrop-blur-xl ring-1 ring-white/10 p-3 absolute left-4 right-4 top-20 md:relative md:left-auto md:right-auto md:top-auto md:mt-0 md:flex-row md:items-center md:gap-1 md:bg-transparent md:ring-0 md:p-0 md:backdrop-blur-none md:animate-none shadow-[0_20px_60px_-15px_rgba(0,0,0,0.6)] md:shadow-none"
      >
        <!-- Accueil -->
        <li>
          <a
            href="/"
            class={`block rounded-full px-4 py-2 text-[15px] font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ${
              isActive("/")
                ? "text-[var(--color-brand-300)] md:bg-white/5"
                : "text-white/75 hover:text-white hover:bg-white/5"
            }`}
            aria-current={isActive("/") ? "page" : undefined}
          >
            Accueil
          </a>
        </li>

        <!-- Expériences -->
        <li class="relative">
          <button
            type="button"
            id="experiences-button"
            data-dropdown="experiences-dropdown"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="experiences-dropdown"
            class={`flex items-center w-full md:w-auto justify-between gap-1.5 rounded-full px-4 py-2 text-[15px] font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ${
              isExperiencesSubmenu
                ? "text-[var(--color-brand-300)] md:bg-white/5"
                : "text-white/75 hover:text-white hover:bg-white/5"
            }`}
          >
            Expériences
            <svg
              class="dropdown-arrow w-3.5 h-3.5 transition-transform duration-[var(--dur-base)]"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <ul
            id="experiences-dropdown"
            role="menu"
            aria-labelledby="experiences-button"
            class="hidden md:absolute md:left-0 md:top-full md:mt-3 md:min-w-[340px] md:bg-[var(--color-surface-card)]/95 md:backdrop-blur-xl md:ring-1 md:ring-white/10 md:rounded-2xl md:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.6)] md:p-2 md:dropdown-anim z-50 mt-2 flex flex-col gap-1"
          >
            {experiencesItems.map((it) => (
              <li role="none">
                <a
                  href={it.href}
                  role="menuitem"
                  class={`group flex items-start gap-3 rounded-xl p-3 transition-all duration-[var(--dur-fast)] ${
                    isActive(it.href)
                      ? "bg-white/5 ring-1 ring-[var(--color-brand-500)]/30"
                      : "hover:bg-white/5"
                  }`}
                >
                  <span class={`shrink-0 w-9 h-9 rounded-lg bg-gradient-to-br ${it.accent} flex items-center justify-center shadow-md transition-transform duration-[var(--dur-base)] group-hover:scale-110`}>
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={it.icon} />
                  </span>
                  <span class="flex flex-col min-w-0">
                    <span class={`text-sm font-semibold ${isActive(it.href) ? "text-[var(--color-brand-300)]" : "text-white"}`}>
                      {it.title}
                    </span>
                    <span class="text-xs text-white/55 mt-0.5">{it.desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </li>

        <!-- Occasions -->
        <li class="relative">
          <button
            type="button"
            id="occasions-button"
            data-dropdown="occasions-dropdown"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="occasions-dropdown"
            class={`flex items-center w-full md:w-auto justify-between gap-1.5 rounded-full px-4 py-2 text-[15px] font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ${
              isOccasionsSubmenu
                ? "text-[var(--color-brand-300)] md:bg-white/5"
                : "text-white/75 hover:text-white hover:bg-white/5"
            }`}
          >
            Occasions
            <svg
              class="dropdown-arrow w-3.5 h-3.5 transition-transform duration-[var(--dur-base)]"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <ul
            id="occasions-dropdown"
            role="menu"
            aria-labelledby="occasions-button"
            class="hidden md:absolute md:left-0 md:top-full md:mt-3 md:min-w-[340px] md:bg-[var(--color-surface-card)]/95 md:backdrop-blur-xl md:ring-1 md:ring-white/10 md:rounded-2xl md:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.6)] md:p-2 md:dropdown-anim z-50 mt-2 flex flex-col gap-1"
          >
            {occasionsItems.map((it) => (
              <li role="none">
                <a
                  href={it.href}
                  role="menuitem"
                  class={`group flex items-start gap-3 rounded-xl p-3 transition-all duration-[var(--dur-fast)] ${
                    isActive(it.href)
                      ? "bg-white/5 ring-1 ring-[var(--color-brand-500)]/30"
                      : "hover:bg-white/5"
                  }`}
                >
                  <span class={`shrink-0 w-9 h-9 rounded-lg bg-gradient-to-br ${it.accent} flex items-center justify-center shadow-md transition-transform duration-[var(--dur-base)] group-hover:scale-110`}>
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={it.icon} />
                  </span>
                  <span class="flex flex-col min-w-0">
                    <span class={`text-sm font-semibold ${isActive(it.href) ? "text-[var(--color-brand-300)]" : "text-white"}`}>
                      {it.title}
                    </span>
                    <span class="text-xs text-white/55 mt-0.5">{it.desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </li>

        <!-- Tarifs -->
        <li>
          <a
            href="/tarifs"
            class={`block rounded-full px-4 py-2 text-[15px] font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ${
              isActive("/tarifs")
                ? "text-[var(--color-brand-300)] md:bg-white/5"
                : "text-white/75 hover:text-white hover:bg-white/5"
            }`}
            aria-current={isActive("/tarifs") ? "page" : undefined}
          >
            Tarifs
          </a>
        </li>

        <!-- Contact -->
        <li>
          <a
            href="/contact"
            class={`block rounded-full px-4 py-2 text-[15px] font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ${
              currentPath === "/contact" || currentPath.includes("/contact/")
                ? "text-[var(--color-brand-300)] md:bg-white/5"
                : "text-white/75 hover:text-white hover:bg-white/5"
            }`}
            aria-current={(currentPath === "/contact" || currentPath.includes("/contact/")) ? "page" : undefined}
          >
            Contact
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  function initNavBar() {
    const mobileMenuButton = document.querySelector<HTMLButtonElement>(
      '[data-collapse-toggle="navbar-sticky"]'
    );
    const mobileMenu = document.querySelector<HTMLElement>("#navbar-sticky");
    const hamburgerIcon = document.querySelector<HTMLElement>("#hamburger-icon");
    const closeIcon = document.querySelector<HTMLElement>("#close-icon");

    const dropdownButtons = document.querySelectorAll<HTMLButtonElement>(
      "[data-dropdown]"
    );

    function closeAllDropdowns() {
      dropdownButtons.forEach((btn) => {
        const dropdownId = btn.getAttribute("data-dropdown");
        const dropdown = dropdownId ? document.getElementById(dropdownId) : null;
        const arrow = btn.querySelector(".dropdown-arrow");

        if (dropdown) {
          dropdown.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
        }
        arrow?.classList.remove("rotate-180");
      });
    }

    function openDropdown(button: Element) {
      const dropdownId = button.getAttribute("data-dropdown");
      if (!dropdownId) return;

      const dropdown = document.getElementById(dropdownId);
      const arrow = button.querySelector(".dropdown-arrow");

      if (dropdown) {
        dropdown.classList.remove("hidden");
        button.setAttribute("aria-expanded", "true");
        arrow?.classList.add("rotate-180");

        const firstLink = dropdown.querySelector(
          'a[role="menuitem"]'
        ) as HTMLElement | null;
        firstLink?.focus();
      }
    }

    function closeDropdown(button: Element) {
      const dropdownId = button.getAttribute("data-dropdown");
      if (!dropdownId) return;

      const dropdown = document.getElementById(dropdownId);
      const arrow = button.querySelector(".dropdown-arrow");

      if (dropdown) {
        dropdown.classList.add("hidden");
        button.setAttribute("aria-expanded", "false");
        arrow?.classList.remove("rotate-180");
      }
    }

    function toggleDropdown(button: Element) {
      const dropdownId = button.getAttribute("data-dropdown");
      if (!dropdownId) return;

      const dropdown = document.getElementById(dropdownId);
      const isHidden = dropdown?.classList.contains("hidden");

      dropdownButtons.forEach((btn) => {
        if (btn !== button) closeDropdown(btn);
      });

      if (isHidden) {
        openDropdown(button);
      } else {
        closeDropdown(button);
        (button as HTMLElement).focus();
      }
    }

    function closeMobileMenu() {
      mobileMenu?.classList.add("hidden");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      mobileMenuButton?.setAttribute("aria-expanded", "false");
    }

    // Hamburger toggle (re-bindable via data flag)
    if (mobileMenuButton && mobileMenuButton.dataset.navbarBound !== "1") {
      mobileMenuButton.dataset.navbarBound = "1";
      mobileMenuButton.addEventListener("click", () => {
        const isHidden = mobileMenu?.classList.contains("hidden");
        if (isHidden) {
          mobileMenu?.classList.remove("hidden");
          hamburgerIcon?.classList.add("hidden");
          closeIcon?.classList.remove("hidden");
          mobileMenuButton.setAttribute("aria-expanded", "true");
        } else {
          closeMobileMenu();
        }
      });
    }

    // Dropdown buttons
    dropdownButtons.forEach((button) => {
      if (button.dataset.navbarBound === "1") return;
      button.dataset.navbarBound = "1";

      button.addEventListener("click", (e) => {
        e.preventDefault();
        toggleDropdown(button);
      });

      button.addEventListener("keydown", (e: KeyboardEvent) => {
        const key = e.key;

        if (key === "Enter" || key === " ") {
          e.preventDefault();
          toggleDropdown(button);
        } else if (key === "Escape") {
          closeDropdown(button);
          button.focus();
        } else if (key === "ArrowDown") {
          e.preventDefault();
          const dropdownId = button.getAttribute("data-dropdown");
          const dropdown = dropdownId
            ? document.getElementById(dropdownId)
            : null;
          const isHidden = dropdown?.classList.contains("hidden");

          if (isHidden) {
            openDropdown(button);
          } else {
            const firstLink = dropdown?.querySelector(
              'a[role="menuitem"]'
            ) as HTMLElement | null;
            firstLink?.focus();
          }
        }
      });
    });

    // Menu items keyboard navigation
    document.querySelectorAll<HTMLElement>('[role="menu"]').forEach((menu) => {
      const menuItems = menu.querySelectorAll<HTMLElement>(
        'a[role="menuitem"]'
      );

      menuItems.forEach((item, index) => {
        if (item.dataset.navbarBound === "1") return;
        item.dataset.navbarBound = "1";

        item.addEventListener("keydown", (e: KeyboardEvent) => {
          const key = e.key;

          if (key === "ArrowDown") {
            e.preventDefault();
            const nextIndex = (index + 1) % menuItems.length;
            menuItems[nextIndex].focus();
          } else if (key === "ArrowUp") {
            e.preventDefault();
            const prevIndex = (index - 1 + menuItems.length) % menuItems.length;
            menuItems[prevIndex].focus();
          } else if (key === "Escape") {
            e.preventDefault();
            const menuId = menu.id;
            const button = document.querySelector<HTMLElement>(
              `[data-dropdown="${menuId}"]`
            );
            if (button) closeDropdown(button);
            button?.focus();
          } else if (key === "Tab") {
            const menuId = menu.id;
            const button = document.querySelector<HTMLElement>(
              `[data-dropdown="${menuId}"]`
            );
            if (button) closeDropdown(button);
          }
        });
      });
    });

    // Close nav menu on link click (mobile)
    const navLinks = document.querySelectorAll<HTMLElement>(
      "#navbar-sticky a"
    );
    navLinks.forEach((link) => {
      if (link.dataset.navbarBoundLink === "1") return;
      link.dataset.navbarBoundLink = "1";
      link.addEventListener("click", () => {
        const isHidden = mobileMenu?.classList.contains("hidden");
        if (isHidden === false) {
          closeMobileMenu();
          closeAllDropdowns();
        }
      });
    });

    // Document-level click-outside (only bound once globally)
    if (!(window as unknown as { __navbarClickOutsideBound?: boolean })
      .__navbarClickOutsideBound) {
      (window as unknown as { __navbarClickOutsideBound?: boolean })
        .__navbarClickOutsideBound = true;
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (
          !target.closest("[data-dropdown]") &&
          !target.closest('[role="menu"]')
        ) {
          document
            .querySelectorAll<HTMLButtonElement>("[data-dropdown]")
            .forEach((btn) => {
              const dropdownId = btn.getAttribute("data-dropdown");
              const dropdown = dropdownId
                ? document.getElementById(dropdownId)
                : null;
              const arrow = btn.querySelector(".dropdown-arrow");
              if (dropdown) {
                dropdown.classList.add("hidden");
                btn.setAttribute("aria-expanded", "false");
              }
              arrow?.classList.remove("rotate-180");
            });
        }
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNavBar);
  } else {
    initNavBar();
  }
  document.addEventListener("astro:page-load", initNavBar);
</script>
