---
import Logo from "../assets/logo.webp";
import { Image } from "astro:assets";
// NavBar.astro avec dropdowns pour VR et VR sans fil

const currentPath = Astro.url.pathname;

// Actif sur "Expériences" si on est sur une page de jeux
const isExperiencesSubmenu =
  currentPath.includes("/escapes") ||
  currentPath.includes("/jeux") ||
  currentPath.includes("/freeroaming") ||
  currentPath.includes("/escapesFreeroaming");

// Actif sur "Occasions" si on est sur une page commerciale
const isOccasionsSubmenu =
  currentPath === "/anniversaire" ||
  currentPath === "/anniversaire/" ||
  currentPath === "/team-building" ||
  currentPath === "/team-building/" ||
  currentPath === "/evg-evjf" ||
  currentPath === "/evg-evjf/";
---

<nav
  class="fixed inset-s-0 top-0 z-20 w-full"
>
  <div
    class="mx-4 md:mx-auto flex max-w-(--breakpoint-xl) flex-wrap items-center justify-between px-6 py-4 md:px-8 bg-white dark:bg-gray-900 rounded-full shadow-lg my-4"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
      <Image
        loading={"eager"}
        width={64}
        src={Logo}
        class="h-8 w-auto"
        alt="VR café Logo"
      />
    </a>

    <div
      class="flex items-center md:order-2 space-x-3 md:space-x-0 rtl:space-x-reverse"
    >
      <!-- Mobile menu button -->
      <button
        data-collapse-toggle="navbar-sticky"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-lg p-2 text-sm text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 md:hidden dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
        aria-controls="navbar-sticky"
        aria-expanded="false"
      >
        <span class="sr-only">Ouvrir le menu principal</span>
        <!-- Hamburger Icon -->
        <svg
          id="hamburger-icon"
          class="h-5 w-5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 17 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15"></path>
        </svg>
        <!-- Close Icon -->
        <svg
          id="close-icon"
          class="h-5 w-5 hidden"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 14 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"></path>
        </svg>
      </button>
    </div>

    <!-- Menu -->
    <div
      class="hidden w-full items-center justify-between md:order-1 md:flex md:w-auto"
      id="navbar-sticky"
    >
      <ul
        class="mt-4 flex flex-col rounded-lg border border-gray-100 bg-gray-50 p-4 font-medium absolute left-4 right-4 top-20 md:relative md:left-auto md:right-auto md:top-auto md:mt-0 md:flex-row md:space-x-8 md:border-0 md:bg-transparent md:p-0 rtl:space-x-reverse dark:border-gray-700 dark:bg-gray-800 md:dark:bg-transparent shadow-lg md:shadow-none"
      >
        <!-- Accueil -->
        <li>
          <a
            href="/"
            class={currentPath === "/"
              ? "block rounded bg-blue-700 px-4 py-3.5 text-white md:bg-transparent md:p-0 md:text-blue-700 md:dark:text-blue-500"
              : "block rounded px-4 py-3.5 text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 md:bg-transparent md:p-0 md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:text-blue-500 md:dark:hover:bg-transparent md:dark:border-0"}
            aria-current={currentPath === "/" ? "page" : undefined}
          >Accueil</a>
        </li>

        <!-- Expériences avec dropdown -->
        <li class="relative group">
          <button
            type="button"
            id="experiences-button"
            data-dropdown="experiences-dropdown"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="experiences-dropdown"
            class={`flex items-center w-full justify-between rounded px-4 py-3.5 md:w-auto md:border-0 md:p-0 md:hover:bg-transparent md:dark:hover:bg-transparent ${
              isExperiencesSubmenu
                ? "bg-blue-700 text-white md:bg-transparent md:text-blue-700 md:dark:text-blue-500"
                : "text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 md:bg-transparent md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:text-blue-500 md:dark:hover:bg-transparent"
            }`}
          >
            Expériences
            <svg
              class="dropdown-arrow w-4 h-4 ml-2 transition-transform md:rotate-0 md:group-hover:rotate-180"
              aria-hidden="true"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>

          <!-- Dropdown Expériences -->
          <ul
            id="experiences-dropdown"
            role="menu"
            aria-labelledby="experiences-button"
            class="hidden md:absolute left-0 mt-2 bg-white dark:bg-gray-900 rounded-lg shadow-lg md:min-w-56 z-50 md:top-full md:left-0"
          >
            <li role="none">
              <a
                href="/escapes"
                role="menuitem"
                class={`block px-4 py-3.5 rounded-t-lg ${
                  currentPath === "/escapes" || currentPath === "/escapes/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🔐 Escape Games VR
              </a>
            </li>
            <li role="none">
              <a
                href="/escapesFreeroaming"
                role="menuitem"
                class={`block px-4 py-3.5 ${
                  currentPath === "/escapesFreeroaming" || currentPath === "/escapesFreeroaming/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🔐 Escape Games Sans Fil
              </a>
            </li>
            <li role="none">
              <a
                href="/jeux"
                role="menuitem"
                class={`block px-4 py-3.5 ${
                  currentPath === "/jeux" || currentPath === "/jeux/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🎮 Jeux VR
              </a>
            </li>
            <li role="none">
              <a
                href="/freeroaming"
                role="menuitem"
                class={`block px-4 py-3.5 rounded-b-lg ${
                  currentPath === "/freeroaming" || currentPath === "/freeroaming/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🎮 Jeux Sans Fil
              </a>
            </li>
          </ul>
        </li>

        <!-- Occasions avec dropdown -->
        <li class="relative group">
          <button
            type="button"
            id="occasions-button"
            data-dropdown="occasions-dropdown"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="occasions-dropdown"
            class={`flex items-center w-full justify-between rounded px-4 py-3.5 md:w-auto md:border-0 md:p-0 md:hover:bg-transparent md:dark:hover:bg-transparent ${
              isOccasionsSubmenu
                ? "bg-blue-700 text-white md:bg-transparent md:text-blue-700 md:dark:text-blue-500"
                : "text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 md:bg-transparent md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:text-blue-500 md:dark:hover:bg-transparent"
            }`}
          >
            Occasions
            <svg
              class="dropdown-arrow w-4 h-4 ml-2 transition-transform md:rotate-0 md:group-hover:rotate-180"
              aria-hidden="true"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>

          <!-- Dropdown Occasions -->
          <ul
            id="occasions-dropdown"
            role="menu"
            aria-labelledby="occasions-button"
            class="hidden md:absolute left-0 mt-2 bg-white dark:bg-gray-900 rounded-lg shadow-lg md:min-w-56 z-50 md:top-full md:left-0"
          >
            <li role="none">
              <a
                href="/anniversaire"
                role="menuitem"
                class={`block px-4 py-3.5 rounded-t-lg ${
                  currentPath === "/anniversaire" || currentPath === "/anniversaire/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🎂 Anniversaire
              </a>
            </li>
            <li role="none">
              <a
                href="/team-building"
                role="menuitem"
                class={`block px-4 py-3.5 ${
                  currentPath === "/team-building" || currentPath === "/team-building/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🏆 Team Building
              </a>
            </li>
            <li role="none">
              <a
                href="/evg-evjf"
                role="menuitem"
                class={`block px-4 py-3.5 rounded-b-lg ${
                  currentPath === "/evg-evjf" || currentPath === "/evg-evjf/"
                    ? "text-blue-700 dark:text-blue-500"
                    : "text-gray-900 hover:bg-gray-100 hover:text-blue-700 dark:text-white dark:hover:bg-gray-700 dark:hover:text-blue-500"
                }`}
              >
                🥂 EVG / EVJF
              </a>
            </li>
          </ul>
        </li>

        <!-- Tarifs -->
        <li>
          <a
            href="/tarifs"
            class={currentPath === "/tarifs" || currentPath === "/tarifs/"
              ? "block rounded bg-blue-700 px-4 py-3.5 text-white md:bg-transparent md:p-0 md:text-blue-700 md:dark:text-blue-500"
              : "block rounded px-4 py-3.5 text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 md:bg-transparent md:p-0 md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:text-blue-500 md:dark:hover:bg-transparent md:dark:border-0"}
          >
            Tarifs
          </a>
        </li>

        {/* TODO: Carte Cadeau — à réactiver quand la gestion sera intégrée au système de réservation
        <li>
          <a
            href="/cadeaux"
            class={currentPath === "/cadeaux" || currentPath.includes("/cadeaux/")
              ? "block rounded bg-blue-700 px-4 py-3.5 text-white md:bg-transparent md:p-0 md:text-blue-700 md:dark:text-blue-500"
              : "block rounded px-4 py-3.5 text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 md:bg-transparent md:p-0 md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:text-blue-500 md:dark:hover:bg-transparent md:dark:border-0"}
          >
            Carte Cadeau
          </a>
        </li>
        */}

        <!-- Contact -->
        <li>
          <a
            href="/contact"
            class={currentPath === "/contact" || currentPath.includes("/contact/")
              ? "block rounded bg-blue-700 px-4 py-3.5 text-white md:bg-transparent md:p-0 md:text-blue-700 md:dark:text-blue-500"
              : "block rounded px-4 py-3.5 text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 md:bg-transparent md:p-0 md:hover:bg-transparent md:hover:text-blue-700 md:dark:hover:text-blue-500 md:dark:hover:bg-transparent md:dark:border-0"}
          >
            Contact
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  // Toggle mobile menu
  const mobileMenuButton = document.querySelector(
    '[data-collapse-toggle="navbar-sticky"]'
  );
  const mobileMenu = document.querySelector("#navbar-sticky");
  const hamburgerIcon = document.querySelector("#hamburger-icon");
  const closeIcon = document.querySelector("#close-icon");

  mobileMenuButton?.addEventListener("click", () => {
    const isHidden = mobileMenu?.classList.contains("hidden");

    if (isHidden) {
      mobileMenu?.classList.remove("hidden");
      hamburgerIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      mobileMenuButton?.setAttribute("aria-expanded", "true");
    } else {
      mobileMenu?.classList.add("hidden");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      mobileMenuButton?.setAttribute("aria-expanded", "false");
    }
  });

  // Gérer les dropdowns (mobile ET desktop)
  const dropdownButtons = document.querySelectorAll("[data-dropdown]");

  // Fonction pour fermer tous les dropdowns
  function closeAllDropdowns() {
    dropdownButtons.forEach((btn) => {
      const dropdownId = btn.getAttribute("data-dropdown");
      const dropdown = dropdownId ? document.getElementById(dropdownId) : null;
      const arrow = btn.querySelector(".dropdown-arrow");

      if (dropdown) {
        dropdown.classList.add("hidden");
        dropdown.classList.remove("flex", "flex-col");
        btn.setAttribute("aria-expanded", "false");
      }
      arrow?.classList.remove("rotate-180");
    });
  }

  // Fonction pour ouvrir un dropdown
  function openDropdown(button: Element) {
    const dropdownId = button.getAttribute("data-dropdown");
    if (!dropdownId) return;

    const dropdown = document.getElementById(dropdownId);
    const arrow = button.querySelector(".dropdown-arrow");

    if (dropdown) {
      dropdown.classList.remove("hidden");
      dropdown.classList.add("flex", "flex-col");
      button.setAttribute("aria-expanded", "true");
      arrow?.classList.add("rotate-180");

      // Focus le premier lien du menu
      const firstLink = dropdown.querySelector('a[role="menuitem"]') as HTMLElement;
      firstLink?.focus();
    }
  }

  // Fonction pour fermer un dropdown
  function closeDropdown(button: Element) {
    const dropdownId = button.getAttribute("data-dropdown");
    if (!dropdownId) return;

    const dropdown = document.getElementById(dropdownId);
    const arrow = button.querySelector(".dropdown-arrow");

    if (dropdown) {
      dropdown.classList.add("hidden");
      dropdown.classList.remove("flex", "flex-col");
      button.setAttribute("aria-expanded", "false");
      arrow?.classList.remove("rotate-180");
    }
  }

  // Fonction pour toggle un dropdown
  function toggleDropdown(button: Element) {
    const dropdownId = button.getAttribute("data-dropdown");
    if (!dropdownId) return;

    const dropdown = document.getElementById(dropdownId);
    const isHidden = dropdown?.classList.contains("hidden");

    // Fermer tous les autres dropdowns
    dropdownButtons.forEach((btn) => {
      if (btn !== button) {
        closeDropdown(btn);
      }
    });

    // Toggle le dropdown actuel
    if (isHidden) {
      openDropdown(button);
    } else {
      closeDropdown(button);
      (button as HTMLElement).focus();
    }
  }

  dropdownButtons.forEach((button) => {
    // Gestion du clic
    button.addEventListener("click", (e) => {
      e.preventDefault();
      toggleDropdown(button);
    });

    // Gestion du clavier sur les boutons
    (button as HTMLElement).addEventListener("keydown", (e: KeyboardEvent) => {
      const key = e.key;

      if (key === "Enter" || key === " ") {
        e.preventDefault();
        toggleDropdown(button);
      } else if (key === "Escape") {
        closeDropdown(button);
        (button as HTMLElement).focus();
      } else if (key === "ArrowDown") {
        e.preventDefault();
        const dropdownId = button.getAttribute("data-dropdown");
        const dropdown = dropdownId ? document.getElementById(dropdownId) : null;
        const isHidden = dropdown?.classList.contains("hidden");

        if (isHidden) {
          openDropdown(button);
        } else {
          const firstLink = dropdown?.querySelector('a[role="menuitem"]') as HTMLElement;
          firstLink?.focus();
        }
      }
    });
  });

  // Gestion du clavier dans les menus dropdown
  document.querySelectorAll('[role="menu"]').forEach((menu) => {
    const menuItems = menu.querySelectorAll('a[role="menuitem"]');

    menuItems.forEach((item, index) => {
      (item as HTMLElement).addEventListener("keydown", (e: KeyboardEvent) => {
        const key = e.key;

        if (key === "ArrowDown") {
          e.preventDefault();
          const nextIndex = (index + 1) % menuItems.length;
          (menuItems[nextIndex] as HTMLElement).focus();
        } else if (key === "ArrowUp") {
          e.preventDefault();
          const prevIndex = (index - 1 + menuItems.length) % menuItems.length;
          (menuItems[prevIndex] as HTMLElement).focus();
        } else if (key === "Escape") {
          e.preventDefault();
          const menuId = menu.id;
          const button = document.querySelector(`[data-dropdown="${menuId}"]`) as HTMLElement;
          closeDropdown(button);
          button?.focus();
        } else if (key === "Tab") {
          // Fermer le menu sur Tab
          const menuId = menu.id;
          const button = document.querySelector(`[data-dropdown="${menuId}"]`);
          if (button) closeDropdown(button);
        }
      });
    });
  });

  // Fermer les dropdowns quand on clique ailleurs
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("[data-dropdown]") && !target.closest('[role="menu"]')) {
      closeAllDropdowns();
    }
  });

  // Fermer le menu mobile quand on clique sur un lien
  const navLinks = document.querySelectorAll("#navbar-sticky a");
  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      const isHidden = mobileMenu?.classList.contains("hidden");
      if (isHidden === false) {
        mobileMenu?.classList.add("hidden");
        hamburgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        mobileMenuButton?.setAttribute("aria-expanded", "false");

        // Fermer aussi tous les dropdowns
        closeAllDropdowns();
      }
    });
  });
</script>
