---
import PageHeader from "./PageHeader.astro";
import Button from "./Button.astro";

const {
  title = "Contactez-nous",
  subtitle = "Une question ? Une réservation ? Notre équipe est à votre écoute pour vous répondre rapidement.",
} = Astro.props;

// Génération du token CSRF (HMAC-SHA256, fenêtre de 5 minutes)
const secret = import.meta.env.ADMIN_PASSWORD || "vrcafe-csrf-fallback";
const window5m = Math.floor(Date.now() / 300000);
const enc = new TextEncoder();
const key = await crypto.subtle.importKey("raw", enc.encode(secret), { name: "HMAC", hash: "SHA-256" }, false, ["sign"]);
const sig = await crypto.subtle.sign("HMAC", key, enc.encode(String(window5m)));
const csrfToken = btoa(String.fromCharCode(...new Uint8Array(sig)));

// Classes communes des champs (input/textarea)
const fieldClass = "bg-white/5 ring-1 ring-white/10 text-white text-base rounded-xl focus:ring-2 focus:ring-[var(--color-brand-400)] focus:outline-none block w-full p-3.5 placeholder:text-white/35 transition-all";
---

<section id="contact" class="bg-[var(--color-surface)] pb-20 lg:pb-28">
  <div class="flex flex-col items-center">
    <PageHeader eyebrow="Contact" title={title} subtitle={subtitle} />
  </div>

  <div class="px-4 sm:px-6 lg:px-8 mx-auto max-w-6xl">
    <!-- 2 Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      <!-- Left Column - Contact Info -->
      <div class="reveal flex flex-col gap-6">
        <!-- Quick Contact Card -->
        <div class="card-glow p-8">
          <h3 class="text-xl font-bold text-white mb-6">
            Contactez-nous rapidement
          </h3>

          <!-- Phone -->
          <a
            href="tel:0671410695"
            class="flex items-start gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors group mb-2"
          >
            <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-glow-blue)] to-[var(--color-brand-500)] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white/55">Téléphone</p>
              <p class="text-lg font-semibold text-white group-hover:text-[var(--color-brand-300)] transition-colors">06 71 41 06 95</p>
            </div>
          </a>

          <!-- Email -->
          <a
            href="mailto:contact@vr-cafe.fr"
            class="flex items-start gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors group mb-2"
          >
            <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-glow-cyan)] to-[var(--color-brand-500)] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white/55">Email</p>
              <p class="text-lg font-semibold text-white group-hover:text-[var(--color-brand-300)] transition-colors">contact@vr-cafe.fr</p>
            </div>
          </a>

          <!-- Address -->
          <a
            href="https://maps.google.com/?q=2+rue+du+pilou+66140+Canet-en-Roussillon"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors group"
          >
            <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-glow-pink)] to-[var(--color-brand-500)] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white/55">Adresse</p>
              <p class="text-lg font-semibold text-white group-hover:text-[var(--color-brand-300)] transition-colors">2 rue du pilou<br />66140 Canet-en-Roussillon</p>
            </div>
          </a>
        </div>

        <!-- Carte Google Maps -->
        <div class="card-glow overflow-hidden aspect-square">
          <iframe
            loading="lazy"
            src="https://www.google.com/maps?q=VR%20Café%202%20rue%20du%20pilou%2066140%20Canet-en-Roussillon,%20France&output=embed"
            width="100%"
            height="100%"
            style="border:0; width: 100%; height: 100%;"
            allowfullscreen=""
            referrerpolicy="no-referrer-when-downgrade"
            title="Localisation VR Café"
            class="w-full h-full"
          ></iframe>
        </div>
      </div>

      <!-- Right Column - Contact Form -->
      <div class="reveal card-glow p-8 flex flex-col">
        <h3 class="text-xl font-bold text-white mb-6">
          Envoyez-nous un message
        </h3>

        <form
          name="contact"
          method="POST"
          action="/api/contact"
          class="flex flex-col grow space-y-6"
        >
          <!-- Token CSRF -->
          <input type="hidden" name="_csrf" value={csrfToken} />

          <!-- Honeypot anti-spam (caché pour les humains) -->
          <p class="hidden" aria-hidden="true">
            <label>
              Ne pas remplir si vous êtes humain : <input name="bot-field" />
            </label>
          </p>

          <!-- Email Field -->
          <div>
            <label for="email" class="flex items-center gap-2 mb-2 text-sm font-semibold text-white">
              <svg class="w-4 h-4 text-[var(--color-brand-300)]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
              </svg>
              Votre email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class={fieldClass}
              placeholder="votre.email@exemple.com"
              required
            />
          </div>

          <!-- Subject Field -->
          <div>
            <label for="subject" class="flex items-center gap-2 mb-2 text-sm font-semibold text-white">
              <svg class="w-4 h-4 text-[var(--color-brand-300)]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
              </svg>
              Sujet
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              class={fieldClass}
              placeholder="En quoi pouvons-nous vous aider ?"
              required
            />
          </div>

          <!-- Message Field -->
          <div class="flex flex-col grow">
            <label for="message" class="flex items-center gap-2 mb-2 text-sm font-semibold text-white">
              <svg class="w-4 h-4 text-[var(--color-brand-300)]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 13V5a2 2 0 00-2-2H4a2 2 0 00-2 2v8a2 2 0 002 2h3l3 3 3-3h3a2 2 0 002-2zM5 7a1 1 0 011-1h8a1 1 0 110 2H6a1 1 0 01-1-1zm1 3a1 1 0 100 2h3a1 1 0 100-2H6z" clip-rule="evenodd"></path>
              </svg>
              Votre message
            </label>
            <textarea
              id="message"
              name="message"
              class={`${fieldClass} resize-none grow min-h-50`}
              placeholder="Décrivez votre demande..."
              required></textarea>
          </div>

          <!-- Message d'erreur (caché par défaut) -->
          <div id="contact-error" class="hidden rounded-xl bg-red-500/10 border border-red-500/30 px-4 py-3 text-sm text-red-300" role="alert">
            Une erreur est survenue. Veuillez réessayer ou nous contacter directement par email.
          </div>

          <!-- Submit Button -->
          <Button type="submit" variant="primary" size="lg" class="w-full" id="contact-submit">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
            </svg>
            Envoyer le message
          </Button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('form[name="contact"]');
    if (!form || form.dataset.fetchBound) return;
    form.dataset.fetchBound = "true";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const btn = form.querySelector<HTMLButtonElement>("#contact-submit");
      const errorEl = form.querySelector<HTMLElement>("#contact-error");

      if (errorEl) errorEl.classList.add("hidden");
      if (btn) btn.disabled = true;

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          redirect: "manual",
        });

        // opaqueredirect = le serveur a répondu 303 (redirect manuel intercepté par le browser)
        if (res.type === "opaqueredirect" || res.ok) {
          window.location.href = "/contact/merci";
          return;
        }

        throw new Error(`HTTP ${res.status}`);
      } catch {
        if (errorEl) errorEl.classList.remove("hidden");
        if (btn) btn.disabled = false;
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
