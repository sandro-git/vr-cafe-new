---
const {
  title = "Contactez-nous",
  subtitle = "Une question ? Une réservation ? Notre équipe est à votre écoute pour vous répondre rapidement.",
  showPhone = true,
} = Astro.props;
---

<section id="contact" class="bg-gradient-to-br from-gray-50 to-blue-50 dark:from-gray-900 dark:to-gray-800 py-12 md:py-20">
  <div class="py-8 lg:py-16 px-4 mx-auto max-w-screen-xl">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2
        class="mb-4 text-4xl md:text-5xl tracking-tight font-extrabold text-gray-900 dark:text-white"
      >
        {title}
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- 2 Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Left Column - Contact Info -->
      <div class="flex flex-col gap-8">
        <!-- Quick Contact Card -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-8">
          <h3
            class="text-2xl font-bold text-gray-900 dark:text-white mb-6"
          >
            Contactez-nous rapidement
          </h3>

          <!-- Phone -->
          <a
            href="tel:0671410695"
            class="flex items-start gap-4 p-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors group mb-4"
          >
            <div
              class="flex-shrink-0 w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform"
            >
              <svg
                class="w-6 h-6 text-blue-600 dark:text-blue-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">
                Téléphone
              </p>
              <p
                class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400"
              >
                06 71 41 06 95
              </p>
            </div>
          </a>

          <!-- Email -->
          <a
            href="mailto:contact@vr-cafe.fr"
            class="flex items-start gap-4 p-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors group mb-4"
          >
            <div
              class="flex-shrink-0 w-12 h-12 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform"
            >
              <svg
                class="w-6 h-6 text-green-600 dark:text-green-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">
                Email
              </p>
              <p
                class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400"
              >
                contact@vr-cafe.fr
              </p>
            </div>
          </a>

          <!-- Address -->
          <a
            href="https://maps.google.com/?q=2+rue+du+pilou+66140+Canet-en-Roussillon"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-4 p-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors group"
          >
            <div
              class="flex-shrink-0 w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform"
            >
              <svg
                class="w-6 h-6 text-purple-600 dark:text-purple-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">
                Adresse
              </p>
              <p
                class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400"
              >
                2 rue du pilou<br />66140 Canet-en-Roussillon
              </p>
            </div>
          </a>
        </div>

        <!-- Carte Google Maps -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl overflow-hidden aspect-square">
          <iframe
            loading="lazy"
            src="https://www.google.com/maps?q=VR%20Café%202%20rue%20du%20pilou%2066140%20Canet-en-Roussillon,%20France&output=embed"
            width="100%"
            height="100%"
            style="border:0; width: 100%; height: 100%;"
            allowfullscreen=""
            referrerpolicy="no-referrer-when-downgrade"
            title="Localisation VR Café"
            class="w-full h-full"
          ></iframe>
        </div>
      </div>

      <!-- Right Column - Contact Form -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-8 flex flex-col">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
          Envoyez-nous un message
        </h3>

        <!-- Message de succès/erreur -->
        <div id="form-message" class="hidden mb-6"></div>

        <form id="contact-form" class="flex flex-col flex-grow space-y-6">
          <!-- Nom Field -->
          <div>
            <label
              for="name"
              class="flex items-center gap-2 mb-2 text-sm font-semibold text-gray-900 dark:text-white"
            >
              <svg
                class="w-4 h-4 text-blue-600 dark:text-blue-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                  clip-rule="evenodd"></path>
              </svg>
              Votre nom
            </label>
            <input
              type="text"
              id="name"
              name="name"
              class="bg-gray-50 border border-gray-300 text-gray-900 text-base rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full p-3.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 transition-all"
              placeholder="Jean Dupont"
              required
            />
          </div>

          <!-- Email Field -->
          <div>
            <label
              for="email"
              class="flex items-center gap-2 mb-2 text-sm font-semibold text-gray-900 dark:text-white"
            >
              <svg
                class="w-4 h-4 text-blue-600 dark:text-blue-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
                ></path>
                <path
                  d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
                ></path>
              </svg>
              Votre email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="bg-gray-50 border border-gray-300 text-gray-900 text-base rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full p-3.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 transition-all"
              placeholder="votre.email@exemple.com"
              required
            />
          </div>

          <!-- Téléphone Field -->
          <div>
            <label
              for="phone"
              class="flex items-center gap-2 mb-2 text-sm font-semibold text-gray-900 dark:text-white"
            >
              <svg
                class="w-4 h-4 text-blue-600 dark:text-blue-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              Téléphone <span class="text-gray-400 font-normal">(optionnel)</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="bg-gray-50 border border-gray-300 text-gray-900 text-base rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full p-3.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 transition-all"
              placeholder="06 12 34 56 78"
            />
          </div>

          <!-- Subject Field -->
          <div>
            <label
              for="subject"
              class="flex items-center gap-2 mb-2 text-sm font-semibold text-gray-900 dark:text-white"
            >
              <svg
                class="w-4 h-4 text-blue-600 dark:text-blue-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                  clip-rule="evenodd"></path>
              </svg>
              Sujet <span class="text-gray-400 font-normal">(optionnel)</span>
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              class="bg-gray-50 border border-gray-300 text-gray-900 text-base rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full p-3.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 transition-all"
              placeholder="En quoi pouvons-nous vous aider ?"
            />
          </div>

          <!-- Message Field -->
          <div class="flex flex-col flex-grow">
            <label
              for="message"
              class="flex items-center gap-2 mb-2 text-sm font-semibold text-gray-900 dark:text-white"
            >
              <svg
                class="w-4 h-4 text-blue-600 dark:text-blue-400"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M18 13V5a2 2 0 00-2-2H4a2 2 0 00-2 2v8a2 2 0 002 2h3l3 3 3-3h3a2 2 0 002-2zM5 7a1 1 0 011-1h8a1 1 0 110 2H6a1 1 0 01-1-1zm1 3a1 1 0 100 2h3a1 1 0 100-2H6z"
                  clip-rule="evenodd"></path>
              </svg>
              Votre message
            </label>
            <textarea
              id="message"
              name="message"
              class="bg-gray-50 border border-gray-300 text-gray-900 text-base rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full p-3.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500 transition-all resize-none flex-grow min-h-[200px]"
              placeholder="Décrivez votre demande..."
              required></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-button"
            class="w-full bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-bold py-4 px-6 rounded-lg transition-all duration-300 transform hover:scale-[1.02] focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800 shadow-lg hover:shadow-xl flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          >
            <svg
              id="send-icon"
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
            </svg>
            <svg
              id="loading-icon"
              class="w-5 h-5 animate-spin hidden"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
            <span id="button-text">Envoyer le message</span>
          </button>
        </form>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const form = document.getElementById('contact-form');
          const submitButton = document.getElementById('submit-button');
          const buttonText = document.getElementById('button-text');
          const sendIcon = document.getElementById('send-icon');
          const loadingIcon = document.getElementById('loading-icon');
          const formMessage = document.getElementById('form-message');

          form?.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Récupérer les données du formulaire
            const formData = new FormData(form);
            const data = {
              name: formData.get('name'),
              email: formData.get('email'),
              phone: formData.get('phone'),
              subject: formData.get('subject'),
              message: formData.get('message'),
            };

            // Désactiver le bouton et afficher le loader
            submitButton.disabled = true;
            buttonText.textContent = 'Envoi en cours...';
            sendIcon.classList.add('hidden');
            loadingIcon.classList.remove('hidden');
            formMessage.classList.add('hidden');

            try {
              const response = await fetch('/.netlify/functions/send-contact', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
              });

              const result = await response.json();

              if (response.ok) {
                // Succès
                formMessage.innerHTML = `
                  <div class="bg-green-50 dark:bg-green-900/20 border-l-4 border-green-500 p-4 rounded-lg">
                    <div class="flex items-start">
                      <svg class="w-6 h-6 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      <div class="ml-3">
                        <h3 class="text-sm font-semibold text-green-800 dark:text-green-200">Message envoyé avec succès !</h3>
                        <p class="text-sm text-green-700 dark:text-green-300 mt-1">${result.message}</p>
                      </div>
                    </div>
                  </div>
                `;
                formMessage.classList.remove('hidden');

                // Réinitialiser le formulaire
                form.reset();

                // Faire défiler vers le message de succès
                formMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
              } else {
                // Erreur
                throw new Error(result.error || 'Une erreur est survenue');
              }
            } catch (error) {
              // Erreur réseau ou autre
              formMessage.innerHTML = `
                <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-lg">
                  <div class="flex items-start">
                    <svg class="w-6 h-6 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    <div class="ml-3">
                      <h3 class="text-sm font-semibold text-red-800 dark:text-red-200">Erreur lors de l'envoi</h3>
                      <p class="text-sm text-red-700 dark:text-red-300 mt-1">${error.message}</p>
                      <p class="text-sm text-red-600 dark:text-red-400 mt-2">Vous pouvez également nous contacter directement à <a href="mailto:contact@vr-cafe.fr" class="underline font-medium">contact@vr-cafe.fr</a></p>
                    </div>
                  </div>
                </div>
              `;
              formMessage.classList.remove('hidden');
              formMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } finally {
              // Réactiver le bouton
              submitButton.disabled = false;
              buttonText.textContent = 'Envoyer le message';
              sendIcon.classList.remove('hidden');
              loadingIcon.classList.add('hidden');
            }
          });
        });
      </script>
    </div>
  </div>
</section>
