---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import { graph, businessNode, breadcrumb, service } from "../lib/seo";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";

const schema = graph([
  businessNode,
  breadcrumb([
    { name: "Accueil", path: "/" },
    { name: "EVG & EVJF VR", path: "/evg-evjf" },
  ]),
  service({
    name: "EVG / EVJF en réalité virtuelle",
    description:
      "Organisez un enterrement de vie de garçon ou de jeune fille en réalité virtuelle au VR Café de Canet-en-Roussillon, près de Perpignan. Escape games, défis VR et ambiance festive pour 2 à 12 personnes.",
    serviceType: "Enterrement de vie de garçon / jeune fille",
    path: "/evg-evjf",
    offer: { price: 25, description: "Petit groupe, session 60 min" },
  }),
]);
---

<BaseLayout
  title="EVG & EVJF en Réalité Virtuelle à Perpignan | VR Café Canet-en-Roussillon"
  description="Organisez un EVG ou EVJF inoubliable en VR à Canet-en-Roussillon, près de Perpignan. Escape games, ambiance festive, formules groupe. Réservez !"
>
  <JsonLd schema={schema} />
  <!-- Hero -->
  <section class="bg-[var(--color-surface)]">
    <div class="flex flex-col items-center">
      <PageHeader
        eyebrow="EVG / EVJF"
        title="L'activité qui marquera vos esprits avant le grand jour"
        highlight="vos esprits"
        subtitle="Escape games, défis VR, fous rires garantis… Organisez votre enterrement de vie de garçon ou de jeune fille en réalité virtuelle à Canet-en-Roussillon, à 10 min de Perpignan."
      >
        <Button href="/reservation" variant="primary" size="lg">Réserver pour mon EVG/EVJF</Button>
      </PageHeader>
    </div>
  </section>

  <!-- Pourquoi VR Café -->
  <section class="bg-[var(--color-surface-elevated)] pt-10 pb-16 lg:pt-14 lg:pb-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="reveal font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-white text-center mb-12">
        L'activité EVG/EVJF <span class="text-shimmer">parfaite</span> près de Perpignan
      </h2>
      <div class="reveal reveal-stagger grid md:grid-cols-3 gap-6">
        {[
          { emoji: "😂", accent: "from-[var(--color-accent-400)] to-[var(--color-glow-pink)]", title: "Fous rires assurés", text: "Voir ses amis réagir dans la réalité virtuelle, c'est hilarant. Les casques créent des moments inoubliables et des photos mémorables." },
          { emoji: "🎮", accent: "from-[var(--color-glow-blue)] to-[var(--color-brand-500)]", title: "Défis entre amis", text: "Escape games en compétition ou en coopération — qui sera le meilleur ? Les défis VR révèlent les personnalités !" },
          { emoji: "🌊", accent: "from-[var(--color-glow-cyan)] to-[var(--color-brand-500)]", title: "Cadre idéal", text: "Canet-en-Roussillon, entre mer et montagne, à 10 min de Perpignan. Combinez VR Café et plage pour une journée parfaite." },
        ].map((c) => (
          <article class="card-glow group p-7 text-center transition-transform duration-[var(--dur-base)] hover:-translate-y-1">
            <div class={`mx-auto mb-5 inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br ${c.accent} text-2xl shadow-lg transition-transform duration-[var(--dur-base)] group-hover:scale-110`}>{c.emoji}</div>
            <h3 class="text-lg font-bold text-white mb-2">{c.title}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{c.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Programme suggéré -->
  <section class="bg-[var(--color-surface)] pt-10 pb-16 lg:pt-14 lg:pb-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="reveal font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-white text-center mb-12">
        Programme EVG/EVJF suggéré
      </h2>
      <div class="reveal reveal-stagger space-y-4">
        {[
          { time: "14h", accent: "from-[var(--color-glow-blue)] to-[var(--color-brand-500)]", title: "Accueil & initiation", text: "Notre équipe vous accueille et vous guide sur le matériel. Première session découverte pour se mettre dans l'ambiance." },
          { time: "15h", accent: "from-[var(--color-accent-400)] to-[var(--color-glow-pink)]", title: "Escape game VR en équipe", text: "Le futur marié(e) et son équipe affrontent un escape game en réalité virtuelle. Chronomètre en marche !" },
          { time: "16h", accent: "from-[var(--color-glow-pink)] to-[var(--color-brand-500)]", title: "Défis & jeux libres", text: "Tournoi libre, jeux multijoueurs, défis personnalisés… chaque groupe compose son programme." },
          { time: "17h", accent: "from-[var(--color-brand-500)] to-[var(--color-glow-cyan)]", title: "Détente au bar & terrasse", text: "Partagez vos meilleurs moments de la session autour d'un verre dans notre espace bar avec vue." },
        ].map((p) => (
          <div class="flex gap-4 items-stretch">
            <div class={`shrink-0 w-14 inline-flex items-center justify-center rounded-2xl bg-gradient-to-br ${p.accent} text-white font-bold shadow-lg`}>{p.time}</div>
            <div class="card-glow p-5 flex-1">
              <h3 class="text-white font-bold mb-1">{p.title}</h3>
              <p class="text-white/70 text-sm leading-relaxed">{p.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formules -->
  <section class="bg-[var(--color-surface-elevated)] pt-10 pb-16 lg:pt-14 lg:pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="reveal font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-white text-center mb-12">
        Formules EVG / EVJF
      </h2>
      <div class="reveal reveal-stagger grid md:grid-cols-2 gap-6">
        <div class="card-glow p-8">
          <h3 class="text-2xl font-bold text-white mb-2">Petit groupe (2–4 pers.)</h3>
          <div class="mb-5">
            <span class="text-3xl font-extrabold text-[var(--color-brand-300)]">25–29 €</span>
            <span class="text-base font-normal text-white/55">/pers.</span>
          </div>
          <ul class="text-white/75 space-y-2.5 mb-7">
            {["Session 60 min", "Escape game ou jeux au choix", "Initiation incluse", "Réservation en ligne"].map((f) => (
              <li class="flex items-start gap-2.5">
                <svg class="w-5 h-5 shrink-0 mt-0.5 text-[var(--color-brand-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {f}
              </li>
            ))}
          </ul>
          <Button href="/reservation" variant="secondary" size="md" class="w-full">Réserver en ligne</Button>
        </div>
        <div class="card-glow ring-2 ring-[var(--color-brand-500)]/40 p-8">
          <div class="text-xs text-[var(--color-brand-300)] font-bold uppercase tracking-wide mb-2">Groupe</div>
          <h3 class="text-2xl font-bold text-white mb-2">Grand groupe (5–12 pers.)</h3>
          <div class="text-3xl font-extrabold text-[var(--color-brand-300)] mb-5">Sur devis</div>
          <ul class="text-white/75 space-y-2.5 mb-7">
            {["Sessions organisées en rotation", "Privatisation possible", "Programme personnalisé", "Facturation simplifiée"].map((f) => (
              <li class="flex items-start gap-2.5">
                <svg class="w-5 h-5 shrink-0 mt-0.5 text-[var(--color-brand-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {f}
              </li>
            ))}
          </ul>
          <Button href="/contact" variant="primary" size="md" class="w-full">Demander un devis</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[var(--color-surface)] py-16 px-4">
    <div class="reveal relative max-w-4xl mx-auto rounded-[var(--radius-card)] overflow-hidden mesh-bg ring-1 ring-white/10 px-6 py-14 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-4">
        Prêt(e) à vivre le <span class="text-shimmer">meilleur EVG/EVJF</span> de Perpignan ?
      </h2>
      <p class="text-white/70 text-lg mb-8 max-w-2xl mx-auto">
        Réservez directement en ligne ou contactez-nous pour organiser votre soirée sur-mesure.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/reservation" variant="primary" size="lg">Réserver en ligne</Button>
        <Button href="/contact" variant="secondary" size="lg">Nous contacter</Button>
      </div>
    </div>
  </section>
</BaseLayout>
