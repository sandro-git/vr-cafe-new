---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Salle de Réalité Virtuelle à Perpignan — VR Café Canet-en-Roussillon"
  description="La meilleure salle VR près de Perpignan. Escape games, jeux multijoueurs et free roaming à Canet-en-Roussillon, à seulement 10 min de Perpignan."
  canonical="https://vr-cafe.fr/realite-virtuelle-perpignan"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["EntertainmentBusiness", "LocalBusiness"],
    "name": "VR Café",
    "url": "https://vr-cafe.fr",
    "description": "La salle VR la plus proche de Perpignan. Escape games, jeux multijoueurs et free roaming à Canet-en-Roussillon, à seulement 10 minutes de Perpignan.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "2 rue du Pilou",
      "addressLocality": "Canet-en-Roussillon",
      "postalCode": "66140",
      "addressRegion": "Occitanie",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 42.7025,
      "longitude": 3.0211
    },
    "telephone": "+33671410695",
    "email": "contact@vr-cafe.fr",
    "priceRange": "€€",
    "hasMap": "https://maps.google.com/?q=VR+Café+2+rue+du+Pilou+66140+Canet-en-Roussillon",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"],
        "opens": "14:00",
        "closes": "20:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Friday", "Saturday"],
        "opens": "10:00",
        "closes": "22:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Sunday"],
        "opens": "10:00",
        "closes": "20:00"
      }
    ]
  })} />
  <!-- Hero -->
  <section class="bg-[var(--color-surface)]">
    <div class="flex flex-col items-center">
      <PageHeader
        eyebrow="Réalité virtuelle · Perpignan"
        title="La salle VR incontournable du Roussillon"
        highlight="incontournable"
        subtitle="À seulement 10 minutes de Perpignan. Escape games, jeux multijoueurs, free roaming… Vivez des expériences immersives inoubliables au VR Café de Canet-en-Roussillon."
      >
        <Button href="/reservation" variant="primary" size="lg">Réserver ma session</Button>
      </PageHeader>
    </div>
  </section>

  <!-- Proximité Perpignan -->
  <section class="bg-[var(--color-surface-elevated)] pt-10 pb-16 lg:pt-14 lg:pb-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="reveal font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-white text-center mb-12">
        La salle VR <span class="text-shimmer">la plus proche</span> de Perpignan
      </h2>
      <div class="reveal reveal-stagger grid md:grid-cols-3 gap-6 text-center">
        {[
          { stat: "10 min", color: "text-[var(--color-brand-300)]", label: "depuis le centre de Perpignan" },
          { stat: "250 m²", color: "text-[var(--color-glow-pink)]", label: "de salle immersive" },
          { stat: "4,9/5", color: "text-[var(--color-glow-cyan)]", label: "sur TripAdvisor (56 avis)" },
        ].map((s) => (
          <div class="card-glow p-7">
            <div class={`text-4xl font-extrabold mb-2 ${s.color}`}>{s.stat}</div>
            <p class="text-white/70">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expériences disponibles -->
  <section class="bg-[var(--color-surface)] pt-10 pb-16 lg:pt-14 lg:pb-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="reveal font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-white text-center mb-12">
        Nos expériences VR près de Perpignan
      </h2>
      <div class="reveal reveal-stagger grid md:grid-cols-2 gap-6">
        {[
          { href: "/escapes", title: "Escape Games VR", text: "Résolvez des énigmes en réalité virtuelle en équipe. Des scénarios épiques pour 1 à 6 joueurs — la formule idéale entre amis ou en famille.", cta: "Découvrir les escapes" },
          { href: "/freeroaming", title: "Free Roaming VR", text: "Sautez dans la réalité virtuelle sans câbles. Le free roaming offre une liberté totale de mouvement pour une immersion absolue.", cta: "Découvrir le free roaming" },
          { href: "/jeux", title: "Jeux VR Multijoueur", text: "Affrontez-vous ou coopérez en réalité virtuelle. Des dizaines de jeux pour tous les niveaux, dès 7 ans.", cta: "Voir les jeux" },
          { href: "/cadeaux", title: "Cartes Cadeaux", text: "Offrez une expérience inoubliable à vos proches. Valable 1 an sur toutes nos formules. Livraison par email immédiate.", cta: "Commander une carte cadeau" },
        ].map((e) => (
          <a href={e.href} class="card-glow group block p-8 transition-transform duration-[var(--dur-base)] hover:-translate-y-1">
            <h3 class="text-2xl font-bold text-white mb-3 transition-colors group-hover:text-[var(--color-brand-300)]">{e.title}</h3>
            <p class="text-white/70 mb-4 leading-relaxed">{e.text}</p>
            <span class="inline-flex items-center gap-1.5 text-[var(--color-brand-300)] font-semibold">
              {e.cta}
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tarifs -->
  <section class="bg-[var(--color-surface-elevated)] pt-10 pb-16 lg:pt-14 lg:pb-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="reveal font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-white mb-4">
        Tarifs accessibles depuis Perpignan
      </h2>
      <p class="reveal text-white/55 mb-10">Les meilleures expériences VR au meilleur prix du département</p>
      <div class="reveal reveal-stagger grid md:grid-cols-2 gap-6 text-left">
        <div class="card-glow p-8">
          <div class="mb-2">
            <span class="text-3xl font-extrabold text-white">18 €</span>
            <span class="text-lg font-normal text-white/55">/pers.</span>
          </div>
          <div class="text-[var(--color-brand-300)] font-semibold text-xl mb-3">Session 30 min</div>
          <p class="text-white/70">Idéal pour découvrir la VR ou pour une sortie rapide</p>
        </div>
        <div class="card-glow ring-2 ring-[var(--color-brand-500)]/40 p-8">
          <div class="text-xs text-[var(--color-brand-300)] font-bold uppercase tracking-wide mb-2">Populaire</div>
          <div class="mb-2">
            <span class="text-3xl font-extrabold text-white">25–29 €</span>
            <span class="text-lg font-normal text-white/55">/pers.</span>
          </div>
          <div class="text-[var(--color-brand-300)] font-semibold text-xl mb-3">Session 60 min</div>
          <p class="text-white/70">La formule complète pour profiter de toutes les expériences</p>
        </div>
      </div>
      <div class="reveal mt-10">
        <Button href="/reservation" variant="primary" size="lg">Réserver maintenant</Button>
      </div>
    </div>
  </section>

  <!-- Accès -->
  <section class="bg-[var(--color-surface)] py-16 px-4">
    <div class="reveal relative max-w-3xl mx-auto rounded-[var(--radius-card)] overflow-hidden mesh-bg ring-1 ring-white/10 px-6 py-14 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-6">Comment venir depuis Perpignan ?</h2>
      <p class="text-white text-lg font-semibold mb-4">
        VR Café — 2 rue du Pilou, 66140 Canet-en-Roussillon
      </p>
      <p class="text-white/70 mb-3">
        À seulement 10 minutes en voiture depuis Perpignan via la D617. Parking gratuit à proximité.
      </p>
      <p class="text-white/70 mb-8">
        En bus depuis Perpignan : ligne 1 (arrêt Canet-Village) ou ligne côtière en été.
      </p>
      <Button
        href="https://maps.google.com/?q=VR+Café+2+rue+du+Pilou+66140+Canet-en-Roussillon"
        variant="secondary"
        size="md"
        target="_blank"
        rel="noopener noreferrer"
      >
        Voir sur Google Maps
      </Button>
    </div>
  </section>
</BaseLayout>
