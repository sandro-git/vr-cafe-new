---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "sanity:client";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";

type Tarif = {
  _id: string;
  name: string;
  type: "session_30min" | "session_1h" | "anniversaire";
  prix: number;
  badge?: string;
  features?: string[];
  ordre: number;
};

const tarifs = await sanityClient.fetch<Tarif[]>(
  `*[_type == "tarif" && type in ["session_30min", "session_1h"]] | order(ordre asc) { _id, name, type, prix, badge, features, ordre }`
);

const tarif30min = tarifs.find((t) => t.type === "session_30min");
const tarifs1h = tarifs.filter((t) => t.type === "session_1h");
---

<BaseLayout
  title="Tarifs VR Café Canet-en-Roussillon — Prix Sessions VR & Escape Game | Perpignan"
  description="Découvrez nos tarifs pour les sessions VR, escape games et jeux multijoueurs à Canet-en-Roussillon. Dès 18€/personne. Réservation en ligne."
  canonical="https://vr-cafe.fr/tarifs"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Tarifs VR Café",
    "description": "Sessions de réalité virtuelle à Canet-en-Roussillon — prix par personne",
    "itemListElement": [
      {
        "@type": "Offer",
        "position": 1,
        "name": "Session VR 30 minutes",
        "price": "18",
        "priceCurrency": "EUR",
        "url": "https://vr-cafe.fr/tarifs",
        "seller": { "@type": "LocalBusiness", "name": "VR Café" }
      },
      {
        "@type": "Offer",
        "position": 2,
        "name": "Session VR 1 heure — 1 à 2 joueurs",
        "price": "29",
        "priceCurrency": "EUR",
        "url": "https://vr-cafe.fr/tarifs",
        "seller": { "@type": "LocalBusiness", "name": "VR Café" }
      },
      {
        "@type": "Offer",
        "position": 3,
        "name": "Session VR 1 heure — 3 à 4 joueurs",
        "price": "27",
        "priceCurrency": "EUR",
        "url": "https://vr-cafe.fr/tarifs",
        "seller": { "@type": "LocalBusiness", "name": "VR Café" }
      },
      {
        "@type": "Offer",
        "position": 4,
        "name": "Session VR 1 heure — 5 joueurs et plus",
        "price": "25",
        "priceCurrency": "EUR",
        "url": "https://vr-cafe.fr/tarifs",
        "seller": { "@type": "LocalBusiness", "name": "VR Café" }
      }
    ]
  })} />
  <section class="bg-[var(--color-surface)] pb-20 lg:pb-28">
    <div class="flex flex-col items-center">
      <PageHeader
        eyebrow="Tarifs"
        title="Des prix pour toutes les envies"
        highlight="toutes les envies"
        subtitle="Solo, duo ou groupe — réservez en ligne en quelques clics. Dès 18 € par personne."
      />
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Session 30 min -->
      {tarif30min && (
        <div class="reveal mb-14">
          <h2 class="font-display text-2xl sm:text-3xl font-extrabold tracking-tight text-white text-center mb-8">Session 30 minutes</h2>
          <div class="flex justify-center">
            <div class="card-glow w-full max-w-sm p-8 text-center transition-transform duration-[var(--dur-base)] hover:-translate-y-1">
              <div class="mb-6">
                <span class="text-6xl font-extrabold text-white">{tarif30min.prix}</span>
                <span class="text-3xl font-semibold text-white">€</span>
                <span class="text-lg text-white/55 ml-1">/personne</span>
              </div>
              {tarif30min.features && (
                <ul class="space-y-3 text-white/75 mb-8 text-left">
                  {tarif30min.features.map((f) => (
                    <li class="flex items-start gap-2.5">
                      <svg class="w-5 h-5 shrink-0 mt-0.5 text-[var(--color-brand-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      {f}
                    </li>
                  ))}
                </ul>
              )}
              <Button href="/reservation" variant="primary" size="md" class="w-full">Réserver</Button>
            </div>
          </div>
        </div>
      )}

      <!-- Session 1 heure -->
      {tarifs1h.length > 0 && (
        <div class="reveal mb-14">
          <h2 class="font-display text-2xl sm:text-3xl font-extrabold tracking-tight text-white text-center mb-3">Session 1 heure</h2>
          <p class="text-center text-white/55 mb-10">Le prix varie selon le nombre de joueurs</p>
          <div class="reveal-stagger grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
            {tarifs1h.map((tarif) => {
              const hasGroupBadge = tarif.badge && tarif.badge.length > 0;
              return (
                <div class:list={[
                  "card-glow relative p-8 text-center transition-transform duration-[var(--dur-base)] hover:-translate-y-1",
                  hasGroupBadge && "ring-2 ring-[var(--color-brand-500)]/40",
                ]}>
                  {hasGroupBadge && (
                    <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                      <span class="bg-gradient-to-r from-[var(--color-brand-500)] to-[var(--color-glow-pink)] text-white text-xs font-bold px-4 py-1.5 rounded-full shadow whitespace-nowrap">
                        {tarif.badge}
                      </span>
                    </div>
                  )}
                  <h3 class="text-base font-bold text-white/70 mb-4">{tarif.name}</h3>
                  <div class="mb-6">
                    <span class="text-5xl font-extrabold text-[var(--color-brand-300)]">{tarif.prix}</span>
                    <span class="text-2xl font-semibold text-[var(--color-brand-300)]">€</span>
                    <span class="text-base text-white/55 ml-1">/pers.</span>
                  </div>
                  {tarif.features && (
                    <ul class="space-y-2 text-white/75 text-sm mb-6 text-left">
                      {tarif.features.map((f) => (
                        <li class="flex items-start gap-2.5">
                          <svg class="w-4 h-4 shrink-0 mt-0.5 text-[var(--color-brand-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                          {f}
                        </li>
                      ))}
                    </ul>
                  )}
                  <Button href="/reservation" variant={hasGroupBadge ? "primary" : "secondary"} size="sm" class="w-full">Réserver</Button>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <div class="reveal text-center">
        <p class="text-white/55 text-sm mb-6">
          Pour les groupes de plus de 10 personnes ou les événements d'entreprise, <a href="/contact" class="text-[var(--color-brand-300)] hover:underline">contactez-nous</a>.
        </p>
        <Button href="/reservation" variant="primary" size="lg">Réserver maintenant</Button>
      </div>
    </div>
  </section>
</BaseLayout>
