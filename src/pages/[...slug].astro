---
// src/pages/[...slug].astro
import BaseLayout from "../layouts/BaseLayout.astro";
import YoutubePlayer from "../components/YoutubePlayer.astro";
import SanityPicture from "../components/SanityPicture.astro";
import Play from "../components/Play.astro";

export const prerender = true;

import { loadQuery } from "../sanity/lib/load-query";
import { GAME_PATHS_QUERY, GAME_BY_SLUG_QUERY } from "../sanity/lib/queries";
import type { GAME_PATHS_QUERY_RESULT, GAME_BY_SLUG_QUERY_RESULT } from "../../sanity.types";

export async function getStaticPaths() {
  const { data: games } = await loadQuery<GAME_PATHS_QUERY_RESULT>({
    query: GAME_PATHS_QUERY,
  });

  return games.map(({ slug }) => ({
    params: { slug: slug!.current },
  }));
}

const { params } = Astro;

const { data: game } = await loadQuery<GAME_BY_SLUG_QUERY_RESULT>({
  query: GAME_BY_SLUG_QUERY,
  params,
});

if (!game) {
  return Astro.redirect("/404");
}
---

<BaseLayout
  title={`${game.name} — VR Café Canet-en-Roussillon`}
  description={game.description ? game.description.slice(0, 155) + (game.description.length > 155 ? '…' : '') : `Découvrez ${game.name} en réalité virtuelle au VR Café de Canet-en-Roussillon, à 10 min de Perpignan. Réservez en ligne !`}
  canonical={`https://vr-cafe.fr/${params.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": "https://vr-cafe.fr"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": game.name,
        "item": `https://vr-cafe.fr/${params.slug}`
      }
    ]
  })} />
  <div class="container mx-auto px-4 py-8 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
      <!-- Image à gauche -->
      <div class="relative rounded-2xl overflow-hidden shadow-2xl">
        {game.image && (
          <SanityPicture
            image={game.image}
            alt={game.name}
            className="w-full h-auto"
          />
        )}
      </div>

      <!-- Détails à droite -->
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4">
            {game.name}
          </h1>

          <!-- Tags -->
          {game.tags && game.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {game.tags.filter(tag => tag !== null).map((tag) => (
                <span class="px-3 py-1 text-sm border border-blue-400 text-blue-400 rounded-full">
                  {tag.title}
                </span>
              ))}
            </div>
          )}

          <!-- Métadonnées -->
          <div class="space-y-3 text-white">
            {game.players && (
              <div class="flex items-center gap-2">
                <span class="font-semibold">De {game.players} joueurs</span>
              </div>
            )}
            {game.duration && (
              <div class="flex items-center gap-2">
                <span class="font-semibold">Durée :</span>
                <span>{game.duration}</span>
              </div>
            )}
            {game.difficulty && (
              <div class="flex items-center gap-2">
                <span class="font-semibold">Difficulté :</span>
                <div class="flex gap-1">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <div
                      class={`w-3 h-3 rounded-full border border-white ${
                        i < game.difficulty ? 'bg-white' : 'bg-transparent'
                      }`}
                    />
                  ))}
                </div>
              </div>
            )}
            {game.age && (
              <div class="flex items-center gap-2">
                <span class="font-semibold">Age conseillé :</span>
                <span>{game.age}</span>
              </div>
            )}
          </div>
        </div>

        <!-- Description -->
        <div class="text-white space-y-4">
          <p class="text-lg leading-relaxed">{game.description}</p>
        </div>

        <!-- Boutons d'action -->
        <div class="flex flex-wrap gap-4 mt-4">
          <button
            onclick={`document.getElementById('video-modal').classList.remove('hidden')`}
            class="flex items-center gap-2 px-6 py-3 border-2 border-white text-white rounded-lg hover:bg-white hover:text-gray-900 focus:outline-none focus:ring-4 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors"
            aria-label="Voir la vidéo de présentation"
            type="button"
          >
            <Play size={24} />
            Voir la vidéo
          </button>
          <a
            href="/reservation"
            class="px-8 py-3 bg-linear-to-r from-purple-500 to-pink-500 text-white rounded-lg font-semibold hover:shadow-lg transition-shadow"
          >
            Réserver
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal vidéo -->
  <div
    id="video-modal"
    class="fixed inset-0 bg-black/90 z-50 hidden"
    onclick="this.classList.add('hidden')"
    role="dialog"
    aria-modal="true"
    aria-label="Vidéo de présentation"
  >
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="w-full max-w-5xl" onclick="event.stopPropagation()">
        <div class="flex justify-end mb-4">
          <button
            onclick="document.getElementById('video-modal').classList.add('hidden')"
            class="text-white text-4xl hover:text-gray-300 focus:outline-none focus:ring-4 focus:ring-white rounded-lg px-3 transition-colors"
            aria-label="Fermer la vidéo"
            type="button"
          >
            ×
          </button>
        </div>
        {game.youtubeLink && (
          <YoutubePlayer videoId={game.youtubeLink} />
        )}
      </div>
    </div>
  </div>
</BaseLayout>
