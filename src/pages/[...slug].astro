---
// src/pages/[...slug].astro
import BaseLayout from "../layouts/BaseLayout.astro";
import YoutubePlayer from "../components/YoutubePlayer.astro";
import SanityPicture from "../components/SanityPicture.astro";
import Play from "../components/Play.astro";
import Button from "../components/Button.astro";
import JsonLd from "../components/JsonLd.astro";
import { graph, breadcrumb } from "../lib/seo";

export const prerender = true;

import { loadQuery } from "../sanity/lib/load-query";
import { GAME_PATHS_QUERY, GAME_BY_SLUG_QUERY } from "../sanity/lib/queries";
import type { GAME_PATHS_QUERY_RESULT, GAME_BY_SLUG_QUERY_RESULT } from "../../sanity.types";

export async function getStaticPaths() {
  const { data: games } = await loadQuery<GAME_PATHS_QUERY_RESULT>({
    query: GAME_PATHS_QUERY,
  });

  return games.map(({ slug }) => ({
    params: { slug: slug!.current },
  }));
}

const { params } = Astro;

const { data: game } = await loadQuery<GAME_BY_SLUG_QUERY_RESULT>({
  query: GAME_BY_SLUG_QUERY,
  params: { slug: params.slug! },
});

if (!game) {
  return Astro.redirect("/404");
}
---

<BaseLayout
  title={`${game.name} — VR Café Canet-en-Roussillon`}
  description={game.description ? game.description.slice(0, 155) + (game.description.length > 155 ? '…' : '') : `Découvrez ${game.name} en réalité virtuelle au VR Café de Canet-en-Roussillon, à 10 min de Perpignan. Réservez en ligne !`}
  canonical={`https://vr-cafe.fr/${params.slug}/`}
>
  <JsonLd
    schema={graph([
      breadcrumb([
        { name: "Accueil", path: "/" },
        { name: game.name!, path: `/${params.slug}/` },
      ]),
    ])}
  />
  <section class="bg-[var(--color-surface)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-8 lg:pt-12 pb-20 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
        <!-- Image à gauche -->
        <div class="reveal relative rounded-[var(--radius-card)] overflow-hidden ring-1 ring-white/10 shadow-[0_30px_120px_-20px_rgba(139,92,246,0.45)]">
          {game.image && (
            <SanityPicture
              image={game.image}
              alt={game.name}
              className="w-full h-auto"
              sizes="(min-width: 1024px) 600px, 100vw"
              loading="eager"
            />
          )}
        </div>

        <!-- Détails à droite -->
        <div class="reveal flex flex-col gap-6">
          <div>
            <h1 class="font-display text-4xl lg:text-5xl font-extrabold tracking-tight text-white mb-4">
              {game.name}
            </h1>

            <!-- Tags -->
            {game.tags && game.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-6">
                {game.tags.filter(tag => tag !== null).map((tag) => (
                  <span class="px-3 py-1 text-sm rounded-full bg-white/5 ring-1 ring-[var(--color-brand-500)]/30 text-[var(--color-brand-300)]">
                    {tag.title}
                  </span>
                ))}
              </div>
            )}

            <!-- Métadonnées -->
            <div class="flex flex-wrap gap-2.5">
              {game.players && (
                <span class="inline-flex items-center gap-2 rounded-full bg-white/5 ring-1 ring-white/10 px-4 py-2 text-sm text-white/85">
                  <svg class="w-4 h-4 text-[var(--color-glow-blue)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-8a4 4 0 11-8 0 4 4 0 018 0zm6 3a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  De {game.players} joueurs
                </span>
              )}
              {game.duration && (
                <span class="inline-flex items-center gap-2 rounded-full bg-white/5 ring-1 ring-white/10 px-4 py-2 text-sm text-white/85">
                  <svg class="w-4 h-4 text-[var(--color-glow-cyan)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  {game.duration}
                </span>
              )}
              {game.age && (
                <span class="inline-flex items-center gap-2 rounded-full bg-white/5 ring-1 ring-white/10 px-4 py-2 text-sm text-white/85">
                  <svg class="w-4 h-4 text-[var(--color-glow-pink)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  Dès {game.age}
                </span>
              )}
            </div>

            {game.difficulty && (
              <div class="flex items-center gap-3 mt-4">
                <span class="text-sm font-semibold text-white/70">Difficulté</span>
                <div class="flex gap-1.5">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <div
                      class={`w-2.5 h-2.5 rounded-full ${
                        i < (game.difficulty ?? 0) ? 'bg-[var(--color-brand-400)]' : 'bg-white/15'
                      }`}
                    />
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Description -->
          <div class="space-y-4">
            <p class="text-lg leading-relaxed text-white/75">{game.description}</p>
          </div>

          <!-- Boutons d'action -->
          <div class="flex flex-wrap gap-4 mt-2">
            <Button
              variant="secondary"
              size="md"
              class="video-trigger"
              ariaLabel="Voir la vidéo de présentation"
            >
              <Play size={20} />
              Voir la vidéo
            </Button>
            <Button href="/reservation" variant="primary" size="md">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Réserver
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal vidéo -->
  <div
    id="video-modal"
    class="fixed inset-0 bg-black/90 z-50 hidden"
    onclick="this.classList.add('hidden')"
    role="dialog"
    aria-modal="true"
    aria-label="Vidéo de présentation"
  >
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="w-full max-w-5xl" onclick="event.stopPropagation()">
        <div class="flex justify-end mb-4">
          <button
            onclick="document.getElementById('video-modal').classList.add('hidden')"
            class="text-white text-4xl hover:text-gray-300 focus:outline-none focus:ring-4 focus:ring-white rounded-lg px-3 transition-colors"
            aria-label="Fermer la vidéo"
            type="button"
          >
            ×
          </button>
        </div>
        {game.youtubeLink && (
          <YoutubePlayer videoId={game.youtubeLink} />
        )}
      </div>
    </div>
  </div>

  <script>
    const initVideoTrigger = () => {
      document.querySelectorAll(".video-trigger").forEach((btn) => {
        if ((btn as HTMLElement).dataset.videoBound === "1") return;
        (btn as HTMLElement).dataset.videoBound = "1";
        btn.addEventListener("click", () => {
          document.getElementById("video-modal")?.classList.remove("hidden");
        });
      });
    };
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initVideoTrigger);
    } else {
      initVideoTrigger();
    }
    document.addEventListener("astro:page-load", initVideoTrigger);
  </script>
</BaseLayout>
