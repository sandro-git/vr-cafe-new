---
export const prerender = true;
// Welcome to Astro! Everything between these triple-dash code fences
// is your "component frontmatter". It never runs in the browser.
//components
import GameList from "../components/GameList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import GamesLayout from "../layouts/GamesLayout.astro";

import { loadQuery } from "../sanity/lib/load-query";
import { FREEROAMING_QUERY } from "../sanity/lib/queries";
import type { JEUX_VR_QUERY_RESULT } from "../../sanity.types";
import JsonLd from "../components/JsonLd.astro";
import { graph, businessNode, breadcrumb, gameListSchema } from "../lib/seo";

const { data: freeroaming } = await loadQuery<JEUX_VR_QUERY_RESULT>({ query: FREEROAMING_QUERY });

const schema = graph([
  businessNode,
  breadcrumb([
    { name: "Accueil", path: "/" },
    { name: "Free Roaming VR", path: "/freeroaming" },
  ]),
  gameListSchema(freeroaming),
]);
---

<BaseLayout
  title="Jumpers VR à Canet-en-Roussillon — Saut en Réalité Virtuelle | VR Café"
  description="Sautez dans la réalité virtuelle sans fil à Canet-en-Roussillon. L'expérience free roaming la plus immersive près de Perpignan. Réservez !"
>
  <JsonLd schema={schema} />
  <GamesLayout
    title="VR Sans Fil"
    highlight="Sans Fil"
    subtitle="Liberté de mouvement totale : déplacez-vous réellement dans des mondes virtuels, sans aucun câble."
  >
    <GameList experiences={freeroaming} />
  </GamesLayout>
</BaseLayout>
