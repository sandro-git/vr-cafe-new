---
export const prerender = true;
import GameList from "../components/GameList.astro";
import GamesLayout from "../layouts/GamesLayout.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

import { sanityClient } from "sanity:client";
import JsonLd from "../components/JsonLd.astro";
import { graph, businessNode, breadcrumb, gameListSchema } from "../lib/seo";

const escapes =
  await sanityClient.fetch(`*[_type == "games" && tag->title == "escapeGame"]{
  name,
  description,
  image{
    alt,
    asset->{url}
  },
  tag->{name, title},
  players,
  duration,
  slug
}`);
// This fetches all games with the tag "escapeGame" from Sanity

const schema = graph([
  businessNode,
  breadcrumb([
    { name: "Accueil", path: "/" },
    { name: "Escape Games VR", path: "/escapes" },
  ]),
  gameListSchema(escapes),
]);
---

<BaseLayout
  title="Escape Game VR à Perpignan | Canet-en-Roussillon — VR Café"
  description="Vivez les meilleurs escape games en réalité virtuelle à Canet-en-Roussillon, à 10 min de Perpignan. Dès 25€/pers. Réservation en ligne."
>
  <JsonLd schema={schema} />
  <GamesLayout>
    <GameList experiences={escapes} />
  </GamesLayout>
</BaseLayout>
