---
export const prerender = true;
import GameList from "../components/GameList.astro";
import GamesLayout from "../layouts/GamesLayout.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

import { loadQuery } from "../sanity/lib/load-query";
import { GAMES_BY_TAG_QUERY, type GameListItem } from "../sanity/lib/queries";
import JsonLd from "../components/JsonLd.astro";
import { graph, businessNode, breadcrumb, gameListSchema } from "../lib/seo";

const { data: escapes } = await loadQuery<GameListItem[]>({
  query: GAMES_BY_TAG_QUERY,
  params: { tagTitle: "escapeGame" },
});

const schema = graph([
  businessNode,
  breadcrumb([
    { name: "Accueil", path: "/" },
    { name: "Escape Games VR", path: "/escapes" },
  ]),
  gameListSchema(escapes),
]);
---

<BaseLayout
  title="Escape Game VR à Perpignan | Canet-en-Roussillon — VR Café"
  description="Vivez les meilleurs escape games en réalité virtuelle à Canet-en-Roussillon, à 10 min de Perpignan. Dès 25€/pers. Réservation en ligne."
>
  <JsonLd schema={schema} />
  <GamesLayout
    title="Escape Games VR"
    highlight="Escape Games"
    subtitle="Résolvez des énigmes immersives en équipe, dans des univers où chaque seconde compte."
    filters={[
      { href: "/escapes", label: "Tout" },
      { href: "/escapes/arvi", label: "ARVI VR" },
      { href: "/escapes/ubisoft", label: "Ubisoft" },
    ]}
  >
    <GameList experiences={escapes} />
  </GamesLayout>
</BaseLayout>
