---
// Enhanced with StarWind CTA component
import GameList from "../components/GameList.astro";
import GamesLayout from "../layouts/GamesLayout.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "@/components/starwind/button/Button.astro";

import { getGamesByTag } from "../lib/keystatic-reader";
import Play from "../components/Play.astro";

const escapes = await getGamesByTag("escapeGame");
// This fetches all games with the tag "escapeGame" from Keystatic
---

<BaseLayout>
  <GamesLayout>
    <GameList experiences={escapes} />

    <!-- CTA Section -->
    <section class="bg-white dark:bg-gray-900 py-12 md:py-16">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="text-left">
          <h2 class="mb-4 text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">
            Relevez le défi des Escape Games VR !
          </h2>
          <p class="mb-8 text-lg text-gray-600 dark:text-gray-300 max-w-2xl">
            Collaborez avec votre équipe pour résoudre des énigmes immersives et échapper dans le temps imparti. Une expérience unique de team-building ou de divertissement !
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button href="/reservation" size="lg" class="bg-blue-700 hover:bg-blue-800 text-white px-8 py-4 text-lg transform hover:scale-105 transition-all">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Réserver maintenant
            </Button>
            <Button href="/contact" variant="outline" size="lg" class="border-2 border-blue-700 text-blue-700 dark:text-blue-400 dark:border-blue-400 hover:bg-blue-50 dark:hover:bg-gray-800 px-8 py-4 text-lg">
              Nous contacter
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </Button>
          </div>
        </div>
      </div>
    </section>
  </GamesLayout>
</BaseLayout>
