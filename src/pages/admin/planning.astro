---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <main class="min-h-screen py-8 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto">

      <!-- En-tête -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-white">Planning</h1>
          <p class="text-gray-400 text-sm mt-0.5">VR Café · Back-office</p>
        </div>
        <a
          href="/admin/reservations"
          class="text-sm text-gray-400 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500"
        >
          ← Réservations
        </a>
      </div>

      <!-- Contrôles -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <!-- Navigation date -->
        <div class="flex items-center gap-2">
          <button
            id="btn-prev"
            class="w-9 h-9 flex items-center justify-center bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-xl border border-gray-600 transition-colors text-lg"
          >‹</button>
          <button
            id="btn-today"
            class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-xl border border-gray-600 transition-colors"
          >Aujourd'hui</button>
          <button
            id="btn-next"
            class="w-9 h-9 flex items-center justify-center bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-xl border border-gray-600 transition-colors text-lg"
          >›</button>
          <span id="date-label" class="text-white font-medium ml-2 text-sm sm:text-base"></span>
        </div>

        <!-- Onglets vue -->
        <div class="flex rounded-xl border border-gray-600 overflow-hidden">
          <button
            id="tab-week"
            class="px-4 py-2 text-sm font-medium transition-colors bg-blue-600 text-white"
          >Vue Semaine</button>
          <button
            id="tab-day"
            class="px-4 py-2 text-sm font-medium transition-colors text-gray-400 hover:text-white"
          >Vue Jour</button>
        </div>
      </div>

      <!-- Loader -->
      <div id="plan-loading" class="py-16 text-center">
        <div class="inline-block w-10 h-10 border-4 border-gray-600 border-t-blue-500 rounded-full animate-spin mb-4"></div>
        <p class="text-gray-400">Chargement...</p>
      </div>

      <!-- Erreur -->
      <div id="plan-error" class="hidden mb-4 p-4 bg-red-900/50 border border-red-700 rounded-xl text-red-300 text-sm"></div>

      <!-- Vue Semaine -->
      <div id="view-week" class="hidden overflow-x-auto">
        <div id="week-grid" class="min-w-[640px]"></div>
      </div>

      <!-- Vue Jour -->
      <div id="view-day" class="hidden overflow-x-auto">
        <div id="day-grid" class="min-w-[640px]"></div>
      </div>

    </div>
  </main>
</AdminLayout>

<script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ── Constantes ────────────────────────────────────────────────────────────
  let OPEN_HOUR = 10;
  let CLOSE_HOUR = 22;
  let BUFFER_MIN = 30;
  const ROW_H = 48; // px par tranche de 30 min
  let TOTAL_ROWS = (CLOSE_HOUR - OPEN_HOUR) * 2;

  const DAY_NAMES = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'];
  const DAY_NAMES_FULL = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche'];
  const MONTH_NAMES = [
    'janvier', 'février', 'mars', 'avril', 'mai', 'juin',
    'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'
  ];

  // ── État ──────────────────────────────────────────────────────────────────
  let currentView = 'week';
  let currentWeekStart = getMonday(new Date());
  let currentDay = stripTime(new Date());
  let boxes = [];

  // ── Utilitaires date ──────────────────────────────────────────────────────
  function stripTime(d) {
    return new Date(d.getFullYear(), d.getMonth(), d.getDate());
  }

  function getMonday(d) {
    const date = stripTime(d);
    const day = date.getDay(); // 0=dim, 1=lun, …
    const diff = (day === 0 ? -6 : 1 - day);
    date.setDate(date.getDate() + diff);
    return date;
  }

  function addDays(d, n) {
    const r = new Date(d);
    r.setDate(r.getDate() + n);
    return r;
  }

  function isSameDay(a, b) {
    return a.getFullYear() === b.getFullYear()
      && a.getMonth() === b.getMonth()
      && a.getDate() === b.getDate();
  }

  function formatTime(d) {
    return d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
  }

  function esc(str) {
    return String(str ?? '—')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  // ── Labels de date ────────────────────────────────────────────────────────
  function updateDateLabel() {
    const el = document.getElementById('date-label');
    if (currentView === 'week') {
      const end = addDays(currentWeekStart, 6);
      const sameMonth = currentWeekStart.getMonth() === end.getMonth();
      if (sameMonth) {
        el.textContent = `${currentWeekStart.getDate()} – ${end.getDate()} ${MONTH_NAMES[end.getMonth()]} ${end.getFullYear()}`;
      } else {
        el.textContent = `${currentWeekStart.getDate()} ${MONTH_NAMES[currentWeekStart.getMonth()]} – ${end.getDate()} ${MONTH_NAMES[end.getMonth()]} ${end.getFullYear()}`;
      }
    } else {
      const dayIdx = (currentDay.getDay() + 6) % 7; // 0=lun, 6=dim
      el.textContent = `${DAY_NAMES_FULL[dayIdx]} ${currentDay.getDate()} ${MONTH_NAMES[currentDay.getMonth()]} ${currentDay.getFullYear()}`;
    }
  }

  // ── Couleurs statut + durée ───────────────────────────────────────────────
  function statusClass(statut, duree) {
    if (statut === 'annulée')  return 'bg-red-900/60 border-red-800 text-red-200';
    if (statut === 'no_show')  return 'bg-yellow-900/60 border-yellow-700 text-yellow-200';
    if (statut === 'confirmée') {
      return duree <= 30
        ? 'bg-violet-700/60 border-violet-500 text-violet-100'  // 30 min → violet
        : 'bg-blue-700/60 border-blue-500 text-blue-100';        // 60 min → bleu
    }
    return 'bg-gray-700/60 border-gray-600 text-gray-300';
  }

  // ── Chargement données ─────────────────────────────────────────────────────
  async function loadConfig() {
    const { data, error } = await supabase.from('config').select('cle, valeur');
    if (error || !data?.length) return;
    const cfg = Object.fromEntries(data.map(r => [r.cle, r.valeur]));
    if (cfg.heure_ouverture) OPEN_HOUR = parseInt(cfg.heure_ouverture.split(':')[0], 10);
    if (cfg.heure_fermeture) CLOSE_HOUR = parseInt(cfg.heure_fermeture.split(':')[0], 10);
    if (cfg.buffer_minutes) BUFFER_MIN = parseInt(cfg.buffer_minutes, 10);
    TOTAL_ROWS = (CLOSE_HOUR - OPEN_HOUR) * 2;
  }

  async function loadBoxes() {
    const { data } = await supabase.from('boxes').select('id, nom').order('nom');
    boxes = data ?? [];
  }

  async function loadReservationsForRange(start, end) {
    const { data, error } = await supabase
      .from('reservations')
      .select(`
        id, creneau_debut, creneau_fin, duree_minutes,
        client_nom, nb_personnes, statut,
        reservation_boxes ( box_id, boxes ( nom ) )
      `)
      .gte('creneau_debut', start.toISOString())
      .lte('creneau_debut', end.toISOString())
      .order('creneau_debut');
    return { data: data ?? [], error };
  }

  // ── Layout côte-à-côte (anti-overlap) ─────────────────────────────────────
  function layoutBlocs(evts) {
    // Tri par heure de début
    evts.sort((a, b) => a.startMin - b.startMin);

    // Regroupement en clusters chevauchants
    const clusters = [];
    let cur = [], maxEnd = -1;
    for (const ev of evts) {
      if (!cur.length || ev.startMin < maxEnd) {
        cur.push(ev);
        maxEnd = Math.max(maxEnd, ev.endMin);
      } else {
        clusters.push(cur);
        cur = [ev];
        maxEnd = ev.endMin;
      }
    }
    if (cur.length) clusters.push(cur);

    // Assignation des colonnes dans chaque cluster
    clusters.forEach(cluster => {
      const lanes = [];
      cluster.forEach(ev => {
        let lane = lanes.findIndex(end => end <= ev.startMin);
        if (lane === -1) { lane = lanes.length; lanes.push(0); }
        ev.colIdx = lane;
        lanes[lane] = ev.endMin;
      });
      const total = lanes.length;
      cluster.forEach(ev => ev.totalCols = total);
    });
  }

  // ── Rendu Vue Semaine ──────────────────────────────────────────────────────
  async function renderWeek() {
    showLoading();

    const weekEnd = addDays(currentWeekStart, 6);
    const rangeEnd = new Date(weekEnd);
    rangeEnd.setHours(23, 59, 59);

    const { data: reservations, error } = await loadReservationsForRange(currentWeekStart, rangeEnd);
    if (error) { showError('Erreur Supabase : ' + error.message); return; }

    const grid = document.getElementById('week-grid');
    grid.innerHTML = '';

    // Conteneur grille avec position relative pour les lignes de fond
    const wrapper = document.createElement('div');
    wrapper.className = 'relative border border-gray-700 rounded-2xl overflow-hidden';

    // Grille CSS
    const gridEl = document.createElement('div');
    gridEl.style.display = 'grid';
    gridEl.style.gridTemplateColumns = '3rem repeat(7, 1fr)';

    // Ligne d'en-tête
    const headerSpacer = document.createElement('div');
    headerSpacer.className = 'bg-gray-800 border-b border-r border-gray-700 h-10';
    gridEl.appendChild(headerSpacer);

    const today = stripTime(new Date());
    for (let d = 0; d < 7; d++) {
      const day = addDays(currentWeekStart, d);
      const isToday = isSameDay(day, today);
      const dayIdx = d; // 0=lun

      const hCell = document.createElement('div');
      hCell.className = `bg-gray-800 border-b border-gray-700 h-10 flex items-center justify-center text-xs font-medium cursor-pointer transition-colors hover:bg-gray-700 ${d < 6 ? 'border-r' : ''}`;
      hCell.innerHTML = `<span class="${isToday ? 'text-blue-400 font-bold' : 'text-gray-400'}">${DAY_NAMES[dayIdx]} ${day.getDate()}</span>`;
      hCell.dataset.day = day.toISOString();
      hCell.addEventListener('click', () => {
        currentDay = stripTime(new Date(hCell.dataset.day));
        switchView('day');
      });
      gridEl.appendChild(hCell);
    }

    // Lignes horaires
    for (let row = 0; row < TOTAL_ROWS; row++) {
      const hour = OPEN_HOUR + Math.floor(row / 2);
      const min = row % 2 === 0 ? '00' : '30';
      const isHalfHour = row % 2 !== 0;

      // Cellule heure
      const timeCell = document.createElement('div');
      timeCell.className = `bg-gray-800/50 border-r border-gray-700 flex items-start justify-end pr-1 pt-0.5 ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50`;
      timeCell.style.height = ROW_H + 'px';
      if (!isHalfHour) {
        timeCell.innerHTML = `<span class="text-gray-500 text-xs">${hour}h</span>`;
      }
      gridEl.appendChild(timeCell);

      // Cellules jour
      for (let d = 0; d < 7; d++) {
        const dayDate = addDays(currentWeekStart, d);
        const cell = document.createElement('div');
        cell.className = `relative ${d < 6 ? 'border-r' : ''} ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50 ${isHalfHour ? 'border-dashed' : ''}`;
        cell.style.height = ROW_H + 'px';
        cell.dataset.day = d;
        cell.dataset.row = row;
        gridEl.appendChild(cell);
      }
    }

    wrapper.appendChild(gridEl);

    // Overlay absolu : 7 colonnes (une par jour)
    const overlay = document.createElement('div');
    overlay.style.cssText = `
      position: absolute;
      top: 40px;
      left: 3rem;
      right: 0;
      bottom: 0;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      pointer-events: none;
    `;

    const colEls = Array.from({ length: 7 }, (_, i) => {
      const col = document.createElement('div');
      col.style.position = 'relative';
      overlay.appendChild(col);
      return col;
    });

    const openMin = OPEN_HOUR * 60;
    const totalH = TOTAL_ROWS * ROW_H;

    // Grouper par jour et calculer le layout côte-à-côte
    const byDay = {};
    reservations.forEach(res => {
      const debut = new Date(res.creneau_debut);
      const d = Math.round((stripTime(debut) - currentWeekStart) / 86400000);
      if (d < 0 || d > 6) return;
      const startMin = debut.getHours() * 60 + debut.getMinutes();
      if (!byDay[d]) byDay[d] = [];
      byDay[d].push({ res, startMin, endMin: startMin + res.duree_minutes });
    });
    Object.entries(byDay).forEach(([d, evts]) => {
      layoutBlocs(evts);
      evts.forEach(({ res, startMin, colIdx, totalCols }) => {
        const debut = new Date(res.creneau_debut);
        const top = ((startMin - openMin) / 30) * ROW_H;
        const height = Math.max((res.duree_minutes / 30) * ROW_H - 4, ROW_H - 4);
        if (top < 0 || top >= totalH) return;

        const pct = 100 / totalCols;
        const left = `calc(${colIdx * pct}% + 2px)`;
        const width = `calc(${pct}% - 4px)`;

        const bloc = document.createElement('div');
        bloc.style.cssText = `position:absolute;top:${top}px;left:${left};width:${width};height:${height}px;pointer-events:auto;overflow:hidden;`;
        bloc.className = `rounded border px-1.5 py-1 text-xs leading-tight cursor-default ${statusClass(res.statut, res.duree_minutes)}`;
        bloc.title = `${esc(res.client_nom)} · ${res.nb_personnes} pers. · ${res.duree_minutes} min\n${formatTime(debut)} → ${formatTime(new Date(res.creneau_fin))}`;
        bloc.innerHTML = `<span class="font-medium truncate block">${esc(res.client_nom)}</span><span class="opacity-70">👥${res.nb_personnes} · ${res.duree_minutes}min</span>`;
        colEls[Number(d)].appendChild(bloc);

        // Zone buffer
        if (BUFFER_MIN > 0) {
          const bufTop = top + height + 4;
          const bufH = (BUFFER_MIN / 30) * ROW_H - 2;
          const buf = document.createElement('div');
          buf.style.cssText = `position:absolute;top:${bufTop}px;left:${left};width:${width};height:${bufH}px;pointer-events:none;`;
          buf.className = 'rounded-sm border border-dashed border-gray-500/50 bg-gray-700/20';
          buf.title = `Buffer ${BUFFER_MIN} min`;
          colEls[Number(d)].appendChild(buf);
        }
      });
    });

    wrapper.appendChild(overlay);
    grid.appendChild(wrapper);

    showView('week');
    updateDateLabel();
  }

  // ── Rendu Vue Jour ─────────────────────────────────────────────────────────
  async function renderDay() {
    showLoading();

    const dayStart = new Date(currentDay);
    const dayEnd = new Date(currentDay);
    dayEnd.setHours(23, 59, 59);

    const { data: reservations, error } = await loadReservationsForRange(dayStart, dayEnd);
    if (error) { showError('Erreur Supabase : ' + error.message); return; }

    const grid = document.getElementById('day-grid');
    grid.innerHTML = '';

    const colCount = boxes.length || 6;

    const wrapper = document.createElement('div');
    wrapper.className = 'relative border border-gray-700 rounded-2xl overflow-hidden';

    const gridEl = document.createElement('div');
    gridEl.style.display = 'grid';
    gridEl.style.gridTemplateColumns = `3rem repeat(${colCount}, 1fr)`;

    // Ligne d'en-tête
    const headerSpacer = document.createElement('div');
    headerSpacer.className = 'bg-gray-800 border-b border-r border-gray-700 h-10';
    gridEl.appendChild(headerSpacer);

    boxes.forEach((box, i) => {
      const hCell = document.createElement('div');
      hCell.className = `bg-gray-800 border-b border-gray-700 h-10 flex items-center justify-center text-xs font-medium text-gray-300 ${i < colCount - 1 ? 'border-r' : ''}`;
      hCell.textContent = box.nom;
      gridEl.appendChild(hCell);
    });

    // Colonnes pour les blocs (position relative)
    // On va créer une superposition : la grille de fond (lignes) + les colonnes de blocs

    // Lignes horaires (grille de fond uniquement)
    for (let row = 0; row < TOTAL_ROWS; row++) {
      const hour = OPEN_HOUR + Math.floor(row / 2);
      const isHalfHour = row % 2 !== 0;

      const timeCell = document.createElement('div');
      timeCell.className = `bg-gray-800/50 border-r border-gray-700 flex items-start justify-end pr-1 pt-0.5 ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50`;
      timeCell.style.height = ROW_H + 'px';
      if (!isHalfHour) {
        timeCell.innerHTML = `<span class="text-gray-500 text-xs">${hour}h</span>`;
      }
      gridEl.appendChild(timeCell);

      for (let c = 0; c < colCount; c++) {
        const cell = document.createElement('div');
        cell.className = `${c < colCount - 1 ? 'border-r' : ''} ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50 ${isHalfHour ? 'border-dashed' : ''}`;
        cell.style.height = ROW_H + 'px';
        gridEl.appendChild(cell);
      }
    }

    wrapper.appendChild(gridEl);

    // Superposition pour les blocs absolus par colonne
    const overlay = document.createElement('div');
    overlay.style.cssText = `
      position: absolute;
      top: 40px;
      left: 3rem;
      right: 0;
      bottom: 0;
      display: grid;
      grid-template-columns: repeat(${colCount}, 1fr);
      pointer-events: none;
    `;

    // Créer une colonne relative par box
    const colEls = boxes.map((_, i) => {
      const col = document.createElement('div');
      col.style.cssText = `position: relative; ${i < colCount - 1 ? 'border-right: 1px solid transparent;' : ''}`;
      overlay.appendChild(col);
      return col;
    });

    const openMin = OPEN_HOUR * 60;
    const totalH = TOTAL_ROWS * ROW_H;

    reservations.forEach(res => {
      const debut = new Date(res.creneau_debut);
      const debutMin = debut.getHours() * 60 + debut.getMinutes();
      const top = ((debutMin - openMin) / 30) * ROW_H;
      const height = Math.max((res.duree_minutes / 30) * ROW_H - 4, ROW_H - 4);

      if (top < 0 || top >= totalH) return;

      // Boxes concernées par cette réservation
      const resBoxIds = res.reservation_boxes?.map(rb => rb.box_id) ?? [];

      boxes.forEach((box, colIdx) => {
        if (!resBoxIds.includes(box.id)) return;

        const bloc = document.createElement('div');
        bloc.style.cssText = `
          position: absolute;
          top: ${top}px;
          left: 4px;
          right: 4px;
          height: ${height}px;
          pointer-events: auto;
          overflow: hidden;
        `;
        bloc.className = `rounded border px-2 py-1 text-xs leading-tight cursor-default ${statusClass(res.statut, res.duree_minutes)}`;
        bloc.title = `${esc(res.client_nom)} · ${res.nb_personnes} pers. · ${res.duree_minutes} min\n${formatTime(debut)} → ${formatTime(new Date(res.creneau_fin))}`;
        bloc.innerHTML = `
          <div class="font-semibold truncate">${esc(res.client_nom)}</div>
          <div class="opacity-80 mt-0.5">👥 ${res.nb_personnes} · ${res.duree_minutes} min</div>
          <div class="opacity-70">${formatTime(debut)}</div>
        `;
        if (colEls[colIdx]) {
          colEls[colIdx].appendChild(bloc);

          // Zone buffer
          if (BUFFER_MIN > 0) {
            const bufTop = top + height + 4;
            const bufH = (BUFFER_MIN / 30) * ROW_H - 2;
            const buf = document.createElement('div');
            buf.style.cssText = `position:absolute;top:${bufTop}px;left:4px;right:4px;height:${bufH}px;pointer-events:none;`;
            buf.className = 'rounded-sm border border-dashed border-gray-500/50 bg-gray-700/20';
            buf.title = `Buffer ${BUFFER_MIN} min`;
            colEls[colIdx].appendChild(buf);
          }
        }
      });
    });

    wrapper.appendChild(overlay);
    grid.appendChild(wrapper);

    showView('day');
    updateDateLabel();
  }

  // ── UI helpers ─────────────────────────────────────────────────────────────
  function showLoading() {
    document.getElementById('plan-loading').classList.remove('hidden');
    document.getElementById('plan-error').classList.add('hidden');
    document.getElementById('view-week').classList.add('hidden');
    document.getElementById('view-day').classList.add('hidden');
  }

  function showView(view) {
    document.getElementById('plan-loading').classList.add('hidden');
    document.getElementById('plan-error').classList.add('hidden');
    document.getElementById('view-week').classList.toggle('hidden', view !== 'week');
    document.getElementById('view-day').classList.toggle('hidden', view !== 'day');
  }

  function showError(msg) {
    document.getElementById('plan-loading').classList.add('hidden');
    const el = document.getElementById('plan-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  // ── Changement de vue ──────────────────────────────────────────────────────
  function switchView(view) {
    currentView = view;

    const tabWeek = document.getElementById('tab-week');
    const tabDay = document.getElementById('tab-day');

    if (view === 'week') {
      tabWeek.className = 'px-4 py-2 text-sm font-medium transition-colors bg-blue-600 text-white';
      tabDay.className = 'px-4 py-2 text-sm font-medium transition-colors text-gray-400 hover:text-white';
      renderWeek();
    } else {
      tabDay.className = 'px-4 py-2 text-sm font-medium transition-colors bg-blue-600 text-white';
      tabWeek.className = 'px-4 py-2 text-sm font-medium transition-colors text-gray-400 hover:text-white';
      renderDay();
    }
  }

  // ── Event listeners ────────────────────────────────────────────────────────
  document.getElementById('tab-week').addEventListener('click', () => switchView('week'));
  document.getElementById('tab-day').addEventListener('click', () => switchView('day'));

  document.getElementById('btn-today').addEventListener('click', () => {
    if (currentView === 'week') {
      currentWeekStart = getMonday(new Date());
      renderWeek();
    } else {
      currentDay = stripTime(new Date());
      renderDay();
    }
  });

  document.getElementById('btn-prev').addEventListener('click', () => {
    if (currentView === 'week') {
      currentWeekStart = addDays(currentWeekStart, -7);
      renderWeek();
    } else {
      currentDay = addDays(currentDay, -1);
      renderDay();
    }
  });

  document.getElementById('btn-next').addEventListener('click', () => {
    if (currentView === 'week') {
      currentWeekStart = addDays(currentWeekStart, 7);
      renderWeek();
    } else {
      currentDay = addDays(currentDay, 1);
      renderDay();
    }
  });

  // ── Démarrage ──────────────────────────────────────────────────────────────
  await Promise.all([loadConfig(), loadBoxes()]);
  renderWeek();
</script>
