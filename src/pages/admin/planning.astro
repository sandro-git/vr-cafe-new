---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <main class="min-h-screen py-8 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto">

      <!-- En-tête -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-white">Planning</h1>
          <p class="text-gray-400 text-sm mt-0.5">VR Café · Back-office</p>
        </div>
        <a
          href="/admin/reservations"
          class="text-sm text-gray-400 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500"
        >
          ← Réservations
        </a>
      </div>

      <!-- Contrôles -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <!-- Navigation date -->
        <div class="flex items-center gap-2">
          <button
            id="btn-prev"
            class="w-9 h-9 flex items-center justify-center bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-xl border border-gray-600 transition-colors text-lg"
          >‹</button>
          <button
            id="btn-today"
            class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-xl border border-gray-600 transition-colors"
          >Aujourd'hui</button>
          <button
            id="btn-next"
            class="w-9 h-9 flex items-center justify-center bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-xl border border-gray-600 transition-colors text-lg"
          >›</button>
          <span id="date-label" class="text-white font-medium ml-2 text-sm sm:text-base"></span>
        </div>

        <!-- Onglets vue -->
        <div class="flex rounded-xl border border-gray-600 overflow-hidden">
          <button
            id="tab-week"
            class="px-4 py-2 text-sm font-medium transition-colors bg-blue-600 text-white"
          >Vue Semaine</button>
          <button
            id="tab-day"
            class="px-4 py-2 text-sm font-medium transition-colors text-gray-400 hover:text-white"
          >Vue Jour</button>
        </div>
      </div>

      <!-- Loader -->
      <div id="plan-loading" class="py-16 text-center">
        <div class="inline-block w-10 h-10 border-4 border-gray-600 border-t-blue-500 rounded-full animate-spin mb-4"></div>
        <p class="text-gray-400">Chargement...</p>
      </div>

      <!-- Erreur -->
      <div id="plan-error" class="hidden mb-4 p-4 bg-red-900/50 border border-red-700 rounded-xl text-red-300 text-sm"></div>

      <!-- Vue Semaine -->
      <div id="view-week" class="hidden overflow-x-auto">
        <div id="week-grid" class="min-w-[640px]"></div>
      </div>

      <!-- Vue Jour -->
      <div id="view-day" class="hidden overflow-x-auto">
        <div id="day-grid" class="min-w-[640px]"></div>
      </div>

    </div>
  </main>

  <!-- ── Modal réservation ─────────────────────────────────────────────────── -->
  <div id="res-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="res-modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-gray-800 border border-gray-600 rounded-2xl shadow-2xl w-full max-w-sm max-h-[90vh] overflow-y-auto">

      <!-- Vue détail -->
      <div id="modal-detail">
        <div class="p-6">
          <button id="modal-close" class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors text-xl leading-none">✕</button>
          <h3 id="modal-title" class="text-lg font-bold text-white mb-4 pr-8"></h3>
          <div id="modal-body" class="space-y-0 text-sm"></div>
        </div>
        <div class="px-6 pb-6 flex gap-2">
          <button id="modal-btn-edit" type="button" class="flex-1 py-2.5 bg-gray-700 hover:bg-gray-600 text-white border border-gray-600 rounded-xl text-sm font-medium transition-colors">
            Modifier
          </button>
          <button id="modal-btn-cancel" type="button" class="flex-1 py-2.5 bg-red-900/50 hover:bg-red-900/80 text-red-400 hover:text-red-300 border border-red-800 rounded-xl text-sm font-medium transition-colors">
            Annuler
          </button>
        </div>
      </div>

      <!-- Vue édition -->
      <div id="modal-edit" class="hidden p-6">
        <div class="flex items-center gap-3 mb-5">
          <button id="modal-btn-back" type="button" class="text-gray-400 hover:text-white transition-colors text-sm">← Retour</button>
          <h3 class="text-lg font-bold text-white">Modifier</h3>
        </div>
        <form id="modal-edit-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Date</label>
              <input id="edit-date" type="date" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 [color-scheme:dark]" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Heure de début</label>
              <select id="edit-heure" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></select>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Nom complet</label>
            <input id="edit-nom" type="text" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Email</label>
            <input id="edit-email" type="email" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Téléphone</label>
            <input id="edit-telephone" type="tel" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Nombre de joueurs</label>
            <input id="edit-nb" type="number" min="1" max="6" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Notes</label>
            <textarea id="edit-notes" rows="2" class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
          </div>
          <p id="modal-edit-error" class="hidden text-red-400 text-xs"></p>
          <button type="submit" id="modal-btn-save" class="w-full py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-sm font-medium transition-colors">
            Enregistrer
          </button>
        </form>
      </div>

    </div>
  </div>

</AdminLayout>

<script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ── Constantes ────────────────────────────────────────────────────────────
  let OPEN_HOUR = 10;
  let CLOSE_HOUR = 22;
  let BUFFER_MIN = 30;
  const ROW_H = 48; // px par tranche de 30 min
  let TOTAL_ROWS = (CLOSE_HOUR - OPEN_HOUR) * 2;

  const DAY_NAMES = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'];
  const DAY_NAMES_FULL = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche'];
  const MONTH_NAMES = [
    'janvier', 'février', 'mars', 'avril', 'mai', 'juin',
    'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'
  ];

  // ── État ──────────────────────────────────────────────────────────────────
  let currentView = 'week';
  let currentWeekStart = getMonday(new Date());
  let currentDay = stripTime(new Date());
  let boxes = [];
  let modalRes = null; // réservation couramment affichée dans le modal

  // ── Utilitaires date ──────────────────────────────────────────────────────
  function stripTime(d) {
    return new Date(d.getFullYear(), d.getMonth(), d.getDate());
  }

  function getMonday(d) {
    const date = stripTime(d);
    const day = date.getDay();
    const diff = (day === 0 ? -6 : 1 - day);
    date.setDate(date.getDate() + diff);
    return date;
  }

  function addDays(d, n) {
    const r = new Date(d);
    r.setDate(r.getDate() + n);
    return r;
  }

  function isSameDay(a, b) {
    return a.getFullYear() === b.getFullYear()
      && a.getMonth() === b.getMonth()
      && a.getDate() === b.getDate();
  }

  function formatTime(d) {
    return d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
  }

  function localDateStr(d) {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function esc(str) {
    return String(str ?? '—')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  // ── Labels de date ────────────────────────────────────────────────────────
  function updateDateLabel() {
    const el = document.getElementById('date-label');
    if (currentView === 'week') {
      const end = addDays(currentWeekStart, 6);
      const sameMonth = currentWeekStart.getMonth() === end.getMonth();
      if (sameMonth) {
        el.textContent = `${currentWeekStart.getDate()} – ${end.getDate()} ${MONTH_NAMES[end.getMonth()]} ${end.getFullYear()}`;
      } else {
        el.textContent = `${currentWeekStart.getDate()} ${MONTH_NAMES[currentWeekStart.getMonth()]} – ${end.getDate()} ${MONTH_NAMES[end.getMonth()]} ${end.getFullYear()}`;
      }
    } else {
      const dayIdx = (currentDay.getDay() + 6) % 7;
      el.textContent = `${DAY_NAMES_FULL[dayIdx]} ${currentDay.getDate()} ${MONTH_NAMES[currentDay.getMonth()]} ${currentDay.getFullYear()}`;
    }
  }

  // ── Couleurs statut + durée ───────────────────────────────────────────────
  function isSansFil(res) {
    return res.reservation_boxes?.some(rb => rb.boxes?.type === 'sans_fil') ?? false;
  }

  function statusClass(res) {
    if (isSansFil(res)) return 'bg-emerald-700/60 border-emerald-500 text-emerald-100';
    return res.duree_minutes <= 30
      ? 'bg-violet-700/60 border-violet-500 text-violet-100'
      : 'bg-blue-700/60 border-blue-500 text-blue-100';
  }

  // ── Chargement données ─────────────────────────────────────────────────────
  async function loadConfig() {
    const { data, error } = await supabase.from('config').select('cle, valeur');
    if (error || !data?.length) return;
    const cfg = Object.fromEntries(data.map(r => [r.cle, r.valeur]));
    if (cfg.heure_ouverture) OPEN_HOUR = parseInt(cfg.heure_ouverture.split(':')[0], 10);
    if (cfg.heure_fermeture) CLOSE_HOUR = parseInt(cfg.heure_fermeture.split(':')[0], 10);
    if (cfg.buffer_minutes) BUFFER_MIN = parseInt(cfg.buffer_minutes, 10);
    TOTAL_ROWS = (CLOSE_HOUR - OPEN_HOUR) * 2;
  }

  async function loadBoxes() {
    const { data } = await supabase.from('boxes').select('id, nom, type').order('nom');
    boxes = data ?? [];
  }

  async function loadReservationsForRange(start, end) {
    const { data, error } = await supabase
      .from('reservations')
      .select(`
        id, creneau_debut, creneau_fin, duree_minutes,
        client_nom, client_email, client_telephone, nb_personnes, statut, notes,
        reservation_boxes ( box_id, boxes ( nom, type ) )
      `)
      .gte('creneau_debut', start.toISOString())
      .lte('creneau_debut', end.toISOString())
      .not('statut', 'in', '("annulée","no_show")')
      .order('creneau_debut');
    return { data: data ?? [], error };
  }

  // ── Layout côte-à-côte (anti-overlap) ─────────────────────────────────────
  function layoutBlocs(evts) {
    evts.sort((a, b) => a.startMin - b.startMin);
    const clusters = [];
    let cur = [], maxEnd = -1;
    for (const ev of evts) {
      if (!cur.length || ev.startMin < maxEnd) {
        cur.push(ev);
        maxEnd = Math.max(maxEnd, ev.endMin);
      } else {
        clusters.push(cur);
        cur = [ev];
        maxEnd = ev.endMin;
      }
    }
    if (cur.length) clusters.push(cur);
    clusters.forEach(cluster => {
      const lanes = [];
      cluster.forEach(ev => {
        let lane = lanes.findIndex(end => end <= ev.startMin);
        if (lane === -1) { lane = lanes.length; lanes.push(0); }
        ev.colIdx = lane;
        lanes[lane] = ev.endMin;
      });
      const total = lanes.length;
      cluster.forEach(ev => ev.totalCols = total);
    });
  }

  // ── Rendu Vue Semaine ──────────────────────────────────────────────────────
  async function renderWeek() {
    showLoading();

    const weekEnd = addDays(currentWeekStart, 6);
    const rangeEnd = new Date(weekEnd);
    rangeEnd.setHours(23, 59, 59);

    const { data: reservations, error } = await loadReservationsForRange(currentWeekStart, rangeEnd);
    if (error) { showError('Erreur Supabase : ' + error.message); return; }

    const grid = document.getElementById('week-grid');
    grid.innerHTML = '';

    const wrapper = document.createElement('div');
    wrapper.className = 'relative border border-gray-700 rounded-2xl overflow-hidden';

    const gridEl = document.createElement('div');
    gridEl.style.display = 'grid';
    gridEl.style.gridTemplateColumns = '3rem repeat(7, minmax(90px, 1fr))';

    const headerSpacer = document.createElement('div');
    headerSpacer.className = 'bg-gray-800 border-b border-r border-gray-700 h-10';
    gridEl.appendChild(headerSpacer);

    const today = stripTime(new Date());
    for (let d = 0; d < 7; d++) {
      const day = addDays(currentWeekStart, d);
      const isToday = isSameDay(day, today);
      const hCell = document.createElement('div');
      hCell.className = `bg-gray-800 border-b border-gray-700 h-10 flex items-center justify-center text-xs font-medium cursor-pointer transition-colors hover:bg-gray-700 ${d < 6 ? 'border-r' : ''}`;
      hCell.innerHTML = `<span class="${isToday ? 'text-blue-400 font-bold' : 'text-gray-400'}">${DAY_NAMES[d]} ${day.getDate()}</span>`;
      hCell.dataset.day = day.toISOString();
      hCell.addEventListener('click', () => {
        currentDay = stripTime(new Date(hCell.dataset.day));
        switchView('day');
      });
      gridEl.appendChild(hCell);
    }

    for (let row = 0; row < TOTAL_ROWS; row++) {
      const hour = OPEN_HOUR + Math.floor(row / 2);
      const isHalfHour = row % 2 !== 0;
      const timeCell = document.createElement('div');
      timeCell.className = `bg-gray-800/50 border-r border-gray-700 flex items-start justify-end pr-1 pt-0.5 ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50`;
      timeCell.style.height = ROW_H + 'px';
      if (!isHalfHour) timeCell.innerHTML = `<span class="text-gray-500 text-xs">${hour}h</span>`;
      gridEl.appendChild(timeCell);
      for (let d = 0; d < 7; d++) {
        const cell = document.createElement('div');
        cell.className = `relative ${d < 6 ? 'border-r' : ''} ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50 ${isHalfHour ? 'border-dashed' : ''}`;
        cell.style.height = ROW_H + 'px';
        gridEl.appendChild(cell);
      }
    }

    wrapper.appendChild(gridEl);

    const overlay = document.createElement('div');
    overlay.style.cssText = `position:absolute;top:40px;left:3rem;right:0;bottom:0;display:grid;grid-template-columns:repeat(7,minmax(90px,1fr));pointer-events:none;`;

    const colEls = Array.from({ length: 7 }, () => {
      const col = document.createElement('div');
      col.style.position = 'relative';
      overlay.appendChild(col);
      return col;
    });

    const openMin = OPEN_HOUR * 60;
    const totalH = TOTAL_ROWS * ROW_H;

    const byDay = {};
    reservations.forEach(res => {
      const debut = new Date(res.creneau_debut);
      const d = Math.round((stripTime(debut) - currentWeekStart) / 86400000);
      if (d < 0 || d > 6) return;
      const startMin = debut.getHours() * 60 + debut.getMinutes();
      if (!byDay[d]) byDay[d] = [];
      byDay[d].push({ res, startMin, endMin: startMin + res.duree_minutes });
    });

    Object.entries(byDay).forEach(([d, evts]) => {
      layoutBlocs(evts);
      evts.forEach(({ res, startMin, colIdx, totalCols }) => {
        const debut = new Date(res.creneau_debut);
        const top = ((startMin - openMin) / 30) * ROW_H;
        const height = Math.max((res.duree_minutes / 30) * ROW_H - 4, ROW_H - 4);
        if (top < 0 || top >= totalH) return;
        const pct = 100 / totalCols;
        const left = `calc(${colIdx * pct}% + 2px)`;
        const width = `calc(${pct}% - 4px)`;
        const bloc = document.createElement('div');
        bloc.style.cssText = `position:absolute;top:${top}px;left:${left};width:${width};height:${height}px;pointer-events:auto;overflow:hidden;`;
        bloc.className = `rounded border px-1.5 py-1 text-xs leading-tight cursor-pointer ${statusClass(res)}`;
        bloc.innerHTML = `<span class="font-medium truncate block">${esc(res.client_nom)}</span><span class="opacity-70">👥${res.nb_personnes} · ${res.duree_minutes}min</span>`;
        bloc.addEventListener('click', () => openModal(res));
        colEls[Number(d)].appendChild(bloc);
        if (BUFFER_MIN > 0) {
          const buf = document.createElement('div');
          buf.style.cssText = `position:absolute;top:${top + height + 4}px;left:${left};width:${width};height:${(BUFFER_MIN / 30) * ROW_H - 2}px;pointer-events:none;`;
          buf.className = 'rounded-sm border border-dashed border-gray-500/50 bg-gray-700/20';
          colEls[Number(d)].appendChild(buf);
        }
      });
    });

    wrapper.appendChild(overlay);
    grid.appendChild(wrapper);
    showView('week');
    updateDateLabel();
  }

  // ── Rendu Vue Jour ─────────────────────────────────────────────────────────
  async function renderDay() {
    showLoading();

    const dayStart = new Date(currentDay);
    const dayEnd = new Date(currentDay);
    dayEnd.setHours(23, 59, 59);

    const { data: reservations, error } = await loadReservationsForRange(dayStart, dayEnd);
    if (error) { showError('Erreur Supabase : ' + error.message); return; }

    const grid = document.getElementById('day-grid');
    grid.innerHTML = '';

    const colCount = boxes.length || 6;

    const wrapper = document.createElement('div');
    wrapper.className = 'relative border border-gray-700 rounded-2xl overflow-hidden';

    const gridEl = document.createElement('div');
    gridEl.style.display = 'grid';
    gridEl.style.gridTemplateColumns = `3rem repeat(${colCount}, 1fr)`;

    const headerSpacer = document.createElement('div');
    headerSpacer.className = 'bg-gray-800 border-b border-r border-gray-700 h-10';
    gridEl.appendChild(headerSpacer);

    boxes.forEach((box, i) => {
      const hCell = document.createElement('div');
      hCell.className = `bg-gray-800 border-b border-gray-700 h-10 flex items-center justify-center text-xs font-medium text-gray-300 ${i < colCount - 1 ? 'border-r' : ''}`;
      hCell.textContent = (box.type === 'sans_fil' ? '📡 ' : '') + box.nom;
      gridEl.appendChild(hCell);
    });

    for (let row = 0; row < TOTAL_ROWS; row++) {
      const hour = OPEN_HOUR + Math.floor(row / 2);
      const isHalfHour = row % 2 !== 0;
      const timeCell = document.createElement('div');
      timeCell.className = `bg-gray-800/50 border-r border-gray-700 flex items-start justify-end pr-1 pt-0.5 ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50`;
      timeCell.style.height = ROW_H + 'px';
      if (!isHalfHour) timeCell.innerHTML = `<span class="text-gray-500 text-xs">${hour}h</span>`;
      gridEl.appendChild(timeCell);
      for (let c = 0; c < colCount; c++) {
        const cell = document.createElement('div');
        cell.className = `${c < colCount - 1 ? 'border-r' : ''} ${row < TOTAL_ROWS - 1 ? 'border-b' : ''} border-gray-700/50 ${isHalfHour ? 'border-dashed' : ''}`;
        cell.style.height = ROW_H + 'px';
        gridEl.appendChild(cell);
      }
    }

    wrapper.appendChild(gridEl);

    const overlay = document.createElement('div');
    overlay.style.cssText = `position:absolute;top:40px;left:3rem;right:0;bottom:0;display:grid;grid-template-columns:repeat(${colCount},1fr);pointer-events:none;`;

    const colEls = boxes.map((_, i) => {
      const col = document.createElement('div');
      col.style.cssText = `position:relative;${i < colCount - 1 ? 'border-right:1px solid transparent;' : ''}`;
      overlay.appendChild(col);
      return col;
    });

    const openMin = OPEN_HOUR * 60;
    const totalH = TOTAL_ROWS * ROW_H;

    reservations.forEach(res => {
      const debut = new Date(res.creneau_debut);
      const debutMin = debut.getHours() * 60 + debut.getMinutes();
      const top = ((debutMin - openMin) / 30) * ROW_H;
      const height = Math.max((res.duree_minutes / 30) * ROW_H - 4, ROW_H - 4);
      if (top < 0 || top >= totalH) return;
      const resBoxIds = res.reservation_boxes?.map(rb => rb.box_id) ?? [];
      boxes.forEach((box, colIdx) => {
        if (!resBoxIds.includes(box.id)) return;
        const bloc = document.createElement('div');
        bloc.style.cssText = `position:absolute;top:${top}px;left:4px;right:4px;height:${height}px;pointer-events:auto;overflow:hidden;`;
        bloc.className = `rounded border px-2 py-1 text-xs leading-tight cursor-pointer ${statusClass(res)}`;
        bloc.innerHTML = `
          <div class="font-semibold truncate">${esc(res.client_nom)}</div>
          <div class="opacity-80 mt-0.5">👥 ${res.nb_personnes} · ${res.duree_minutes} min</div>
          <div class="opacity-70">${formatTime(debut)}</div>
        `;
        bloc.addEventListener('click', () => openModal(res));
        if (colEls[colIdx]) {
          colEls[colIdx].appendChild(bloc);
          if (BUFFER_MIN > 0) {
            const buf = document.createElement('div');
            buf.style.cssText = `position:absolute;top:${top + height + 4}px;left:4px;right:4px;height:${(BUFFER_MIN / 30) * ROW_H - 2}px;pointer-events:none;`;
            buf.className = 'rounded-sm border border-dashed border-gray-500/50 bg-gray-700/20';
            colEls[colIdx].appendChild(buf);
          }
        }
      });
    });

    wrapper.appendChild(overlay);
    grid.appendChild(wrapper);
    showView('day');
    updateDateLabel();
  }

  // ── UI helpers ─────────────────────────────────────────────────────────────
  function showLoading() {
    document.getElementById('plan-loading').classList.remove('hidden');
    document.getElementById('plan-error').classList.add('hidden');
    document.getElementById('view-week').classList.add('hidden');
    document.getElementById('view-day').classList.add('hidden');
  }

  function showView(view) {
    document.getElementById('plan-loading').classList.add('hidden');
    document.getElementById('plan-error').classList.add('hidden');
    document.getElementById('view-week').classList.toggle('hidden', view !== 'week');
    document.getElementById('view-day').classList.toggle('hidden', view !== 'day');
  }

  function showError(msg) {
    document.getElementById('plan-loading').classList.add('hidden');
    const el = document.getElementById('plan-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  // ── Changement de vue ──────────────────────────────────────────────────────
  function switchView(view) {
    currentView = view;
    const tabWeek = document.getElementById('tab-week');
    const tabDay = document.getElementById('tab-day');
    if (view === 'week') {
      tabWeek.className = 'px-4 py-2 text-sm font-medium transition-colors bg-blue-600 text-white';
      tabDay.className = 'px-4 py-2 text-sm font-medium transition-colors text-gray-400 hover:text-white';
      renderWeek();
    } else {
      tabDay.className = 'px-4 py-2 text-sm font-medium transition-colors bg-blue-600 text-white';
      tabWeek.className = 'px-4 py-2 text-sm font-medium transition-colors text-gray-400 hover:text-white';
      renderDay();
    }
  }

  // ── Validation ────────────────────────────────────────────────────────────
  function isValidEmail(v) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim());
  }
  function isValidPhone(v) {
    return /^(?:(?:\+|00)33|0)[1-9](?:[\s.-]?\d{2}){4}$/.test(v.trim());
  }

  // ── Modal ──────────────────────────────────────────────────────────────────
  function openModal(res) {
    modalRes = res;
    const debut = new Date(res.creneau_debut);
    const fin = new Date(res.creneau_fin);
    const dateFmt = debut.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    const boxNames = res.reservation_boxes?.map(rb => {
      const prefix = rb.boxes?.type === 'sans_fil' ? '📡 ' : '🔌 ';
      return prefix + (rb.boxes?.nom ?? `Box ${rb.box_id}`);
    }).join(', ') ?? '—';

    document.getElementById('modal-title').textContent = res.client_nom ?? '—';
    document.getElementById('modal-body').innerHTML = `
      <div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Date</span><span class="text-white text-right">${dateFmt}</span></div>
      <div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Horaire</span><span class="text-white">${formatTime(debut)} → ${formatTime(fin)}</span></div>
      <div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Durée</span><span class="text-white">${res.duree_minutes} min</span></div>
      <div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Joueurs</span><span class="text-white">${res.nb_personnes}</span></div>
      <div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Boxes</span><span class="text-white">${esc(boxNames)}</span></div>
      ${res.client_email ? `<div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Email</span><a href="mailto:${esc(res.client_email)}" class="text-blue-400 hover:text-blue-300 truncate ml-4">${esc(res.client_email)}</a></div>` : ''}
      ${res.client_telephone ? `<div class="flex justify-between py-2 border-b border-gray-700"><span class="text-gray-400">Téléphone</span><a href="tel:${esc(res.client_telephone)}" class="text-blue-400 hover:text-blue-300">${esc(res.client_telephone)}</a></div>` : ''}
      ${res.notes ? `<div class="py-2"><span class="text-gray-400 block mb-1">Notes</span><span class="text-gray-300">${esc(res.notes)}</span></div>` : ''}
    `;

    // Pré-remplir le formulaire d'édition
    document.getElementById('edit-date').value = localDateStr(debut);
    populateHeures(debut);
    document.getElementById('edit-nom').value = res.client_nom ?? '';
    document.getElementById('edit-email').value = res.client_email ?? '';
    document.getElementById('edit-telephone').value = res.client_telephone ?? '';
    document.getElementById('edit-nb').value = String(res.nb_personnes ?? '');
    document.getElementById('edit-notes').value = res.notes ?? '';
    document.getElementById('modal-edit-error').classList.add('hidden');

    // Afficher vue détail
    document.getElementById('modal-detail').classList.remove('hidden');
    document.getElementById('modal-edit').classList.add('hidden');
    document.getElementById('res-modal').classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('res-modal').classList.add('hidden');
    modalRes = null;
  }

  function populateHeures(selectedDate) {
    const sel = document.getElementById('edit-heure');
    sel.innerHTML = '';
    const selectedMin = selectedDate.getHours() * 60 + selectedDate.getMinutes();
    for (let m = OPEN_HOUR * 60; m < CLOSE_HOUR * 60; m += 30) {
      const h = String(Math.floor(m / 60)).padStart(2, '0');
      const min = m % 60 === 0 ? '00' : '30';
      const opt = document.createElement('option');
      opt.value = `${h}:${min}`;
      opt.textContent = `${h}:${min}`;
      if (m === selectedMin) opt.selected = true;
      sel.appendChild(opt);
    }
  }

  // Fermeture modal
  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('res-modal-backdrop').addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // Bouton Modifier → vue édition
  document.getElementById('modal-btn-edit').addEventListener('click', () => {
    document.getElementById('modal-detail').classList.add('hidden');
    document.getElementById('modal-edit').classList.remove('hidden');
  });

  // Bouton Retour → vue détail
  document.getElementById('modal-btn-back').addEventListener('click', () => {
    document.getElementById('modal-edit').classList.add('hidden');
    document.getElementById('modal-detail').classList.remove('hidden');
  });

  // Bouton Annuler la réservation
  document.getElementById('modal-btn-cancel').addEventListener('click', async () => {
    if (!modalRes) return;
    if (!confirm('Confirmer l\'annulation de cette réservation ?')) return;
    const btn = document.getElementById('modal-btn-cancel');
    btn.disabled = true;
    btn.textContent = '...';
    const { error } = await supabase.from('reservations').update({ statut: 'annulée' }).eq('id', modalRes.id);
    btn.disabled = false;
    btn.textContent = 'Annuler';
    if (error) {
      document.getElementById('plan-error').textContent = 'Erreur : ' + error.message;
      document.getElementById('plan-error').classList.remove('hidden');
    } else {
      fetch('/api/reservation-annulation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          client_nom: modalRes.client_nom,
          client_email: modalRes.client_email,
          client_telephone: modalRes.client_telephone,
          nb_personnes: modalRes.nb_personnes,
          duree_minutes: modalRes.duree_minutes,
          vr_type: modalRes.reservation_boxes?.[0]?.boxes?.type ?? 'filaire',
          creneau_debut: modalRes.creneau_debut,
          creneau_fin: modalRes.creneau_fin,
          box_names: modalRes.reservation_boxes.map(b => b.boxes.nom).join(', '),
          ref: modalRes.id.split('-')[0].toUpperCase(),
          notes: modalRes.notes ?? null,
        }),
      }).catch(err => console.error('Email annulation failed:', err));
      closeModal();
      currentView === 'week' ? renderWeek() : renderDay();
    }
  });

  // Formulaire d'édition
  document.getElementById('modal-edit-form').addEventListener('submit', async e => {
    e.preventDefault();
    if (!modalRes) return;
    const btn = document.getElementById('modal-btn-save');
    btn.disabled = true;
    btn.textContent = 'Enregistrement...';

    const dateVal = document.getElementById('edit-date').value;
    const heureVal = document.getElementById('edit-heure').value;
    const newDebut = new Date(`${dateVal}T${heureVal}:00`);
    const newFin = new Date(newDebut.getTime() + modalRes.duree_minutes * 60000);
    const newFinBlocage = new Date(newFin.getTime() + BUFFER_MIN * 60000);

    const emailVal = document.getElementById('edit-email').value.trim();
    const telVal = document.getElementById('edit-telephone').value.trim();
    if (emailVal && !isValidEmail(emailVal)) {
      const errEl = document.getElementById('modal-edit-error');
      errEl.textContent = 'Adresse email invalide.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Enregistrer';
      return;
    }
    if (telVal && !isValidPhone(telVal)) {
      const errEl = document.getElementById('modal-edit-error');
      errEl.textContent = 'Numéro de téléphone invalide (format français attendu).';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Enregistrer';
      return;
    }
    const { error } = await supabase.from('reservations').update({
      client_nom: document.getElementById('edit-nom').value.trim(),
      client_email: document.getElementById('edit-email').value.trim(),
      client_telephone: document.getElementById('edit-telephone').value.trim(),
      nb_personnes: parseInt(document.getElementById('edit-nb').value),
      notes: document.getElementById('edit-notes').value.trim() || null,
      creneau_debut: newDebut.toISOString(),
      creneau_fin: newFin.toISOString(),
      creneau_fin_blocage: newFinBlocage.toISOString(),
    }).eq('id', modalRes.id);

    btn.disabled = false;
    btn.textContent = 'Enregistrer';

    if (error) {
      const errEl = document.getElementById('modal-edit-error');
      errEl.textContent = 'Erreur : ' + error.message;
      errEl.classList.remove('hidden');
    } else {
      closeModal();
      currentView === 'week' ? renderWeek() : renderDay();
    }
  });

  // ── Event listeners navigation ─────────────────────────────────────────────
  document.getElementById('tab-week').addEventListener('click', () => switchView('week'));
  document.getElementById('tab-day').addEventListener('click', () => switchView('day'));

  document.getElementById('btn-today').addEventListener('click', () => {
    if (currentView === 'week') { currentWeekStart = getMonday(new Date()); renderWeek(); }
    else { currentDay = stripTime(new Date()); renderDay(); }
  });

  document.getElementById('btn-prev').addEventListener('click', () => {
    if (currentView === 'week') { currentWeekStart = addDays(currentWeekStart, -7); renderWeek(); }
    else { currentDay = addDays(currentDay, -1); renderDay(); }
  });

  document.getElementById('btn-next').addEventListener('click', () => {
    if (currentView === 'week') { currentWeekStart = addDays(currentWeekStart, 7); renderWeek(); }
    else { currentDay = addDays(currentDay, 1); renderDay(); }
  });

  // ── Démarrage ──────────────────────────────────────────────────────────────
  await Promise.all([loadConfig(), loadBoxes()]);
  renderWeek();
</script>
