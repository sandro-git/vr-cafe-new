---
import AdminLayout from "../../layouts/AdminLayout.astro";
import DatePicker from "../../components/DatePicker.astro";
---

<AdminLayout>
  <main class="min-h-screen py-8 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">

      <!-- En-tête -->
      <div class="flex flex-col gap-4 mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div>
            <h1 class="font-display text-2xl font-extrabold tracking-tight text-white">Réservations</h1>
            <p class="text-white/55 text-sm mt-0.5">VR Café · Back-office</p>
          </div>
          <!-- Date : navigation jour + datepicker -->
          <div class="flex items-center gap-2 sm:order-last flex-wrap">
            <button
              id="btn-prev"
              type="button"
              aria-label="Jour précédent"
              class="w-9 h-9 flex items-center justify-center bg-white/5 hover:bg-white/10 text-white/70 rounded-xl border border-white/10 transition-colors text-lg"
            >‹</button>
            <button
              id="btn-today"
              type="button"
              class="px-4 py-2 bg-white/5 hover:bg-white/10 text-white/70 text-sm rounded-xl border border-white/10 transition-colors"
            >Aujourd'hui</button>
            <button
              id="btn-next"
              type="button"
              aria-label="Jour suivant"
              class="w-9 h-9 flex items-center justify-center bg-white/5 hover:bg-white/10 text-white/70 rounded-xl border border-white/10 transition-colors text-lg"
            >›</button>
            <div class="ml-1 w-60">
              <DatePicker id="dp-reservations" />
            </div>
          </div>
        </div>
        <!-- Boutons : grille 2 colonnes sur mobile, inline sur desktop -->
        <div class="grid grid-cols-2 sm:flex sm:justify-end gap-3">
          <button
            id="btn-block-reservations"
            class="flex items-center justify-center px-4 py-2.5 text-sm rounded-xl transition-colors border col-span-2 sm:col-span-1 bg-white/5 border-white/10 text-white/70 hover:bg-white/10"
          >
            <span id="btn-block-label">⏳ Chargement…</span>
          </button>
          <a
            href="/admin/planning"
            class="flex items-center justify-center px-4 py-2.5 bg-white/5 hover:bg-white/10 text-white/70 text-sm rounded-xl transition-colors border border-white/10"
          >
            📅 Planning
          </a>
          <a
            href="/admin/clients"
            class="flex items-center justify-center px-4 py-2.5 bg-white/5 hover:bg-white/10 text-white/70 text-sm rounded-xl transition-colors border border-white/10"
          >
            👤 Clients
          </a>
        </div>
      </div>

      <!-- Statistiques du jour -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
        <div class="bg-[var(--color-surface-card)] border border-white/10 rounded-xl p-4">
          <p class="text-white/55 text-xs mb-1 uppercase tracking-wide">Total</p>
          <p id="stat-total" class="text-2xl font-bold text-white">—</p>
        </div>
        <div class="bg-[var(--color-surface-card)] border border-white/10 rounded-xl p-4">
          <p class="text-white/55 text-xs mb-1 uppercase tracking-wide">Confirmées</p>
          <p id="stat-confirmed" class="text-2xl font-bold text-green-300">—</p>
        </div>
        <div class="bg-[var(--color-surface-card)] border border-white/10 rounded-xl p-4">
          <p class="text-white/55 text-xs mb-1 uppercase tracking-wide">Annulées</p>
          <p id="stat-cancelled" class="text-2xl font-bold text-red-300">—</p>
        </div>
        <div class="bg-[var(--color-surface-card)] border border-white/10 rounded-xl p-4">
          <p class="text-white/55 text-xs mb-1 uppercase tracking-wide">Joueurs</p>
          <p id="stat-players" class="text-2xl font-bold text-[var(--color-brand-300)]">—</p>
        </div>
        <div class="bg-[var(--color-surface-card)] border border-white/10 rounded-xl p-4 col-span-2 sm:col-span-1">
          <p class="text-white/55 text-xs mb-1 uppercase tracking-wide">CA théorique</p>
          <p id="stat-revenue" class="text-2xl font-bold text-[var(--color-accent-400)]">—</p>
        </div>
      </div>

      <!-- Erreur -->
      <div id="admin-error" class="hidden mb-4 p-4 bg-red-500/10 border border-red-500/30 rounded-xl text-red-300 text-sm"></div>

      <!-- Chargement -->
      <div id="admin-loading" class="py-16 text-center">
        <div class="inline-block w-10 h-10 border-4 border-white/20 border-t-[var(--color-brand-400)] rounded-full animate-spin mb-4"></div>
        <p class="text-white/55">Chargement...</p>
      </div>

      <!-- Vide -->
      <div id="admin-empty" class="hidden py-16 text-center">
        <p class="text-4xl mb-3">📅</p>
        <p class="text-white font-medium">Aucune réservation ce jour</p>
        <p class="text-white/55 text-sm mt-1">Profitez-en pour vous reposer !</p>
      </div>

      <!-- Tableau -->
      <div id="admin-table-wrap" class="hidden">

        <!-- Vue mobile/tablette : cartes -->
        <div id="admin-cards" class="lg:hidden space-y-3"></div>

        <!-- Vue desktop : tableau -->
        <div class="hidden lg:block overflow-x-auto rounded-2xl border border-white/10">
          <table class="w-full text-sm">
            <thead class="bg-white/5">
              <tr class="text-left text-white/55 text-xs uppercase tracking-wide">
                <th class="px-5 py-3 font-medium">Horaire</th>
                <th class="px-5 py-3 font-medium">Client</th>
                <th class="px-5 py-3 font-medium">Contact</th>
                <th class="px-5 py-3 font-medium">Session</th>
                <th class="px-5 py-3 font-medium">Boxes</th>
                <th class="px-5 py-3 font-medium">Statut</th>
                <th class="px-5 py-3 font-medium">Actions</th>
              </tr>
            </thead>
            <tbody id="reservations-body" class="divide-y divide-white/5"></tbody>
          </table>
        </div>

      </div>

    </div>
  </main>
</AdminLayout>

<script>
  // @ts-nocheck
  import { supabase } from '../../lib/supabase.js';
  import { calcMontant } from '../../lib/pricing';

  let currentDate = localDateStr(new Date());
  let reservationsCache = [];

  // ── Chargement ────────────────────────────────────────────────────────────
  async function loadReservations(dateStr) {
    showState('loading');
    hideError();

    const start = new Date(dateStr + 'T00:00:00');
    const end = new Date(dateStr + 'T23:59:59');

    const { data, error } = await supabase
      .from('reservations')
      .select(`
        *, type_reservation,
        reservation_boxes (
          box_id,
          boxes ( nom, type )
        )
      `)
      .gte('creneau_debut', start.toISOString())
      .lte('creneau_debut', end.toISOString())
      .order('creneau_debut');

    if (error) {
      showState('error');
      showError('Erreur Supabase : ' + error.message);
      updateStats([]);
      return;
    }

    reservationsCache = data ?? [];
    updateStats(reservationsCache);

    if (!reservationsCache.length) {
      showState('empty');
      return;
    }

    renderTable(reservationsCache);
    renderCards(reservationsCache);
    showState('table');
  }

  // ── Stats ─────────────────────────────────────────────────────────────────
  function updateStats(reservations) {
    const confirmed = reservations.filter(r => r.statut === 'confirmée');
    const cancelled = reservations.filter(r => r.statut === 'annulée');
    const players = confirmed.reduce((sum, r) => sum + (r.nb_personnes || 0), 0);
    const revenue = confirmed.reduce((sum, r) => sum + (calcMontant(r.duree_minutes, r.nb_personnes || 0) ?? 0), 0);

    document.getElementById('stat-total').textContent = String(reservations.length);
    document.getElementById('stat-confirmed').textContent = String(confirmed.length);
    document.getElementById('stat-cancelled').textContent = String(cancelled.length);
    document.getElementById('stat-players').textContent = String(players);
    document.getElementById('stat-revenue').textContent = `${revenue} €`;
  }

  // ── Tableau desktop ────────────────────────────────────────────────────────
  function renderTable(reservations) {
    const tbody = document.getElementById('reservations-body');
    tbody.innerHTML = '';

    reservations.forEach(res => {
      const { h1, h2, boxNames, badge } = resDisplay(res);

      const tr = document.createElement('tr');
      tr.className = `text-white/70 transition-colors ${res.type_reservation === 'anniversaire' ? 'bg-pink-500/5 hover:bg-pink-500/10' : res.type_reservation === 'mdj' ? 'bg-violet-500/5 hover:bg-violet-500/10' : 'hover:bg-white/5'}`;
      tr.dataset.id = res.id;
      tr.innerHTML = `
        <td class="px-5 py-4">
          <span class="font-semibold text-white">${h1}</span>
          <span class="text-white/40"> → ${h2}</span>
        </td>
        <td class="px-5 py-4">
          <p class="font-medium text-white">
            ${res.type_reservation === 'anniversaire' ? '<span class="inline-block mr-1 px-1.5 py-0.5 rounded text-xs font-semibold bg-pink-500/15 text-pink-300 border border-pink-500/30">🎂 Anniv.</span>' : res.type_reservation === 'mdj' ? '<span class="inline-block mr-1 px-1.5 py-0.5 rounded text-xs font-semibold bg-violet-500/15 text-violet-300 border border-violet-500/30">🏠 MDJ</span>' : ''}${esc(res.client_nom)}
          </p>
          ${res.notes ? `<p class="text-white/40 text-xs mt-0.5 max-w-xs truncate">${esc(res.notes)}</p>` : ''}
        </td>
        <td class="px-5 py-4">
          <p>${esc(res.client_email)}</p>
          <p class="text-white/40 text-xs mt-0.5">${esc(res.client_telephone)}</p>
        </td>
        <td class="px-5 py-4">
          <p>${res.duree_minutes} min</p>
          <p class="text-white/40 text-xs mt-0.5">${res.nb_personnes} joueur${res.nb_personnes > 1 ? 's' : ''}</p>
        </td>
        <td class="px-5 py-4 text-white/55 text-xs">${esc(boxNames)}</td>
        <td class="px-5 py-4">
          <span class="px-2 py-1 rounded-lg border text-xs font-medium ${badge}">${res.statut}</span>
        </td>
        <td class="px-5 py-4">
          ${res.statut === 'confirmée'
            ? `<button class="btn-cancel text-xs text-red-300 hover:text-red-200 transition-colors" data-id="${res.id}">Annuler</button>`
            : res.statut === 'annulée'
              ? `<button class="btn-noshow text-xs text-white/40 hover:text-yellow-300 transition-colors" data-id="${res.id}">No-show</button>`
              : ''
          }
        </td>
      `;
      tbody.appendChild(tr);
    });
  }

  // ── Cartes mobile/tablette ─────────────────────────────────────────────────
  function renderCards(reservations) {
    const container = document.getElementById('admin-cards');
    container.innerHTML = '';

    reservations.forEach(res => {
      const { h1, h2, boxNames, badge } = resDisplay(res);

      const card = document.createElement('div');
      card.className = `rounded-2xl p-5 border ${res.type_reservation === 'anniversaire' ? 'bg-pink-500/10 border-pink-500/30' : res.type_reservation === 'mdj' ? 'bg-violet-500/10 border-violet-500/30' : 'bg-[var(--color-surface-card)] border-white/10'}`;
      card.dataset.id = res.id;
      card.innerHTML = `
        <div class="flex items-start justify-between mb-3">
          <div>
            <span class="text-white font-bold text-lg">${h1}</span>
            <span class="text-white/55"> → ${h2}</span>
          </div>
          <span class="px-2 py-1 rounded-lg border text-xs font-medium ${badge}">${res.statut}</span>
        </div>
        ${res.type_reservation === 'anniversaire' ? '<span class="inline-block mb-2 px-2 py-0.5 rounded text-xs font-semibold bg-pink-500/15 text-pink-300 border border-pink-500/30">🎂 Anniversaire</span>' : res.type_reservation === 'mdj' ? '<span class="inline-block mb-2 px-2 py-0.5 rounded text-xs font-semibold bg-violet-500/15 text-violet-300 border border-violet-500/30">🏠 MDJ</span>' : ''}
        <p class="font-medium text-white mb-1">${esc(res.client_nom)}</p>
        <p class="text-white/55 text-sm">${esc(res.client_email)}</p>
        <p class="text-white/55 text-sm">${esc(res.client_telephone)}</p>
        <div class="flex items-center justify-between mt-3 pt-3 border-t border-white/10">
          <div class="text-xs text-white/40">
            ${res.duree_minutes} min · ${res.nb_personnes} joueur${res.nb_personnes > 1 ? 's' : ''} · ${esc(boxNames)}
          </div>
          <div class="flex gap-3">
            ${res.statut === 'confirmée'
              ? `<button class="btn-cancel text-xs text-red-300 hover:text-red-200 transition-colors font-medium" data-id="${res.id}">Annuler</button>`
              : ''
            }
            ${res.statut === 'annulée'
              ? `<button class="btn-noshow text-xs text-yellow-300 hover:text-yellow-200 transition-colors font-medium" data-id="${res.id}">No-show</button>`
              : ''
            }
          </div>
        </div>
      `;
      container.appendChild(card);
    });
  }

  // ── Helper affichage réservation ──────────────────────────────────────────
  function resDisplay(res) {
    const debut = new Date(res.creneau_debut);
    const fin = new Date(res.creneau_fin);
    const h1 = debut.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    const h2 = fin.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    const boxNames = res.reservation_boxes
      ?.map(rb => {
        const prefix = rb.boxes?.type === 'sans_fil' ? '📡 ' : '';
        return prefix + (rb.boxes?.nom ?? `Box ${rb.box_id}`);
      })
      .join(', ') ?? '—';
    const badges = {
      'confirmée': 'bg-green-500/15 text-green-300 border-green-500/30',
      'annulée': 'bg-red-500/15 text-red-300 border-red-500/30',
      'no_show': 'bg-yellow-500/15 text-yellow-300 border-yellow-500/30',
    };
    const badge = badges[res.statut] ?? 'bg-white/5 text-white/55 border-white/10';
    return { h1, h2, boxNames, badge };
  }

  // ── Actions (event delegation) ────────────────────────────────────────────
  document.addEventListener('click', async e => {
    const cancelBtn = /** @type {HTMLElement} */ (e.target).closest('.btn-cancel');
    const noshowBtn = /** @type {HTMLElement} */ (e.target).closest('.btn-noshow');

    if (cancelBtn) {
      const id = cancelBtn.dataset.id;
      if (!id) return;
      if (!confirm('Confirmer l\'annulation de cette réservation ?')) return;
      await updateStatut(id, 'annulée', cancelBtn);
    }

    if (noshowBtn) {
      const id = noshowBtn.dataset.id;
      if (!id) return;
      if (!confirm('Marquer ce client comme no-show ?')) return;
      await updateStatut(id, 'no_show', noshowBtn);
    }
  });

  async function updateStatut(id, newStatut, btn) {
    /** @type {HTMLButtonElement} */ (btn).disabled = true;
    btn.textContent = '...';

    const httpRes = await fetch('/api/admin/db', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'update_reservation', id, fields: { statut: newStatut } }),
    });
    let result;
    try {
      result = await httpRes.json();
    } catch {
      btn.disabled = false;
      btn.textContent = newStatut === 'annulée' ? 'Annuler' : 'No-show';
      showError('Erreur serveur — impossible de contacter l\'API');
      return;
    }
    const error = httpRes.ok ? null : result;

    if (error) {
      btn.disabled = false;
      btn.textContent = newStatut === 'annulée' ? 'Annuler' : 'No-show';
      showError('Erreur : ' + (error.error ?? 'Erreur serveur'));
    } else {
      if (newStatut === 'annulée') {
        const res = reservationsCache.find(r => r.id === id);
        if (res) {
          fetch('/api/reservation-annulation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              client_nom: res.client_nom,
              client_email: res.client_email,
              client_telephone: res.client_telephone,
              nb_personnes: res.nb_personnes,
              duree_minutes: res.duree_minutes,
              vr_type: res.reservation_boxes?.[0]?.boxes?.type ?? 'filaire',
              creneau_debut: res.creneau_debut,
              creneau_fin: res.creneau_fin,
              box_names: res.reservation_boxes.map(b => b.boxes.nom).join(', '),
              ref: res.id.split('-')[0].toUpperCase(),
              notes: res.notes ?? null,
            }),
          }).catch(err => console.error('Email annulation failed:', err));
        }
      }
      loadReservations(currentDate);
    }
  }

  // ── UI helpers ────────────────────────────────────────────────────────────
  function showState(state) {
    ['loading', 'error', 'empty', 'table'].forEach(s => {
      const el = document.getElementById(`admin-${s}${s === 'table' ? '-wrap' : ''}`);
      if (el) el.classList.toggle('hidden', s !== state);
    });
  }

  function showError(msg) {
    const el = document.getElementById('admin-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function hideError() {
    document.getElementById('admin-error').classList.add('hidden');
  }

  function localDateStr(d) {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function esc(str) {
    return String(str ?? '—').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // ── Contrôles date ─────────────────────────────────────────────────────────
  const DP_ID = 'dp-reservations';

  function shiftDay(dateStr, delta) {
    const d = new Date(dateStr + 'T12:00:00');
    d.setDate(d.getDate() + delta);
    return localDateStr(d);
  }

  function setDate(newDate) {
    if (newDate === currentDate) return;
    document.dispatchEvent(new CustomEvent('datepicker:setDate', {
      detail: { id: DP_ID, date: newDate }
    }));
    // datepicker:setDate déclenche datepicker:select → recharge les réservations
  }

  // Sélection depuis le calendrier (ou pilotée par setDate ci-dessus)
  document.addEventListener('datepicker:select', e => {
    if (e.detail.id !== DP_ID) return;
    if (e.detail.date === currentDate) return;
    currentDate = e.detail.date;
    loadReservations(currentDate);
  });

  document.getElementById('btn-prev').addEventListener('click', () => setDate(shiftDay(currentDate, -1)));
  document.getElementById('btn-next').addEventListener('click', () => setDate(shiftDay(currentDate, +1)));
  document.getElementById('btn-today').addEventListener('click', () => setDate(localDateStr(new Date())));

  // Raccourcis clavier ← / → pour naviguer entre jours
  document.addEventListener('keydown', e => {
    const tag = /** @type {HTMLElement} */ (e.target).tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || /** @type {HTMLElement} */ (e.target).isContentEditable) return;
    if (e.key === 'ArrowLeft')  { setDate(shiftDay(currentDate, -1)); e.preventDefault(); }
    if (e.key === 'ArrowRight') { setDate(shiftDay(currentDate, +1)); e.preventDefault(); }
  });

  // Charger les jours fermés + périodes de vacances pour colorer correctement
  // le datepicker (sinon les jours hors ouverture habituelle apparaissent à
  // tort en ambre même pendant les vacances scolaires).
  async function loadJoursOuvertureData() {
    const [fermesRes, vacancesRes] = await Promise.all([
      supabase.from('jours_fermeture').select('date'),
      supabase.from('periodes_vacances').select('date_debut, date_fin').order('date_debut'),
    ]);
    return {
      datesFermees: (fermesRes.data ?? []).map(j => j.date),
      periodesVacances: vacancesRes.data ?? [],
    };
  }

  // Init du datepicker en mode admin avec la date courante + données d'ouverture
  loadJoursOuvertureData().then(({ datesFermees, periodesVacances }) => {
    document.dispatchEvent(new CustomEvent('datepicker:init', {
      detail: {
        id: DP_ID,
        adminMode: true,
        selectedDate: currentDate,
        datesFermees,
        periodesVacances,
        joursNormaux: [0, 3, 5, 6], // dim, mer, ven, sam — cf. ReservationForm.astro
      }
    }));
  });

  // ── Démarrage ─────────────────────────────────────────────────────────────
  loadReservations(currentDate);
  initBlockButton();

  // ── Bouton blocage réservations ───────────────────────────────────────────
  async function initBlockButton() {
    const btn = document.getElementById('btn-block-reservations');
    const label = document.getElementById('btn-block-label');
    if (!btn || !label) return;

    const todayStr = localDateStr(new Date());

    // Lire l'état actuel depuis Supabase
    const { data } = await supabase
      .from('config')
      .select('valeur')
      .eq('cle', 'reservations_bloquees_date')
      .maybeSingle();

    let bloque = data?.valeur === todayStr;
    updateBlockBtn(btn, label, bloque);

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      const newValeur = bloque ? null : todayStr;
      const res = await fetch('/api/admin/db', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'set_config', cle: 'reservations_bloquees_date', valeur: newValeur }),
      });
      btn.disabled = false;
      if (res.ok) {
        bloque = !bloque;
        updateBlockBtn(btn, label, bloque);
      } else {
        showError('Erreur lors de la mise à jour du blocage');
      }
    });
  }

  function updateBlockBtn(btn, label, bloque) {
    const base = 'flex items-center justify-center px-4 py-2.5 text-sm rounded-xl transition-colors border col-span-2 sm:col-span-1';
    if (bloque) {
      btn.className = `${base} bg-red-500/15 border-red-500/30 text-red-300 hover:bg-red-500/25`;
      label.textContent = '🔴 Réservations bloquées — Débloquer';
    } else {
      btn.className = `${base} bg-white/5 border-white/10 text-white/70 hover:bg-white/10`;
      label.textContent = '🚫 Bloquer les réservations du jour';
    }
  }
</script>
