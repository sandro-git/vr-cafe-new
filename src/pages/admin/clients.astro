---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <main class="min-h-screen py-8 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">

      <!-- En-tête -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-white">Clients</h1>
          <p class="text-gray-400 text-sm mt-0.5">VR Café · Back-office</p>
        </div>
        <div class="flex gap-2">
          <a href="/admin/marketing" class="text-sm text-gray-400 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500">
            📊 Marketing
          </a>
          <a href="/admin/reservations" class="text-sm text-gray-400 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500">
            ← Réservations
          </a>
        </div>
      </div>

      <!-- Vue liste (chips + recherche + résultats) -->
      <div id="view-list">

        <!-- Chips de filtre -->
        <div class="flex gap-2 mb-5 flex-wrap">
          <button data-chip="tous"     class="chip-btn chip-active px-4 py-2 rounded-xl text-sm font-medium transition-colors border">Tous · <span id="count-tous">—</span></button>
          <button data-chip="fideles"  class="chip-btn px-4 py-2 rounded-xl text-sm font-medium transition-colors border">🏆 Fidèles · <span id="count-fideles">—</span></button>
          <button data-chip="inactifs" class="chip-btn px-4 py-2 rounded-xl text-sm font-medium transition-colors border">💤 Inactifs · <span id="count-inactifs">—</span></button>
        </div>

        <!-- Recherche -->
        <div class="relative mb-6">
          <input
            id="search-input"
            type="text"
            placeholder="Rechercher par nom, email ou téléphone..."
            autocomplete="off"
            class="w-full bg-gray-800 text-white border border-gray-600 rounded-2xl px-5 py-4 pr-12 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-500"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 text-lg">🔍</span>
        </div>

        <!-- Erreur -->
        <div id="search-error" class="hidden mb-4 p-4 bg-red-900/50 border border-red-700 rounded-xl text-red-300 text-sm"></div>

        <!-- Chargement initial -->
        <div id="state-loading" class="py-16 text-center">
          <div class="inline-block w-10 h-10 border-4 border-gray-600 border-t-blue-500 rounded-full animate-spin mb-4"></div>
          <p class="text-gray-400">Chargement des clients...</p>
        </div>

        <!-- Vide -->
        <div id="state-empty" class="hidden py-16 text-center">
          <p class="text-4xl mb-3">🔍</p>
          <p class="text-white font-medium">Aucun client trouvé</p>
          <p class="text-gray-400 text-sm mt-1">Essayez un autre terme ou filtre</p>
        </div>

        <!-- Liste clients -->
        <div id="clients-list" class="hidden space-y-3"></div>

      </div>

      <!-- Vue détail client -->
      <div id="view-detail" class="hidden">
        <div class="flex items-center justify-between gap-3 mb-6">
          <button id="btn-back" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
            ← Retour aux clients
          </button>
          <div class="flex gap-2">
            <button id="btn-edit" class="text-sm text-gray-300 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500">
              ✏️ Modifier
            </button>
            <button id="btn-delete" class="text-sm text-red-400 hover:text-red-300 transition-colors border border-red-800 rounded-xl px-4 py-2 hover:border-red-600">
              🗑️ Supprimer
            </button>
          </div>
        </div>
        <div id="detail-error" class="hidden mb-4 p-4 bg-red-900/50 border border-red-700 rounded-xl text-red-300 text-sm"></div>
        <div id="client-header" class="bg-gray-700/40 border border-gray-600 rounded-2xl p-6 mb-6"></div>
        <h2 class="text-lg font-semibold text-white mb-4">Historique des réservations</h2>
        <div id="client-reservations" class="space-y-3"></div>
      </div>

    </div>
  </main>

  <!-- Modale de modification client -->
  <div id="modal-edit" class="hidden fixed inset-0 z-50 items-center justify-center p-4 bg-black/60">
    <div class="bg-gray-800 border border-gray-600 rounded-2xl p-6 w-full max-w-md">
      <h3 class="text-lg font-bold text-white mb-5">Modifier le client</h3>
      <div id="modal-error" class="hidden mb-4 p-3 bg-red-900/50 border border-red-700 rounded-xl text-red-300 text-sm"></div>
      <div class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1.5" for="edit-nom">Nom</label>
          <input id="edit-nom" type="text" autocomplete="off"
            class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-500" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5" for="edit-email">Email</label>
          <input id="edit-email" type="email" autocomplete="off"
            class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-500" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5" for="edit-telephone">Téléphone</label>
          <input id="edit-telephone" type="tel" autocomplete="off"
            class="w-full bg-gray-700 text-white border border-gray-600 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-500" />
        </div>
      </div>
      <div class="flex justify-end gap-2 mt-6">
        <button id="modal-cancel" class="text-sm text-gray-400 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500">
          Annuler
        </button>
        <button id="modal-save" class="text-sm text-white bg-blue-600 hover:bg-blue-500 transition-colors rounded-xl px-4 py-2 disabled:opacity-50">
          Enregistrer
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .chip-btn {
    background: rgb(55 65 81 / 0.4);
    border-color: rgb(75 85 99);
    color: rgb(156 163 175);
  }
  .chip-btn:hover {
    border-color: rgb(107 114 128);
    color: white;
  }
  .chip-active {
    background: rgb(37 99 235 / 0.2);
    border-color: rgb(37 99 235 / 0.6);
    color: rgb(147 197 253);
  }
</style>

<script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ── État ──────────────────────────────────────────────────────────────────
  let allClients = [];
  let currentClient = null;
  let activeChip = 'tous';
  let searchQuery = '';
  let searchTimer = null;

  // ── Chargement initial de tous les clients ────────────────────────────────
  async function loadAllClients() {
    // 1. Les clients (source de vérité)
    const { data: clients, error: cErr } = await supabase
      .from('clients')
      .select('id, nom, email, telephone');

    if (cErr) {
      document.getElementById('state-loading').classList.add('hidden');
      showError('Erreur de chargement : ' + cErr.message);
      return;
    }

    // 2. Les réservations pour calculer les statistiques (par client_id)
    const { data: resas, error: rErr } = await supabase
      .from('reservations')
      .select('client_id, statut, creneau_debut');

    if (rErr) {
      document.getElementById('state-loading').classList.add('hidden');
      showError('Erreur de chargement : ' + rErr.message);
      return;
    }

    const threeMonthsAgo = new Date();
    threeMonthsAgo.setMonth(threeMonthsAgo.getMonth() - 3);

    // Agrégation des stats par client_id
    const statsMap = new Map();
    for (const r of (resas ?? [])) {
      if (!r.client_id || r.statut !== 'confirmée') continue;
      const date = r.creneau_debut ? new Date(r.creneau_debut) : null;
      const s = statsMap.get(r.client_id) ?? { nbConfirmees: 0, derniereResa: null };
      s.nbConfirmees++;
      if (date && (!s.derniereResa || date > s.derniereResa)) s.derniereResa = date;
      statsMap.set(r.client_id, s);
    }

    allClients = (clients ?? []).map(c => {
      const s = statsMap.get(c.id) ?? { nbConfirmees: 0, derniereResa: null };
      return {
        id: c.id,
        nom: c.nom ?? '',
        email: c.email ?? '',
        telephone: c.telephone ?? '',
        nbConfirmees: s.nbConfirmees,
        derniereResa: s.derniereResa,
        isFidele: s.nbConfirmees >= 5,
        isInactif: s.nbConfirmees > 0 && (!s.derniereResa || s.derniereResa < threeMonthsAgo),
      };
    }).sort((a, b) => (b.derniereResa ?? 0) - (a.derniereResa ?? 0));

    // Compter pour les chips
    document.getElementById('count-tous').textContent     = allClients.length;
    document.getElementById('count-fideles').textContent  = allClients.filter(c => c.isFidele).length;
    document.getElementById('count-inactifs').textContent = allClients.filter(c => c.isInactif).length;

    document.getElementById('state-loading').classList.add('hidden');
    applyFilters();
  }

  // ── Filtrage ──────────────────────────────────────────────────────────────
  function applyFilters() {
    let filtered = allClients;

    if (activeChip === 'fideles')  filtered = filtered.filter(c => c.isFidele);
    if (activeChip === 'inactifs') filtered = filtered.filter(c => c.isInactif);

    if (searchQuery.length >= 2) {
      const q = searchQuery.toLowerCase();
      filtered = filtered.filter(c =>
        c.nom.toLowerCase().includes(q) ||
        c.email.toLowerCase().includes(q) ||
        c.telephone.includes(q)
      );
    }

    if (!filtered.length) {
      document.getElementById('clients-list').classList.add('hidden');
      document.getElementById('state-empty').classList.remove('hidden');
    } else {
      document.getElementById('state-empty').classList.add('hidden');
      renderClients(filtered);
      document.getElementById('clients-list').classList.remove('hidden');
    }
  }

  // ── Rendu liste ───────────────────────────────────────────────────────────
  function renderClients(clients) {
    const container = document.getElementById('clients-list');
    container.innerHTML = '';
    clients.forEach(c => {
      const badges = [
        c.isFidele  ? '<span class="px-2 py-0.5 rounded-lg bg-yellow-900/40 border border-yellow-700/50 text-yellow-400 text-xs font-medium">🏆 Fidèle</span>' : '',
        c.isInactif ? '<span class="px-2 py-0.5 rounded-lg bg-orange-900/40 border border-orange-700/50 text-orange-400 text-xs font-medium">💤 Inactif</span>' : '',
      ].filter(Boolean).join('');

      const derniereResaFmt = c.derniereResa
        ? c.derniereResa.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })
        : '—';

      const card = document.createElement('div');
      card.className = 'bg-gray-700/40 border border-gray-600 rounded-2xl p-5 flex items-center justify-between hover:border-gray-500 transition-colors cursor-pointer';
      card.innerHTML = `
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap mb-0.5">
            <p class="font-semibold text-white truncate">${esc(c.nom)}</p>
            ${badges}
          </div>
          <p class="text-gray-400 text-sm truncate">${esc(c.email || '—')}</p>
          <p class="text-gray-500 text-xs mt-0.5">${esc(c.telephone || '—')} · ${c.nbConfirmees} rés. · Dernière : ${derniereResaFmt}</p>
        </div>
        <span class="text-gray-500 text-lg ml-3 shrink-0">›</span>
      `;
      card.addEventListener('click', () => openClient(c));
      container.appendChild(card);
    });
  }

  // ── Fiche client ──────────────────────────────────────────────────────────
  async function openClient(client) {
    currentClient = client;
    document.getElementById('view-list').classList.add('hidden');
    document.getElementById('view-detail').classList.remove('hidden');

    const badges = [
      client.isFidele  ? '<span class="px-2 py-1 rounded-lg bg-yellow-900/40 border border-yellow-700/50 text-yellow-400 text-sm font-medium">🏆 Fidèle</span>' : '',
      client.isInactif ? '<span class="px-2 py-1 rounded-lg bg-orange-900/40 border border-orange-700/50 text-orange-400 text-sm font-medium">💤 Inactif</span>' : '',
    ].filter(Boolean).join('');

    document.getElementById('client-header').innerHTML = `
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-blue-700/40 border border-blue-600 flex items-center justify-center text-xl shrink-0">
          ${esc(client.nom?.charAt(0)?.toUpperCase() ?? '?')}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <h2 class="text-xl font-bold text-white">${esc(client.nom)}</h2>
            ${badges}
          </div>
          ${client.email ? `<a href="mailto:${esc(client.email)}" class="text-blue-400 hover:text-blue-300 text-sm block">${esc(client.email)}</a>` : ''}
          ${client.telephone ? `<a href="tel:${esc(client.telephone)}" class="text-gray-400 hover:text-white text-sm transition-colors">${esc(client.telephone)}</a>` : ''}
        </div>
      </div>
    `;

    const resContainer = document.getElementById('client-reservations');
    resContainer.innerHTML = '<p class="text-gray-400 text-sm">Chargement...</p>';

    const q = supabase
      .from('reservations')
      .select('*, reservation_boxes(box_id, boxes(nom, type))')
      .order('creneau_debut', { ascending: false });

    if (client.id) q.eq('client_id', client.id);
    else if (client.email) q.eq('client_email', client.email);
    else { q.eq('client_nom', client.nom); if (client.telephone) q.eq('client_telephone', client.telephone); }

    const { data, error } = await q;

    if (error || !data?.length) {
      resContainer.innerHTML = '<p class="text-gray-400 text-sm">Aucune réservation trouvée.</p>';
      return;
    }

    const confirmed = data.filter(r => r.statut === 'confirmée');
    const totalMin = confirmed.reduce((s, r) => s + (r.duree_minutes || 0), 0);

    resContainer.innerHTML = `
      <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="bg-gray-700/40 border border-gray-600 rounded-xl p-3 text-center">
          <p class="text-2xl font-bold text-white">${data.length}</p>
          <p class="text-gray-400 text-xs mt-0.5">Réservations</p>
        </div>
        <div class="bg-gray-700/40 border border-gray-600 rounded-xl p-3 text-center">
          <p class="text-2xl font-bold text-green-400">${confirmed.length}</p>
          <p class="text-gray-400 text-xs mt-0.5">Confirmées</p>
        </div>
        <div class="bg-gray-700/40 border border-gray-600 rounded-xl p-3 text-center">
          <p class="text-2xl font-bold text-blue-400">${Math.round(totalMin / 60 * 10) / 10}h</p>
          <p class="text-gray-400 text-xs mt-0.5">Temps total</p>
        </div>
      </div>
    `;

    data.forEach(res => {
      const debut = new Date(res.creneau_debut);
      const fin = new Date(res.creneau_fin);
      const dateFmt = debut.toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
      const h1 = debut.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
      const h2 = fin.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
      const boxNames = res.reservation_boxes?.map(rb => {
        const prefix = rb.boxes?.type === 'sans_fil' ? '📡 ' : '🔌 ';
        return prefix + (rb.boxes?.nom ?? `Box ${rb.box_id}`);
      }).join(', ') ?? '—';
      const badgeCls = { 'confirmée': 'bg-green-900/50 text-green-400 border-green-800', 'annulée': 'bg-red-900/50 text-red-400 border-red-800', 'no_show': 'bg-yellow-900/50 text-yellow-400 border-yellow-800' };
      const cls = badgeCls[res.statut] ?? 'bg-gray-700 text-gray-400 border-gray-600';
      const card = document.createElement('div');
      card.className = 'bg-gray-700/40 border border-gray-600 rounded-2xl p-5';
      card.innerHTML = `
        <div class="flex items-start justify-between mb-2">
          <div><p class="text-white font-medium capitalize">${esc(dateFmt)}</p><p class="text-gray-400 text-sm">${h1} → ${h2}</p></div>
          <span class="px-2 py-1 rounded-lg border text-xs font-medium ${cls}">${res.statut}</span>
        </div>
        <div class="text-xs text-gray-500 mt-2 flex flex-wrap gap-x-4 gap-y-1">
          <span>${res.duree_minutes} min</span>
          <span>${res.nb_personnes} joueur${res.nb_personnes > 1 ? 's' : ''}</span>
          <span>${esc(boxNames)}</span>
          ${res.notes ? `<span class="italic">"${esc(res.notes)}"</span>` : ''}
        </div>
      `;
      resContainer.appendChild(card);
    });
  }

  // ── Helpers UI ────────────────────────────────────────────────────────────
  function showError(msg) {
    const el = document.getElementById('search-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function esc(str) {
    return String(str ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // ── Événements ────────────────────────────────────────────────────────────
  document.querySelectorAll('.chip-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.chip-btn').forEach(b => b.classList.remove('chip-active'));
      btn.classList.add('chip-active');
      activeChip = btn.dataset.chip;
      applyFilters();
    });
  });

  document.getElementById('search-input').addEventListener('input', e => {
    clearTimeout(searchTimer);
    searchQuery = e.target.value.trim();
    searchTimer = setTimeout(applyFilters, 250);
  });

  function backToList() {
    document.getElementById('view-detail').classList.add('hidden');
    document.getElementById('detail-error').classList.add('hidden');
    document.getElementById('view-list').classList.remove('hidden');
  }

  document.getElementById('btn-back').addEventListener('click', backToList);

  function showDetailError(msg) {
    const el = document.getElementById('detail-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  // ── Modale de modification ─────────────────────────────────────────────────
  function openModal() {
    if (!currentClient) return;
    document.getElementById('edit-nom').value = currentClient.nom ?? '';
    document.getElementById('edit-email').value = currentClient.email ?? '';
    document.getElementById('edit-telephone').value = currentClient.telephone ?? '';
    document.getElementById('modal-error').classList.add('hidden');
    const modal = document.getElementById('modal-edit');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    const modal = document.getElementById('modal-edit');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function showModalError(msg) {
    const el = document.getElementById('modal-error');
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  document.getElementById('btn-edit').addEventListener('click', openModal);
  document.getElementById('modal-cancel').addEventListener('click', closeModal);
  document.getElementById('modal-edit').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeModal();
  });

  document.getElementById('modal-save').addEventListener('click', async () => {
    if (!currentClient) return;
    const nom = document.getElementById('edit-nom').value.trim();
    const email = document.getElementById('edit-email').value.trim();
    const telephone = document.getElementById('edit-telephone').value.trim();

    if (!nom) { showModalError('Le nom est obligatoire.'); return; }

    const btn = document.getElementById('modal-save');
    btn.disabled = true;
    btn.textContent = 'Enregistrement...';
    try {
      const res = await fetch('/api/admin/db', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'update_client',
          id: currentClient.id,
          fields: { nom, email, telephone },
        }),
      });
      const out = await res.json().catch(() => ({}));
      if (!res.ok || out.error) throw new Error(out.error || `Erreur ${res.status}`);
      closeModal();
      backToList();
      await loadAllClients();
    } catch (err) {
      showModalError('Échec de la modification : ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enregistrer';
    }
  });

  // ── Suppression ────────────────────────────────────────────────────────────
  document.getElementById('btn-delete').addEventListener('click', async () => {
    if (!currentClient) return;
    if (!confirm(`Supprimer « ${currentClient.nom || currentClient.email} » ?\n\nCela supprimera définitivement toutes ses réservations. Cette action est irréversible.`))
      return;

    const btn = document.getElementById('btn-delete');
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/db', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete_client', id: currentClient.id }),
      });
      const out = await res.json().catch(() => ({}));
      if (!res.ok || out.error) throw new Error(out.error || `Erreur ${res.status}`);
      backToList();
      await loadAllClients();
    } catch (err) {
      showDetailError('Échec de la suppression : ' + err.message);
    } finally {
      btn.disabled = false;
    }
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  loadAllClients();
</script>
