---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <main class="min-h-screen py-8 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">

      <!-- En-tête -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-white">Clients</h1>
          <p class="text-gray-400 text-sm mt-0.5">VR Café · Back-office</p>
        </div>
        <a
          href="/admin/reservations"
          class="text-sm text-gray-400 hover:text-white transition-colors border border-gray-600 rounded-xl px-4 py-2 hover:border-gray-500"
        >
          ← Réservations
        </a>
      </div>

      <!-- Recherche -->
      <div class="relative mb-8">
        <input
          id="search-input"
          type="text"
          placeholder="Rechercher par nom, email ou téléphone..."
          autocomplete="off"
          class="w-full bg-gray-800 text-white border border-gray-600 rounded-2xl px-5 py-4 pr-12 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-500"
        />
        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 text-lg">🔍</span>
      </div>

      <!-- Erreur -->
      <div id="search-error" class="hidden mb-4 p-4 bg-red-900/50 border border-red-700 rounded-xl text-red-300 text-sm"></div>

      <!-- État initial -->
      <div id="state-hint" class="py-16 text-center">
        <p class="text-4xl mb-3">👤</p>
        <p class="text-white font-medium">Recherchez un client</p>
        <p class="text-gray-400 text-sm mt-1">Tapez au moins 2 caractères</p>
      </div>

      <!-- Chargement -->
      <div id="state-loading" class="hidden py-16 text-center">
        <div class="inline-block w-10 h-10 border-4 border-gray-600 border-t-blue-500 rounded-full animate-spin mb-4"></div>
        <p class="text-gray-400">Recherche...</p>
      </div>

      <!-- Vide -->
      <div id="state-empty" class="hidden py-16 text-center">
        <p class="text-4xl mb-3">🔍</p>
        <p class="text-white font-medium">Aucun client trouvé</p>
        <p class="text-gray-400 text-sm mt-1">Essayez un autre terme</p>
      </div>

      <!-- Résultats : liste de clients -->
      <div id="clients-list" class="hidden space-y-3"></div>

      <!-- Fiche client (détail) -->
      <div id="client-detail" class="hidden">
        <button id="btn-back-search" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mb-6">
          ← Retour aux résultats
        </button>
        <div id="client-header" class="bg-gray-700/40 border border-gray-600 rounded-2xl p-6 mb-6"></div>
        <h2 class="text-lg font-semibold text-white mb-4">Historique des réservations</h2>
        <div id="client-reservations" class="space-y-3"></div>
      </div>

    </div>
  </main>
</AdminLayout>

<script>
  // @ts-nocheck
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  let searchTimer = null;
  let lastResults = [];

  // ── Recherche ─────────────────────────────────────────────────────────────
  async function search(query) {
    if (query.length < 2) { showState('hint'); return; }
    showState('loading');

    const { data, error } = await supabase
      .from('reservations')
      .select('client_nom, client_email, client_telephone')
      .or(`client_nom.ilike.%${query}%,client_email.ilike.%${query}%,client_telephone.ilike.%${query}%`)
      .order('created_at', { ascending: false })
      .limit(100);

    if (error) { showError('Erreur : ' + error.message); return; }

    // Dédoublonner par email (ou nom si pas d'email)
    const seen = new Set();
    const clients = (data ?? []).filter(r => {
      const key = r.client_email?.toLowerCase() || r.client_nom?.toLowerCase();
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });

    lastResults = clients;

    if (!clients.length) { showState('empty'); return; }
    renderClients(clients);
    showState('results');
  }

  // ── Rendu liste clients ────────────────────────────────────────────────────
  function renderClients(clients) {
    const container = document.getElementById('clients-list');
    container.innerHTML = '';
    clients.forEach(c => {
      const card = document.createElement('div');
      card.className = 'bg-gray-700/40 border border-gray-600 rounded-2xl p-5 flex items-center justify-between hover:border-gray-500 transition-colors cursor-pointer';
      card.innerHTML = `
        <div>
          <p class="font-semibold text-white">${esc(c.client_nom)}</p>
          <p class="text-gray-400 text-sm mt-0.5">${esc(c.client_email ?? '—')}</p>
          <p class="text-gray-500 text-xs mt-0.5">${esc(c.client_telephone ?? '—')}</p>
        </div>
        <span class="text-gray-500 text-lg">›</span>
      `;
      card.addEventListener('click', () => openClient(c));
      container.appendChild(card);
    });
  }

  // ── Fiche client ──────────────────────────────────────────────────────────
  async function openClient(client) {
    showState('detail');

    // En-tête client
    document.getElementById('client-header').innerHTML = `
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-blue-700/40 border border-blue-600 flex items-center justify-center text-xl shrink-0">
          ${esc(client.client_nom?.charAt(0)?.toUpperCase() ?? '?')}
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">${esc(client.client_nom)}</h2>
          ${client.client_email ? `<a href="mailto:${esc(client.client_email)}" class="text-blue-400 hover:text-blue-300 text-sm">${esc(client.client_email)}</a>` : ''}
          ${client.client_telephone ? `<p class="text-gray-400 text-sm mt-0.5"><a href="tel:${esc(client.client_telephone)}" class="hover:text-white transition-colors">${esc(client.client_telephone)}</a></p>` : ''}
        </div>
      </div>
    `;

    // Charger l'historique
    const resContainer = document.getElementById('client-reservations');
    resContainer.innerHTML = '<p class="text-gray-400 text-sm">Chargement...</p>';

    const query = supabase
      .from('reservations')
      .select('*, reservation_boxes(box_id, boxes(nom, type))')
      .order('creneau_debut', { ascending: false });

    // Chercher par email en priorité, sinon par nom + tel
    if (client.client_email) {
      query.eq('client_email', client.client_email);
    } else {
      query.eq('client_nom', client.client_nom);
      if (client.client_telephone) query.eq('client_telephone', client.client_telephone);
    }

    const { data, error } = await query;

    if (error || !data?.length) {
      resContainer.innerHTML = '<p class="text-gray-400 text-sm">Aucune réservation trouvée.</p>';
      return;
    }

    // Stats rapides
    const confirmed = data.filter(r => r.statut === 'confirmée');
    const totalMin = confirmed.reduce((s, r) => s + (r.duree_minutes || 0), 0);
    const statsHtml = `
      <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="bg-gray-700/40 border border-gray-600 rounded-xl p-3 text-center">
          <p class="text-2xl font-bold text-white">${data.length}</p>
          <p class="text-gray-400 text-xs mt-0.5">Réservations</p>
        </div>
        <div class="bg-gray-700/40 border border-gray-600 rounded-xl p-3 text-center">
          <p class="text-2xl font-bold text-green-400">${confirmed.length}</p>
          <p class="text-gray-400 text-xs mt-0.5">Confirmées</p>
        </div>
        <div class="bg-gray-700/40 border border-gray-600 rounded-xl p-3 text-center">
          <p class="text-2xl font-bold text-blue-400">${Math.round(totalMin / 60 * 10) / 10}h</p>
          <p class="text-gray-400 text-xs mt-0.5">Temps total</p>
        </div>
      </div>
    `;

    resContainer.innerHTML = statsHtml;

    data.forEach(res => {
      const debut = new Date(res.creneau_debut);
      const fin = new Date(res.creneau_fin);
      const dateFmt = debut.toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
      const h1 = debut.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
      const h2 = fin.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
      const boxNames = res.reservation_boxes?.map(rb => {
        const prefix = rb.boxes?.type === 'sans_fil' ? '📡 ' : '🔌 ';
        return prefix + (rb.boxes?.nom ?? `Box ${rb.box_id}`);
      }).join(', ') ?? '—';
      const badges = {
        'confirmée': 'bg-green-900/50 text-green-400 border-green-800',
        'annulée': 'bg-red-900/50 text-red-400 border-red-800',
        'no_show': 'bg-yellow-900/50 text-yellow-400 border-yellow-800',
      };
      const badge = badges[res.statut] ?? 'bg-gray-700 text-gray-400 border-gray-600';

      const card = document.createElement('div');
      card.className = 'bg-gray-700/40 border border-gray-600 rounded-2xl p-5';
      card.innerHTML = `
        <div class="flex items-start justify-between mb-2">
          <div>
            <p class="text-white font-medium capitalize">${esc(dateFmt)}</p>
            <p class="text-gray-400 text-sm">${h1} → ${h2}</p>
          </div>
          <span class="px-2 py-1 rounded-lg border text-xs font-medium ${badge}">${res.statut}</span>
        </div>
        <div class="text-xs text-gray-500 mt-2 flex flex-wrap gap-x-4 gap-y-1">
          <span>${res.duree_minutes} min</span>
          <span>${res.nb_personnes} joueur${res.nb_personnes > 1 ? 's' : ''}</span>
          <span>${esc(boxNames)}</span>
          ${res.notes ? `<span class="text-gray-600 italic">"${esc(res.notes)}"</span>` : ''}
        </div>
      `;
      resContainer.appendChild(card);
    });
  }

  // ── UI ────────────────────────────────────────────────────────────────────
  function showState(state) {
    document.getElementById('state-hint').classList.toggle('hidden', state !== 'hint');
    document.getElementById('state-loading').classList.toggle('hidden', state !== 'loading');
    document.getElementById('state-empty').classList.toggle('hidden', state !== 'empty');
    document.getElementById('clients-list').classList.toggle('hidden', state !== 'results');
    document.getElementById('client-detail').classList.toggle('hidden', state !== 'detail');
    document.getElementById('search-error').classList.add('hidden');
  }

  function showError(msg) {
    const el = document.getElementById('search-error');
    el.textContent = msg;
    el.classList.remove('hidden');
    document.getElementById('state-loading').classList.add('hidden');
  }

  function esc(str) {
    return String(str ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // ── Événements ────────────────────────────────────────────────────────────
  document.getElementById('search-input').addEventListener('input', e => {
    clearTimeout(searchTimer);
    const val = e.target.value.trim();
    if (val.length < 2) { showState('hint'); return; }
    showState('loading');
    searchTimer = setTimeout(() => search(val), 300);
  });

  document.getElementById('btn-back-search').addEventListener('click', () => {
    if (lastResults.length) {
      renderClients(lastResults);
      showState('results');
    } else {
      showState('hint');
    }
  });
</script>
