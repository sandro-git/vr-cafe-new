---
import BaseHead from "../../layouts/BaseHead.astro";

// If already logged in, redirect to admin
const cookie = Astro.cookies.get("admin_session");
const password = import.meta.env.ADMIN_PASSWORD || process.env.ADMIN_PASSWORD;
if (password && cookie?.value === password) {
  return Astro.redirect("/admin/reservations");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const submitted = form.get("password")?.toString() ?? "";

  if (submitted === password) {
    Astro.cookies.set("admin_session", submitted, {
      httpOnly: true,
      secure: true,
      sameSite: "strict",
      maxAge: 60 * 60 * 24 * 30, // 30 days
      path: "/",
    });
    return Astro.redirect("/admin/reservations");
  } else {
    error = "Mot de passe incorrect.";
  }
}
---

<html lang="fr" class="dark">
  <BaseHead />
  <body class="bg-[var(--color-surface)] min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <h1 class="font-display text-2xl font-extrabold tracking-tight text-white">Administration</h1>
        <p class="text-sm uppercase tracking-[0.2em] text-[var(--color-brand-400)] mt-2">VR Café</p>
      </div>

      <form method="POST" class="card-glow p-8 space-y-5">
        {error && (
          <div class="p-3 bg-red-500/10 border border-red-500/30 rounded-xl text-red-300 text-sm">
            {error}
          </div>
        )}

        <div>
          <label for="password" class="block text-sm font-medium text-white/70 mb-2">
            Mot de passe
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            class="w-full bg-white/5 text-white ring-1 ring-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-400)] placeholder:text-white/35"
          />
        </div>

        <button
          type="submit"
          class="w-full py-3 bg-[var(--color-brand-600)] hover:bg-[var(--color-brand-500)] text-white font-semibold rounded-xl transition-colors"
        >
          Se connecter
        </button>
      </form>
    </div>
  </body>
</html>
