---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout>
  <main class="min-h-screen py-8 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">

      <!-- En-tête -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="font-display text-2xl font-extrabold tracking-tight text-white">Marketing</h1>
          <p class="text-white/55 text-sm mt-0.5">VR Café · Fidélisation clients</p>
        </div>
        <a href="/admin/clients" class="text-sm text-white/55 hover:text-white transition-colors border border-white/10 rounded-xl px-4 py-2 hover:border-white/20 self-start">
          ← Clients
        </a>
      </div>

      <!-- Chargement -->
      <div id="state-loading" class="py-16 text-center">
        <div class="inline-block w-10 h-10 border-4 border-white/20 border-t-[var(--color-brand-400)] rounded-full animate-spin mb-4"></div>
        <p class="text-white/55">Analyse des clients...</p>
      </div>

      <!-- Contenu -->
      <div id="content" class="hidden space-y-8">

        <!-- Stats cards -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="bg-[var(--color-surface-card)] border border-white/10 rounded-xl p-4 text-center">
            <p id="stat-total" class="text-3xl font-bold text-[var(--color-brand-300)]">—</p>
            <p class="text-white/55 text-xs mt-1 uppercase tracking-wide">Clients total</p>
          </div>
          <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 text-center">
            <p id="stat-fideles" class="text-3xl font-bold text-yellow-300">—</p>
            <p class="text-white/55 text-xs mt-1 uppercase tracking-wide">🏆 Fidèles</p>
          </div>
          <div class="bg-orange-500/10 border border-orange-500/30 rounded-xl p-4 text-center">
            <p id="stat-inactifs" class="text-3xl font-bold text-orange-300">—</p>
            <p class="text-white/55 text-xs mt-1 uppercase tracking-wide">💤 Inactifs</p>
          </div>
          <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 text-center">
            <p id="stat-nouveaux" class="text-3xl font-bold text-green-300">—</p>
            <p class="text-white/55 text-xs mt-1 uppercase tracking-wide">🆕 Nouveaux</p>
          </div>
        </div>

        <!-- Bloc Fidèles -->
        <section>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-white">🏆 Clients fidèles</h2>
              <p class="text-white/55 text-sm mt-0.5">5 réservations confirmées ou plus</p>
            </div>
            <a
              id="btn-mailjet-fideles"
              href="https://app.mailjet.com/campaigns/create"
              target="_blank"
              class="flex items-center gap-2 px-4 py-2 bg-[var(--color-brand-600)]/20 hover:bg-[var(--color-brand-600)]/35 border border-[var(--color-brand-500)]/50 text-[var(--color-brand-200)] text-sm rounded-xl transition-colors"
            >
              Campagne Mailjet ↗
            </a>
          </div>
          <div id="list-fideles" class="space-y-2"></div>
          <p id="empty-fideles" class="hidden text-white/40 text-sm py-4">Aucun client fidèle pour l'instant.</p>
        </section>

        <!-- Bloc Inactifs -->
        <section>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-white">💤 Clients inactifs</h2>
              <p class="text-white/55 text-sm mt-0.5">Aucune réservation depuis plus de 3 mois</p>
            </div>
            <a
              href="https://app.mailjet.com/campaigns/create"
              target="_blank"
              class="flex items-center gap-2 px-4 py-2 bg-[var(--color-brand-600)]/20 hover:bg-[var(--color-brand-600)]/35 border border-[var(--color-brand-500)]/50 text-[var(--color-brand-200)] text-sm rounded-xl transition-colors"
            >
              Campagne Mailjet ↗
            </a>
          </div>
          <div id="list-inactifs" class="space-y-2"></div>
          <p id="empty-inactifs" class="hidden text-white/40 text-sm py-4">Aucun client inactif pour l'instant.</p>
        </section>

        <!-- Bloc Nouveaux -->
        <section>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-semibold text-white">🆕 Nouveaux clients</h2>
              <p class="text-white/55 text-sm mt-0.5">Première réservation dans les 30 derniers jours</p>
            </div>
          </div>
          <div id="list-nouveaux" class="space-y-2"></div>
          <p id="empty-nouveaux" class="hidden text-white/40 text-sm py-4">Aucun nouveau client ce mois-ci.</p>
        </section>

      </div>
    </div>
  </main>
</AdminLayout>

<script>
  // @ts-nocheck
  import { supabase } from '../../lib/supabase.js';

  function esc(str) {
    return String(str ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function fmtDate(date) {
    if (!date) return '—';
    return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  function renderClientRow(c, extraBadge = '') {
    const div = document.createElement('div');
    div.className = 'bg-[var(--color-surface-card)] border border-white/10 rounded-xl px-4 py-3 flex items-center justify-between gap-4';
    div.innerHTML = `
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="font-medium text-white text-sm">${esc(c.nom)}</span>
          ${extraBadge}
        </div>
        <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-0.5">
          ${c.email ? `<a href="mailto:${esc(c.email)}" class="text-[var(--color-brand-300)] hover:text-[var(--color-brand-200)] text-xs">${esc(c.email)}</a>` : ''}
          ${c.telephone ? `<span class="text-white/40 text-xs">${esc(c.telephone)}</span>` : ''}
        </div>
      </div>
      <div class="text-right shrink-0">
        <p class="text-white text-sm font-medium">${c.nbConfirmees} rés.</p>
        <p class="text-white/40 text-xs">${fmtDate(c.derniereResa)}</p>
      </div>
    `;
    return div;
  }

  async function load() {
    const { data, error } = await supabase
      .from('reservations')
      .select('client_nom, client_email, client_telephone, statut, creneau_debut')
      .order('creneau_debut', { ascending: false });

    if (error) { console.error(error); return; }

    const now = new Date();
    const threeMonthsAgo = new Date(); threeMonthsAgo.setMonth(now.getMonth() - 3);
    const thirtyDaysAgo  = new Date(); thirtyDaysAgo.setDate(now.getDate() - 30);

    const clientMap = new Map();

    for (const r of (data ?? [])) {
      const key = r.client_email?.toLowerCase().trim() || r.client_nom?.toLowerCase().trim();
      if (!key) continue;
      const isConfirmee = r.statut === 'confirmée';
      const date = r.creneau_debut ? new Date(r.creneau_debut) : null;

      if (!clientMap.has(key)) {
        clientMap.set(key, {
          nom: r.client_nom ?? '',
          email: r.client_email ?? '',
          telephone: r.client_telephone ?? '',
          nbConfirmees: isConfirmee ? 1 : 0,
          derniereResa: isConfirmee && date ? date : null,
          premiereResa: isConfirmee && date ? date : null,
        });
      } else {
        const c = clientMap.get(key);
        if (isConfirmee && date) {
          c.nbConfirmees++;
          if (!c.derniereResa || date > c.derniereResa) c.derniereResa = date;
          if (!c.premiereResa || date < c.premiereResa) c.premiereResa = date;
        }
      }
    }

    const clients = [...clientMap.values()].map(c => ({
      ...c,
      isFidele:   c.nbConfirmees >= 5,
      isInactif:  c.nbConfirmees > 0 && (!c.derniereResa || c.derniereResa < threeMonthsAgo),
      isNouveau:  c.premiereResa && c.premiereResa >= thirtyDaysAgo,
    }));

    const fideles  = clients.filter(c => c.isFidele).sort((a, b) => b.nbConfirmees - a.nbConfirmees);
    const inactifs = clients.filter(c => c.isInactif).sort((a, b) => (a.derniereResa ?? 0) - (b.derniereResa ?? 0));
    const nouveaux = clients.filter(c => c.isNouveau).sort((a, b) => b.premiereResa - a.premiereResa);

    // Compteurs
    document.getElementById('stat-total').textContent    = clients.length;
    document.getElementById('stat-fideles').textContent  = fideles.length;
    document.getElementById('stat-inactifs').textContent = inactifs.length;
    document.getElementById('stat-nouveaux').textContent = nouveaux.length;

    // Fidèles
    const listFideles = document.getElementById('list-fideles');
    if (fideles.length) {
      fideles.forEach(c => {
        const badge = `<span class="px-1.5 py-0.5 rounded bg-yellow-500/15 border border-yellow-500/30 text-yellow-300 text-xs">${c.nbConfirmees} rés.</span>`;
        listFideles.appendChild(renderClientRow(c, badge));
      });
    } else document.getElementById('empty-fideles').classList.remove('hidden');

    // Inactifs
    const listInactifs = document.getElementById('list-inactifs');
    if (inactifs.length) {
      inactifs.forEach(c => {
        const moisInactif = c.derniereResa
          ? Math.floor((now - c.derniereResa) / (1000 * 60 * 60 * 24 * 30))
          : '?';
        const badge = `<span class="px-1.5 py-0.5 rounded bg-orange-500/15 border border-orange-500/30 text-orange-300 text-xs">+${moisInactif} mois</span>`;
        listInactifs.appendChild(renderClientRow(c, badge));
      });
    } else document.getElementById('empty-inactifs').classList.remove('hidden');

    // Nouveaux
    const listNouveaux = document.getElementById('list-nouveaux');
    if (nouveaux.length) {
      nouveaux.forEach(c => {
        const badge = `<span class="px-1.5 py-0.5 rounded bg-green-500/15 border border-green-500/30 text-green-300 text-xs">Nouveau</span>`;
        listNouveaux.appendChild(renderClientRow(c, badge));
      });
    } else document.getElementById('empty-nouveaux').classList.remove('hidden');

    document.getElementById('state-loading').classList.add('hidden');
    document.getElementById('content').classList.remove('hidden');
  }

  load();
</script>
