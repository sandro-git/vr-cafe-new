---
import AdminLayout from "../../layouts/AdminLayout.astro";
import ReservationForm from "../../components/ReservationForm.astro";
import ReservationFormAnniversaire from "../../components/ReservationFormAnniversaire.astro";

const type = Astro.url.searchParams.get('type') ?? 'standard';
const isAnniversaire = type === 'anniversaire';
---

<AdminLayout>
  <!-- Onglets Standard / Anniversaire -->
  <div class="max-w-xl mx-auto px-4 pt-8 pb-0">
    <div class="flex gap-2 bg-gray-800 rounded-2xl p-1 border border-gray-700">
      <a
        href="/admin/reservation?type=standard"
        class={`flex-1 text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${!isAnniversaire ? 'bg-blue-700 text-white' : 'text-gray-400 hover:text-white'}`}
      >
        🎮 Standard
      </a>
      <a
        href="/admin/reservation?type=anniversaire"
        class={`flex-1 text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${isAnniversaire ? 'bg-pink-700 text-white' : 'text-gray-400 hover:text-white'}`}
      >
        🎂 Anniversaire
      </a>
    </div>
  </div>

  {isAnniversaire
    ? <ReservationFormAnniversaire mode="admin" />
    : <ReservationForm mode="admin" />
  }
</AdminLayout>
