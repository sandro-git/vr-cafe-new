---
import AdminLayout from "../../layouts/AdminLayout.astro";
import ReservationForm from "../../components/ReservationForm.astro";
import ReservationFormAnniversaire from "../../components/ReservationFormAnniversaire.astro";
import ReservationFormMDJ from "../../components/ReservationFormMDJ.astro";

const type = Astro.url.searchParams.get('type') ?? 'standard';
const isAnniversaire = type === 'anniversaire';
const isMDJ = type === 'mdj';
const isStandard = !isAnniversaire && !isMDJ;
---

<AdminLayout>
  <!-- Onglets Standard / Anniversaire / MDJ -->
  <div class="max-w-xl mx-auto px-4 pt-8 pb-0">
    <div class="flex gap-2 bg-[var(--color-surface-card)] rounded-2xl p-1 border border-white/10">
      <a
        href="/admin/reservation?type=standard"
        class={`flex-1 text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${isStandard ? 'bg-[var(--color-brand-600)] text-white' : 'text-white/55 hover:text-white'}`}
      >
        🎮 Standard
      </a>
      <a
        href="/admin/reservation?type=anniversaire"
        class={`flex-1 text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${isAnniversaire ? 'bg-pink-600 text-white' : 'text-white/55 hover:text-white'}`}
      >
        🎂 Anniversaire
      </a>
      <a
        href="/admin/reservation?type=mdj"
        class={`flex-1 text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${isMDJ ? 'bg-violet-600 text-white' : 'text-white/55 hover:text-white'}`}
      >
        🏠 MDJ
      </a>
    </div>
  </div>

  {isMDJ
    ? <ReservationFormMDJ mode="admin" />
    : isAnniversaire
      ? <ReservationFormAnniversaire mode="admin" />
      : <ReservationForm mode="admin" />
  }
</AdminLayout>
