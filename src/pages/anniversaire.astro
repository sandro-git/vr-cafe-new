---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "sanity:client";

type Tarif = {
  _id: string;
  name: string;
  prix: number;
  features?: string[];
};

const tarifAnniversaire = await sanityClient.fetch<Tarif | null>(
  `*[_type == "tarif" && type == "anniversaire"][0] { _id, name, prix, features }`
);
---

<BaseLayout
  title="Anniversaire en Réalité Virtuelle à Perpignan | VR Café Canet-en-Roussillon"
  description="Organisez un anniversaire inoubliable en réalité virtuelle à Canet-en-Roussillon, à 10 min de Perpignan. Escape games, jeux VR, formules groupe. Réservez !"
>
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-6xl mb-6">🎂</div>
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight">
        Anniversaire VR à <span class="text-pink-400">Perpignan</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-4">
        L'anniversaire dont tout le monde va parler
      </p>
      <p class="text-lg text-gray-400 mb-10 max-w-2xl mx-auto">
        Fêtez votre anniversaire ou celui de vos proches en réalité virtuelle au VR Café de Canet-en-Roussillon. Une expérience unique, pour tous les âges, à 10 minutes de Perpignan.
      </p>
      <a
        href="/reservation-anniversaire"
        class="inline-block px-10 py-4 bg-linear-to-r from-pink-500 to-purple-600 text-white font-bold text-lg rounded-full hover:shadow-2xl hover:scale-105 transition-all duration-300"
      >
        Réserver mon anniversaire
      </a>
    </div>
  </section>

  <!-- Pourquoi VR Café -->
  <section class="bg-gray-800 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-12">
        Pourquoi fêter son anniversaire au VR Café ?
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gray-700 rounded-xl p-6 text-center">
          <div class="text-4xl mb-4">🎮</div>
          <h3 class="text-xl font-bold text-white mb-3">Des expériences pour tous</h3>
          <p class="text-gray-400">
            Enfants, ados ou adultes — nos jeux VR conviennent à tous les âges. Escape games, jeux d'action, aventures multijoueurs.
          </p>
        </div>
        <div class="bg-gray-700 rounded-xl p-6 text-center">
          <div class="text-4xl mb-4">👥</div>
          <h3 class="text-xl font-bold text-white mb-3">Groupes jusqu'à 10 personnes</h3>
          <p class="text-gray-400">
            Nous accueillons vos groupes et organisons les sessions pour que tout le monde joue ensemble ou en rotation.
          </p>
        </div>
        <div class="bg-gray-700 rounded-xl p-6 text-center">
          <div class="text-4xl mb-4">⭐</div>
          <h3 class="text-xl font-bold text-white mb-3">4,9/5 sur TripAdvisor</h3>
          <p class="text-gray-400">
            56 avis clients enthousiastes. Nos visiteurs repartent avec des souvenirs plein les yeux — et reviennent !
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Formules -->
  <section class="bg-gray-900 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-12">
        Formules anniversaire
      </h2>
      <div class="flex justify-center">
        <div class="bg-gray-800 border-2 border-purple-500 rounded-xl p-8 w-full max-w-md">
          <h3 class="text-2xl font-bold text-white mb-2">{tarifAnniversaire?.name ?? "Anniversaire"}</h3>
          <div class="text-3xl font-extrabold text-purple-400 mb-4">
            {tarifAnniversaire?.prix ?? 25} €<span class="text-base font-normal text-gray-400">/pers.</span>
          </div>
          <ul class="text-gray-400 space-y-2 mb-6">
            {(tarifAnniversaire?.features ?? [
              "60 minutes de VR",
              "Accès à toutes les expériences",
              "Escape game ou jeux au choix",
              "Minimum 5 enfants",
              "Tables et bancs mis à disposition pour le gâteau",
            ]).map((f) => <li>✓ {f}</li>)}
          </ul>
          <a href="/reservation-anniversaire" class="block text-center py-3 bg-linear-to-r from-purple-500 to-pink-500 text-white font-semibold rounded-lg hover:shadow-lg transition-shadow">
            Réserver
          </a>
        </div>
      </div>
      <p class="text-gray-500 text-sm text-center mt-6">
        Pour les groupes de plus de 6 personnes, contactez-nous pour une organisation sur-mesure.
      </p>
    </div>
  </section>

  <!-- Âges -->
  <section class="bg-gray-800 py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-12">
        Pour quel âge ?
      </h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4 bg-gray-700 rounded-xl p-5">
          <span class="text-2xl">👶</span>
          <div>
            <h3 class="text-white font-bold">Enfants (7–12 ans)</h3>
            <p class="text-gray-400">Jeux adaptés, casques ajustables, accompagnement par notre équipe. La VR est accessible dès 7 ans.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-700 rounded-xl p-5">
          <span class="text-2xl">🧑</span>
          <div>
            <h3 class="text-white font-bold">Adolescents (13–17 ans)</h3>
            <p class="text-gray-400">Escape games, jeux de tir, aventures multijoueurs. La formule parfaite pour un anniversaire entre potes.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 bg-gray-700 rounded-xl p-5">
          <span class="text-2xl">👨</span>
          <div>
            <h3 class="text-white font-bold">Adultes</h3>
            <p class="text-gray-400">Des expériences immersives pour les 18 ans, 30 ans, 40 ans… L'anniversaire qui sort de l'ordinaire.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-linear-to-r from-pink-600 to-purple-700 py-16 px-4">
    <div class="max-w-3xl mx-auto text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Prêt à organiser l'anniversaire parfait ?</h2>
      <p class="text-pink-100 text-lg mb-8">
        Réservez en ligne en quelques clics ou contactez-nous pour un devis groupe.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/reservation-anniversaire"
          class="px-8 py-4 bg-white text-purple-700 font-bold rounded-full hover:bg-gray-100 transition-colors"
        >
          Réserver en ligne
        </a>
        <a
          href="/contact"
          class="px-8 py-4 border-2 border-white text-white font-bold rounded-full hover:bg-white hover:text-purple-700 transition-colors"
        >
          Nous contacter
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
