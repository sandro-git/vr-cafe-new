---
export const prerender = true;
// Welcome to Astro! Everything between these triple-dash code fences
// is your "component frontmatter". It never runs in the browser.
//components
import GameList from "../components/GameList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import GamesLayout from "../layouts/GamesLayout.astro";

import { loadQuery } from "../sanity/lib/load-query";
import { GAMES_BY_TAG_QUERY, type GameListItem } from "../sanity/lib/queries";
import JsonLd from "../components/JsonLd.astro";
import { graph, businessNode, breadcrumb, gameListSchema } from "../lib/seo";

const { data: jeux } = await loadQuery<GameListItem[]>({
  query: GAMES_BY_TAG_QUERY,
  params: { tagTitle: "jeuxVR" },
});

const schema = graph([
  businessNode,
  breadcrumb([
    { name: "Accueil", path: "/" },
    { name: "Jeux VR", path: "/jeux" },
  ]),
  gameListSchema(jeux),
]);
---

<BaseLayout
  title="Tous nos jeux VR à Perpignan | VR Café Canet-en-Roussillon"
  description="Explorez notre catalogue de jeux VR : escape games, free roaming, multijoueur. Salle VR à Canet-en-Roussillon près de Perpignan."
>
  <JsonLd schema={schema} />
  <GamesLayout
    title="Jeux VR"
    highlight="Jeux"
    subtitle="Arcade, sport, action ou contemplatif : explorez notre catalogue de jeux en réalité virtuelle."
  >
    <GameList experiences={jeux} />
  </GamesLayout>
</BaseLayout>
