---
import PageHeader from "../components/PageHeader.astro";

interface Props {
  eyebrow?: string;
  title: string;
  highlight: string;
  subtitle: string;
  filters?: { href: string; label: string }[];
}

const currentPath = Astro.url.pathname;
const { eyebrow = "Catalogue", title, highlight, subtitle, filters } = Astro.props;
---

<section class="bg-[var(--color-surface)]">
  <div class="flex flex-col items-center">
    <PageHeader eyebrow={eyebrow} title={title} highlight={highlight} subtitle={subtitle} />
  </div>

  {filters && filters.length > 0 && (
    <ul class="reveal flex flex-wrap gap-3 justify-center mb-10 px-4">
      {filters.map((f) => {
        const isActive = currentPath === f.href || currentPath === `${f.href}/`;
        return (
          <li>
            <a
              href={f.href}
              class:list={[
                "inline-flex items-center rounded-full px-5 py-2 text-sm font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ring-1",
                isActive
                  ? "text-[var(--color-brand-300)] bg-white/5 ring-[var(--color-brand-500)]/30"
                  : "text-white/75 bg-white/[0.03] ring-white/10 hover:text-white hover:bg-white/10",
              ]}
            >
              {f.label}
            </a>
          </li>
        );
      })}
    </ul>
  )}

  <div class="pb-20 lg:pb-28">
    <slot />
  </div>
</section>
