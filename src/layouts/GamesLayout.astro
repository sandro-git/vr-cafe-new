---
import PageHeader from "../components/PageHeader.astro";

// Récupérer l'URL actuelle pour déterminer la page courante
const currentPath = Astro.url.pathname;
const isEscapesPage =
  currentPath === "/escapes" ||
  currentPath === "/escapes/" ||
  currentPath.includes("/escapes/");

// Déterminer le titre + highlight + sous-titre en fonction de la page
let pageTitle = "Escape Games VR";
let highlight = "Escape Games";
let subtitle = "Résolvez des énigmes immersives en équipe, dans des univers où chaque seconde compte.";

if (currentPath.includes("/jeux")) {
  pageTitle = "Jeux VR";
  highlight = "Jeux";
  subtitle = "Arcade, sport, action ou contemplatif : explorez notre catalogue de jeux en réalité virtuelle.";
} else if (currentPath.includes("/freeroaming")) {
  pageTitle = "VR Sans Fil";
  highlight = "Sans Fil";
  subtitle = "Liberté de mouvement totale : déplacez-vous réellement dans des mondes virtuels, sans aucun câble.";
} else if (currentPath.includes("/escapesFreeroaming")) {
  pageTitle = "Escapes VR Sans Fil";
  highlight = "Sans Fil";
  subtitle = "L'escape game nouvelle génération : marchez, explorez et collaborez en totale liberté.";
}

const filters = [
  { href: "/escapes", label: "Tout" },
  { href: "/escapes/arvi", label: "ARVI VR" },
  { href: "/escapes/ubisoft", label: "Ubisoft" },
];
---

<section class="bg-[var(--color-surface)]">
  <div class="flex flex-col items-center">
    <PageHeader eyebrow="Catalogue" title={pageTitle} highlight={highlight} subtitle={subtitle} />
  </div>

  {isEscapesPage && (
    <ul class="reveal flex flex-wrap gap-3 justify-center mb-10 px-4">
      {filters.map((f) => {
        const isActive = currentPath === f.href || currentPath === `${f.href}/`;
        return (
          <li>
            <a
              href={f.href}
              class:list={[
                "inline-flex items-center rounded-full px-5 py-2 text-sm font-medium tracking-tight transition-colors duration-[var(--dur-fast)] ring-1",
                isActive
                  ? "text-[var(--color-brand-300)] bg-white/5 ring-[var(--color-brand-500)]/30"
                  : "text-white/75 bg-white/[0.03] ring-white/10 hover:text-white hover:bg-white/10",
              ]}
            >
              {f.label}
            </a>
          </li>
        );
      })}
    </ul>
  )}

  <div class="pb-20 lg:pb-28">
    <slot />
  </div>
</section>
