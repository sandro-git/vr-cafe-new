---
import BaseHead from "./BaseHead.astro";
---

<html lang="fr" class="smooth scroll-smooth dark">
  <BaseHead />
  <body class="dark:bg-gray-800">
    <div class="fixed top-0 inset-x-0 z-50 h-12 bg-gray-900/90 backdrop-blur border-b border-gray-700 flex items-center justify-center">
      <a
        href="/reservation"
        target="_blank"
        class="px-6 py-1.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-colors text-sm"
      >
        + Réserver
      </a>
    </div>
    <div class="pt-12">
      <slot />
    </div>
  </body>
</html>
