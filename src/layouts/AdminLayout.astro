---
import BaseHead from "./BaseHead.astro";
const PUBLIC_VAPID_KEY = import.meta.env.PUBLIC_VAPID_KEY ?? "";
---

<html lang="fr" class="smooth scroll-smooth dark">
  <BaseHead />
  <body class="dark:bg-gray-800">
    <div class="fixed top-0 inset-x-0 z-50 h-12 bg-gray-900/90 backdrop-blur border-b border-gray-700 flex items-center justify-center">
      <a
        href="/admin/reservation"
        class="px-6 py-1.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-colors text-sm"
      >
        + Réserver
      </a>
    </div>
    <div class="pt-12">
      <slot />
    </div>
  </body>
</html>

<script define:vars={{ PUBLIC_VAPID_KEY }}>
  if ("serviceWorker" in navigator && "PushManager" in window && PUBLIC_VAPID_KEY) {
    navigator.serviceWorker.register("/sw.js").then(async (registration) => {
      const permission = await Notification.requestPermission();
      if (permission !== "granted") return;

      const existing = await registration.pushManager.getSubscription();
      if (existing) return; // Already subscribed

      const sub = await registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: PUBLIC_VAPID_KEY,
      });

      await fetch("/api/push/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(sub.toJSON()),
      }).catch(() => {});
    }).catch(() => {});
  }
</script>
