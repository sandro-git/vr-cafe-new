---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "VR Café Canet-en-Roussillon — Salle de Réalité Virtuelle & Escape Game | Perpignan",
  description = "Vivez une expérience VR inoubliable à Canet-en-Roussillon. Escape game, jeux multijoueurs, anniversaires & team building. Réservez en ligne !",
  canonical = Astro.url.href,
  ogImage = "https://vr-cafe.fr/og-image.jpg",
} = Astro.props;

const GA_ID = import.meta.env.PUBLIC_GA_ID;
const isProd = import.meta.env.PROD;
---

<head>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1a1a2e" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="VR Café Canet-en-Roussillon — Salle de réalité virtuelle" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="VR Café" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  {isProd && GA_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag("js", new Date());
        gtag("config", GA_ID);
      </script>
    </>
  )}

  <!-- WebMCP: expose site tools to AI agents (https://webmachinelearning.github.io/webmcp/) -->
  <script is:inline>
    (async () => {
      if (!navigator.modelContext) return;

      const ctrl = new AbortController();
      const opts = { signal: ctrl.signal };

      async function mcpCall(name, args) {
        const res = await fetch('/api/mcp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ jsonrpc: '2.0', id: 1, method: 'tools/call', params: { name, arguments: args } }),
        });
        const data = await res.json();
        return data.result?.content?.[0]?.text ?? JSON.stringify(data.result);
      }

      await navigator.modelContext.registerTool({
        name: 'list_games',
        description: 'List VR games available at VR Café Canet-en-Roussillon. Filter by category: jeuxVR, escapeGame, freeroaming, escapeFreeroaming.',
        inputSchema: {
          type: 'object',
          properties: {
            tag: { type: 'string', enum: ['jeuxVR', 'escapeGame', 'freeroaming', 'escapeFreeroaming'] },
          },
        },
        execute: (args) => mcpCall('list_games', args),
      }, opts);

      await navigator.modelContext.registerTool({
        name: 'get_pricing',
        description: 'Get VR session pricing at VR Café Canet-en-Roussillon.',
        inputSchema: { type: 'object', properties: {} },
        execute: () => mcpCall('get_pricing', {}),
      }, opts);

      await navigator.modelContext.registerTool({
        name: 'check_availability',
        description: 'Check available time slots for a VR session at VR Café Canet-en-Roussillon on a given date.',
        inputSchema: {
          type: 'object',
          required: ['date', 'nb_personnes', 'duree_minutes', 'vr_type'],
          properties: {
            date: { type: 'string', description: 'Date (YYYY-MM-DD)' },
            nb_personnes: { type: 'integer', minimum: 1, maximum: 6 },
            duree_minutes: { type: 'integer', enum: [30, 60, 90] },
            vr_type: { type: 'string', enum: ['filaire', 'sans_fil'] },
          },
        },
        execute: (args) => mcpCall('check_availability', args),
      }, opts);

      await navigator.modelContext.registerTool({
        name: 'open_reservation',
        description: 'Navigate to the reservation page to book a VR session at VR Café Canet-en-Roussillon.',
        inputSchema: { type: 'object', properties: {} },
        execute: () => { window.location.href = '/reservation'; return 'Redirecting to reservation page.'; },
      }, opts);
    })();
  </script>
  <slot />
</head>
