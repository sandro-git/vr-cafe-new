---
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import BaseHead from "./BaseHead.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
---

<html lang="fr" class="smooth scroll-smooth pt-16 dark">
  <BaseHead title={title} description={description} canonical={canonical} ogImage={ogImage}>
    <ClientRouter />
  </BaseHead>
  <body class="bg-[var(--color-surface)] text-[var(--color-text-base)]">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NJ2HQDKS"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <NavBar />
    <main>
      <slot />
    </main>
    <Footer />

    {/* TODO: trouver une autre place pour le contact WhatsApp (footer, navbar, page contact) */}
    {/* <FloatingActions /> */}

    <style>
      :root {
        --navHeight: 8rem;
      }
      html {
        scroll-padding-top: var(--navHeight);
      }
    </style>

    <!-- Reveal-on-scroll (IntersectionObserver natif, respect prefers-reduced-motion) -->
    <script is:inline>
      (function () {
        const init = () => {
          const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const targets = document.querySelectorAll(".reveal, .reveal-fade");

          if (reduced || !("IntersectionObserver" in window)) {
            targets.forEach((el) => el.classList.add("is-visible"));
            return;
          }

          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -10% 0px", threshold: 0.08 }
          );

          targets.forEach((el) => io.observe(el));
        };

        // Run now (initial load) and on every navigation (View Transitions)
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
        document.addEventListener("astro:page-load", init);
      })();
    </script>
  </body>
</html>
