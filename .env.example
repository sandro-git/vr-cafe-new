# Mailjet Configuration
# Required for contact form functionality
# Get your API credentials from: https://app.mailjet.com/account/apikeys

MAILJET_API_KEY=your_mailjet_api_key_here
MAILJET_API_SECRET=your_mailjet_api_secret_here
MAILJET_SENDER_EMAIL=contact@vr-cafe.fr

# Sanity CMS (already configured)
PUBLIC_SANITY_PROJECT_ID=0oshw5tf
PUBLIC_SANITY_DATASET=production

# Supabase
PUBLIC_SUPABASE_URL=your_supabase_url_here
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — NE JAMAIS exposer côté client, uniquement dans les fonctions serveur
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
